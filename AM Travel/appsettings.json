{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  //Auth Database
  "ConnectionStrings": {
    "Connection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "",
    "Audience": "",
    "DurationInMinutes": 15
  },

  "OtpSettings": {
    "OtpExpiryMinutes": 10,
    "MaxOtpAttempts": 3,
    "ResendCooldownMinutes": 2,
    "MailWindowDays": 30,
    "MaxMailsInWindow": 20,
    "MaxValidationSendsPerWindow": 10,
    "MaxResetSendsPerWindow": 10,
    "VerifyBlockMinutes": 15,
    "ResetSessionTokenExpiryMinutes": 10
  },

  "PasswordHashSettings": {
    "WorkFactor": 13
  },

  "DataProtectionSettings": {
    "UserDataPurpose": ""
  },

  "RateLimitSettings": {
    "RejectionMessage": "Too many requests. Please try again later.",

    "GlobalLimiter": {
      "PermitLimit": 120,
      "WindowMinutes": 1,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },

    "ApiDefaultPolicy": {
      "PermitLimit": 40,
      "WindowMinutes": 1,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },

    "AuthenticatedUserPolicy": {
      "PermitLimit": 300,
      "WindowMinutes": 5,
      "SegmentsPerWindow": 5,
      "QueueLimit": 0
    },

    "PerUserHeavyOpsPolicy": {
      "PermitLimit": 2,
      "QueueLimit": 0
    },

    "LoginPolicy": {
      "PermitLimit": 5,
      "WindowMinutes": 1,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },

    "RegisterPolicy": {
      "PermitLimit": 3,
      "WindowMinutes": 5,
      "QueueLimit": 0
    },

    "RefreshPolicy": {
      "PermitLimit": 6,
      "WindowMinutes": 1,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },

    "LogoutPolicy": {
      "PermitLimit": 10,
      "WindowMinutes": 1,
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    },

    "HeavyOpsPolicy": {
      "PermitLimit": 8,
      "QueueLimit": 0
    },

    "BurstPerPathPolicy": {
      "PermitLimit": 3,
      "WindowMinutes": 5,
      "QueueLimit": 0
    }
  },

  "Cors": {
    "AllowedOrigins": [
    ]
  },

  "Csrf": {
    "HeaderName": "",
    "CookieName": ""
  },

  "CacheSettings": {
    "Provider": "Memory", // Redis or Memory
    "RedisConnection": ""
  },
  "AppInfo": {
    "Name": "AM Travel",
    "Version": "1"
  },
  "UserThrottle": {
    "Enabled": true,
    "PermitLimit": 7,
    "WindowMinutes": 1,
    "ProtectedPaths": [
    ],
    "ExcludedPaths": [
      "/swagger",
      "/health"
    ]
  },
  "TelegramSettings": {
    "BotToken": "",
    "ChatId": "",
    "SendOTPAfterMinuts": 5,
    "TimeErrorOTP": 3,
    "OtpExpireMinutes": 5
  }
}