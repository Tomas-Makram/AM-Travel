@using AM_Travel.Resources
@using Microsoft.Extensions.Localization
@using DataLayer.Models
@inject IStringLocalizer<SharedResource> L
@model BusinessLayer.DTOs.Company.CompanySeatBookingDetailsDTO
@{
    ViewData["Title"] = L["CSD_Title"];
    var isRoundTrip  = Model.IsRoundTrip || Model.ReturnTripId.HasValue;
    var clientName   = string.IsNullOrWhiteSpace(Model.ClientName)         ? "-" : Model.ClientName;
    var clientPhone  = string.IsNullOrWhiteSpace(Model.ClientPhone)        ? "-" : Model.ClientPhone;
    var companyName  = string.IsNullOrWhiteSpace(Model.CompanyName)        ? "-" : Model.CompanyName;
    var companyPhone = string.IsNullOrWhiteSpace(Model.CompanyPhoneNumber) ? "-" : Model.CompanyPhoneNumber;

    // Build route: split on arrow, isolate each part LTR
    // Returns an HTML string with each city wrapped LTR so arrow never flips
    string BuildRoute(string? route, string? from, string? to)
    {
        // Prefer pre-built route string from manager
        string raw = !string.IsNullOrWhiteSpace(route) ? route
            : (string.IsNullOrWhiteSpace(from) ? "-" : from) + " → " + (string.IsNullOrWhiteSpace(to) ? "-" : to);
        // Split on any arrow variant
        var parts = raw.Split(new[]{ " → ", "->", " -> " }, StringSplitOptions.None);
        if (parts.Length == 2)
        {
            // Wrap each city in a span with explicit LTR direction
            return "<span class=rp-city>" + System.Net.WebUtility.HtmlEncode(parts[0].Trim()) + "</span>"
                 + "<span class=rp-arr>→</span>"
                 + "<span class=rp-city>" + System.Net.WebUtility.HtmlEncode(parts[1].Trim()) + "</span>";
        }
        // fallback: encode entire string
        return System.Net.WebUtility.HtmlEncode(raw);
    }

    var goRouteHtml     = BuildRoute(Model.TripRoute,       Model.FromLocation,       Model.ToLocation);
    var returnRouteHtml = BuildRoute(Model.ReturnTripRoute,  Model.ReturnFromLocation, Model.ReturnToLocation);
    var goSeat      = string.IsNullOrWhiteSpace(Model.SeatLabel)       ? "-" : Model.SeatLabel;
    var returnSeat  = string.IsNullOrWhiteSpace(Model.ReturnSeatLabel) ? "-" : Model.ReturnSeatLabel;

    string TranslateDir(string? raw) => raw?.Trim() switch
    {
        "Inbound"   or "Go"        or "Departure" => L["CSD_DirGo"].Value,
        "Outbound"  or "Return"                   => L["CSD_DirReturn"].Value,
        "RoundTrip" or "Round Trip"               => L["CSD_DirRound"].Value,
        _                                         => raw ?? "-"
    };

    string fullName = Convert.ToString(ViewBag.Name) ?? "User";
    var cleanName   = fullName.Trim().Replace("  ", " ");
    var initials    = string.Join("", cleanName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper();
    if (string.IsNullOrWhiteSpace(initials)) initials = "U";
}

<style>
:root {
    /* Hero */
    --csd-hero-bg:       linear-gradient(135deg, #ff7a18, #ffad42);
    --csd-hero-glow:     rgba(255,122,24,.18);
    --csd-hero-text:     #fff;
    --csd-hero-sub:      rgba(255,255,255,.92);
    --csd-glass:         rgba(255,255,255,.16);
    /* Page background */
    --csd-page-bg:       #f5f7fb;
    /* Info cards — dark navy intentional for data readability */
    --csd-card-bg:       #172033;
    --csd-card-border:   #334155;
    --csd-card-text:     #fff;
    --csd-card-title:    #fff;
    --csd-row-bg:        #0f172a;
    --csd-row-border:    #27364f;
    --csd-label-txt:     #94a3b8;
    --csd-val-txt:       #f1f5f9;
    /* Route pill */
    --csd-route-bg:      rgba(255,122,24,.14);
    --csd-route-bdr:     rgba(255,122,24,.28);
    --csd-route-txt:     #ffad42;
    /* Notes */
    --csd-note-bg:       rgba(255,122,24,.12);
    --csd-note-bdr:      rgba(255,122,24,.22);
    --csd-note-txt:      #ffad42;
}

/* Dark theme only changes hero gradient + slightly deeper card shades */
html[data-theme="dark"] {
    --csd-hero-bg:       linear-gradient(135deg, #c45c0a, #d97c2a);
    --csd-hero-glow:     rgba(196,92,10,.22);
    --csd-hero-text:     #f5f0eb;
    --csd-hero-sub:      rgba(245,240,235,.85);
    --csd-glass:         rgba(255,255,255,.12);
    --csd-page-bg:       #0f172a;
    --csd-card-bg:       #1e2b3f;
    --csd-card-border:   #2c3b55;
    --csd-row-bg:        #131f30;
    --csd-row-border:    #243550;
}

.csd-page { display: grid; gap: 24px; }

/* ── Hero ── */
.csd-hero { position: relative; overflow: hidden; border-radius: 32px; padding: 38px; color: var(--csd-hero-text); background: var(--csd-hero-bg); box-shadow: 0 24px 70px var(--csd-hero-glow); }
.csd-hero::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 26%); pointer-events: none; }
.csd-hero::after  { content: ""; position: absolute; width: 270px; height: 270px; right: -95px; bottom: -115px; border-radius: 50%; background: rgba(255,255,255,.12); pointer-events: none; }
.csd-hero-inner { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
.csd-badge { width: fit-content; padding: 8px 16px; border-radius: 999px; background: rgba(255,255,255,.18); border: 1px solid rgba(255,255,255,.28); font-weight: 1000; color: var(--csd-hero-text); }
.csd-hero h1 { margin: 18px 0 0; font-size: clamp(40px,5.5vw,62px); line-height: 1; letter-spacing: -1.5px; color: var(--csd-hero-text); }
.csd-hero p  { margin: 16px 0 0; font-size: 17px; font-weight: 700; color: var(--csd-hero-sub); }

/* ── Avatar ring ── */
.csd-av-wrap { position: relative; width: 150px; height: 150px; border-radius: 42px; background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.22); display: grid; place-items: center; flex-shrink: 0; }
.csd-av-wrap::before { content: ""; position: absolute; inset: -8px; border-radius: 48px; border: 3px solid rgba(255,255,255,.22); }
.csd-av-wrap::after  { content: ""; position: absolute; inset: -8px; border-radius: 48px; border: 3px solid transparent; border-top-color: #fff; border-right-color: rgba(255,255,255,.72); animation: csd-spin 4s linear infinite; }
@@keyframes csd-spin { to { transform: rotate(360deg); } }
.csd-av { position: relative; z-index: 2; width: 112px; height: 112px; border-radius: 32px; background: #fff; color: #ff6a00; display: grid; place-items: center; font-size: 42px; font-weight: 1000; box-shadow: 0 18px 38px rgba(0,0,0,.14); }
.csd-av-status { position: absolute; right: 22px; bottom: 20px; z-index: 3; width: 20px; height: 20px; border-radius: 50%; background: #12b76a; border: 4px solid #fff; }

/* ── Buttons ── */
.csd-actions { position: relative; z-index: 2; display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
.csd-btn { min-height: 46px; padding: 0 18px; border-radius: 16px; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; font-weight: 900; cursor: pointer; border: none; white-space: nowrap; transition: .2s ease; font-size: 14px; }
.csd-btn:hover { transform: translateY(-2px); }
.csd-btn-white { background: #fff; color: #ff7a18; box-shadow: 0 14px 30px rgba(0,0,0,.12); }
.csd-btn-glass { background: var(--csd-glass); border: 1px solid rgba(255,255,255,.28); color: var(--csd-hero-text); }

/* ── Two-column grid ── */
.csd-grid { display: grid; grid-template-columns: 1.25fr 0.75fr; gap: 20px; align-items: start; }

/* ── Cards ── */
.csd-card { background: var(--csd-card-bg); border: 1px solid var(--csd-card-border); border-radius: 28px; padding: 24px; color: var(--csd-card-text); box-shadow: 0 18px 44px rgba(0,0,0,.20); transition: background .3s, border-color .3s; }
.csd-card h2 { margin: 0 0 20px; font-size: 22px; font-weight: 1000; color: var(--csd-card-title); border-bottom: 1px solid var(--csd-card-border); padding-bottom: 14px; }

/* ── Info rows ── */
.csd-list { display: grid; gap: 8px; }
.csd-row  { display: grid; grid-template-columns: 190px 1fr; gap: 14px; padding: 13px 16px; border-radius: 16px; background: var(--csd-row-bg); border: 1px solid var(--csd-row-border); transition: background .3s, border-color .3s; align-items: center; }
.csd-row small  { color: var(--csd-label-txt); font-weight: 900; font-size: 13px; text-transform: uppercase; letter-spacing: .04em; }
.csd-row strong { color: var(--csd-val-txt); font-weight: 1000; overflow-wrap: anywhere; font-size: 15px; }

/* ── Route pill — THE FIX */
/* Container forces LTR so the arrow never flips on Arabic pages */
.route-pill {
    display: inline-flex;
    align-items: center;
    gap: 0;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--csd-route-bg);
    border: 1px solid var(--csd-route-bdr);
    color: var(--csd-route-txt);
    font-weight: 1000;
    font-size: 14px;
    direction: ltr;           /* force LTR on pill wrapper */
    unicode-bidi: embed;      /* isolate from surrounding RTL */
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
}
/* Each city name uses RTL (so Arabic text renders correctly)
   but the flex order stays: City1 → City2 because the *pill* is LTR */
.rp-city {
    direction: rtl;
    unicode-bidi: isolate;
    display: inline-block;
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    vertical-align: middle;
}
.rp-arr {
    display: inline-block;
    padding: 0 8px;
    direction: ltr;
    unicode-bidi: isolate;
    vertical-align: middle;
    opacity: .8;
    font-size: 16px;
}

/* ── Money grid ── */
.csd-money { display: grid; gap: 12px; }
.csd-mbox  { background: var(--csd-row-bg); border: 1px solid var(--csd-row-border); border-radius: 18px; padding: 18px 20px; transition: background .3s, border-color .3s; }
.csd-mbox small  { display: block; color: var(--csd-label-txt); font-weight: 900; margin-bottom: 6px; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; }
.csd-mbox strong { font-size: 28px; font-weight: 1000; color: var(--csd-val-txt); }
.txt-success { color: #34d399 !important; }
.txt-warning { color: #ffad42 !important; }
.txt-danger  { color: #f87171 !important; }

/* ── Notes ── */
.csd-note { margin-top: 16px; padding: 14px 16px; border-radius: 16px; background: var(--csd-note-bg); border: 1px solid var(--csd-note-bdr); color: var(--csd-note-txt); font-weight: 900; font-size: 14px; }

/* ── Responsive ── */
@@media (max-width: 950px) { .csd-grid { grid-template-columns: 1fr; } }
@@media (max-width: 650px)  {
    .csd-row { grid-template-columns: 1fr; }
    .csd-actions { flex-direction: column; }
    .csd-btn { width: 100%; }
    .csd-av-wrap { width: 112px; height: 112px; border-radius: 32px; }
    .csd-av-wrap::before, .csd-av-wrap::after { border-radius: 38px; }
    .csd-av { width: 88px; height: 88px; font-size: 34px; border-radius: 27px; }
}
</style>

<div class="csd-page">

    @* ── Hero ── *@
    <section class="csd-hero">
        <div class="csd-hero-inner">
            <div>
                <span class="csd-badge">@L["CSD_Badge"]</span>
                <h1>@L["CSD_Heading"]</h1>
                <p>@L["CSD_Subtitle"]</p>
            </div>
            <div class="csd-av-wrap">
                <div class="csd-av">@initials</div>
                <span class="csd-av-status"></span>
            </div>
        </div>
        <div class="csd-actions">
            <a class="csd-btn csd-btn-white" href="javascript:history.back()"> @L["CSD_BackToTrips"] </a>
            <a class="csd-btn csd-btn-glass" asp-action="Trips">@L["CSD_CompanyTrips"]</a>
        </div>
    </section>

    <section class="csd-grid">

        @* ── Booking info card ── *@
        <div class="csd-card">
            <h2>@L["CSD_BookingInfo"]</h2>
            <div class="csd-list">

                <div class="csd-row"><small>@L["CSD_Company"]</small><strong>@companyName</strong></div>
                <div class="csd-row"><small>@L["CSD_CompanyPhone"]</small><strong style="direction:ltr;unicode-bidi:isolate;">@companyPhone</strong></div>
                <div class="csd-row"><small>@L["CSD_ClientName"]</small><strong>@clientName</strong></div>
                <div class="csd-row"><small>@L["CSD_ClientPhone"]</small><strong style="direction:ltr;unicode-bidi:isolate;">@clientPhone</strong></div>
                <div class="csd-row"><small>@L["CSD_TripType"]</small><strong>@TranslateDir(Model.ClientTripType.ToString())</strong></div>
                <div class="csd-row"><small>@L["CSD_BookingDir"]</small><strong>@TranslateDir(Model.BookingDirection.ToString())</strong></div>

                @* ── Go trip ── *@
                <div class="csd-row">
                    <small>@L["CSD_GoRoute"]</small>
                    <strong><span class="route-pill">@Html.Raw(goRouteHtml)</span></strong>
                </div>
                <div class="csd-row">
                    <small>@L["CSD_GoTripDate"]</small>
                    <strong>@(Model.TripDate.HasValue ? Model.TripDate.Value.ToString("yyyy-MM-dd") : "-")</strong>
                </div>
                <div class="csd-row">
                    <small>@L["CSD_GoBus"]</small>
                    <strong>@(string.IsNullOrWhiteSpace(Model.TripBusName) ? "-" : Model.TripBusName)</strong>
                </div>
                <div class="csd-row">
                    <small>@L["CSD_GoPlate"]</small>
                    <strong style="direction:ltr;unicode-bidi:isolate;">@(string.IsNullOrWhiteSpace(Model.TripPlateNumber) ? "-" : Model.TripPlateNumber)</strong>
                </div>
                <div class="csd-row"><small>@L["CSD_GoSeat"]</small><strong>@goSeat</strong></div>

                @* ── Return trip (round trip only) ── *@
                @if (isRoundTrip)
                {
                    <div class="csd-row">
                        <small>@L["CSD_ReturnRoute"]</small>
                        <strong><span class="route-pill">@Html.Raw(returnRouteHtml)</span></strong>
                    </div>
                    <div class="csd-row">
                        <small>@L["CSD_ReturnTripDate"]</small>
                        <strong>@(Model.ReturnTripDate.HasValue ? Model.ReturnTripDate.Value.ToString("yyyy-MM-dd") : "-")</strong>
                    </div>
                    <div class="csd-row">
                        <small>@L["CSD_ReturnBus"]</small>
                        <strong>@(string.IsNullOrWhiteSpace(Model.ReturnBusName) ? "-" : Model.ReturnBusName)</strong>
                    </div>
                    <div class="csd-row">
                        <small>@L["CSD_ReturnPlate"]</small>
                        <strong style="direction:ltr;unicode-bidi:isolate;">@(string.IsNullOrWhiteSpace(Model.ReturnPlateNumber) ? "-" : Model.ReturnPlateNumber)</strong>
                    </div>
                    <div class="csd-row"><small>@L["CSD_ReturnSeat"]</small><strong>@returnSeat</strong></div>
                }

                <div class="csd-row"><small>@L["CSD_Transfer"]</small><strong>@(Model.IsTransfer ? L["CSD_Yes"].Value : L["CSD_No"].Value)</strong></div>
                <div class="csd-row"><small>@L["CSD_CreatedAt"]</small><strong>@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</strong></div>

            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div class="csd-note"><strong>@L["CSD_Notes"]:</strong> @Model.Notes</div>
            }
        </div>

        @* ── Payment card ── *@
        <div class="csd-card">
            <h2>@L["CSD_PaymentDetails"]</h2>
            <div class="csd-money">
                <div class="csd-mbox">
                    <small>@L["CSD_PricePerSeat"]</small>
                    <strong>@Model.PricePerSeat.ToString("N2")</strong>
                </div>
                <div class="csd-mbox">
                    <small>@L["CSD_Total"]</small>
                    <strong class="txt-warning">@Model.TotalPrice.ToString("N2")</strong>
                </div>
                <div class="csd-mbox">
                    <small>@L["CSD_Paid"]</small>
                    <strong class="txt-success">0.00</strong>
                </div>
                <div class="csd-mbox">
                    <small>@L["CSD_Remaining"]</small>
                    <strong class="txt-danger">@Model.TotalPrice.ToString("N2")</strong>
                </div>
            </div>
        </div>

    </section>
</div>
