.dashboard-avatar{position:relative;z-index:2;width:104px;height:104px;border-radius:32px;display:grid;place-items:center;background:radial-gradient(circle at 30% 20%,rgba(255,255,255,.9),rgba(255,255,255,.72)),linear-gradient(135deg,#fff,#fff3e6);color:#ff7a18;font-size:42px;font-weight:1000;text-transform:uppercase;box-shadow:0 18px 38px rgba(0,0,0,.16)}
