    -webkit-overflow-scrolling:touch;
    scrollbar-width:thin;
    scrollbar-color:var(--or) var(--input);
}

.tw-scrollbar::-webkit-scrollbar{
    height:14px;
}

.tw-scrollbar::-webkit-scrollbar-track{
    background:var(--input);
    border-radius:999px;
    border:1px solid var(--ln);
}

.tw-scrollbar::-webkit-scrollbar-thumb{
    background:linear-gradient(135deg,var(--or),var(--or2));
    border-radius:999px;
    border:2px solid var(--input);
}

.tw-scrollbar::-webkit-scrollbar-thumb:hover{
    background:linear-gradient(135deg,#ff8f33,#ffbb5c);
}

.tw-scrollbar-inner{
    height:1px;
    width:1800px;
}

@@media(max-width:1200px){
    .tw table{
        min-width:1900px !important;
    }
}

@@media(max-width:800px){
    .tw table{
        min-width:2000px !important;
    }
}

</style>

<div class="dashboard-page csb-page">
    <section class="dashboard-hero">
        <div class="dashboard-hero-inner">
            <div class="dashboard-title">
                <span class="dashboard-badge">@L["SB_Badge"]</span>
                <h1>@L["SB_Heading"]</h1>
                <p>@L["SB_WelcomeBack"] @currentName. @L["SB_SubtitleRole"]</p>
            </div>
            <div class="dashboard-avatar-wrap" title="@currentName">
                <div class="dashboard-avatar">@initials</div>
                <span class="dashboard-avatar-status"></span>
            </div>
        </div>
        <div class="dashboard-actions">
            <a class="dashboard-btn btn-glass" asp-controller="Transportation" asp-action="CompanySeatAccounting">@L["SB_BtnAccounting"]</a>
            <a class="dashboard-btn btn-glass" asp-controller="Transportation" asp-action="Trips">@L["SB_BtnTrips"]</a>
            <a class="dashboard-btn btn-glass" asp-controller="Transportation" asp-action="Index">@L["SB_BtnCompanyTrips"]</a>
        </div>
    </section>

    <section class="summary-grid">
        <div class="summary-card"><small>@L["SB_CardActiveTab"]</small><strong>@activeTab</strong></div>
        <div class="summary-card"><small>@L["SB_CardLocations"]</small><strong>@(Model.Locations?.Count ?? 0)</strong></div>
        <div class="summary-card"><small>@L["SB_CardBuses"]</small><strong>@(Model.Buses?.Count ?? 0)</strong></div>
        <div class="summary-card">
            <small>@L["SB_CardSearchRows"]</small>
            <strong>
                @(Model.SearchResults?
                    .Sum(x => x.Seats?.Sum(s => Math.Max(1, s.SeatsCount)) ?? 0) ?? 0)
            </strong>
        </div>
    </section>

    <datalist id="locList">
        @foreach (var loc in Model.Locations ?? new List<string>())
        {
            <option value="@loc"></option>
        }
    </datalist>

    <div class="dashboard-filter-card">
        <div class="tab-bar">
            <button type="button" class="tab-btn @(activeTab == "bookTab" ? "active" : "")" onclick="showTab('bookTab', this)">@L["SB_TabBook"]</button>
            <button type="button" class="tab-btn @(activeTab == "transferTab" ? "active" : "")" onclick="showTab('transferTab', this)">@L["SB_TabTransfer"]</button>
            <button type="button" class="tab-btn @(activeTab == "searchTab" ? "active" : "")" onclick="showTab('searchTab', this)">@L["SB_TabSearch"]</button>
        </div>
    </div>

    @* ═══════════════ BOOK TAB ═══════════════ *@
    <section id="bookTab" class="csb-tab" style="display:@(activeTab == "bookTab" ? "" : "none")">
        <div class="dashboard-filter-card">
            <h2 class="panel-title">@L["SB_BookTitle"]</h2>
            <form asp-controller="Transportation" asp-action="SeatBookingBound" method="get" id="routeSearchForm">
                <input type="hidden" name="ActiveTab" value="bookTab" />
                <div class="grid" style="margin-bottom:16px;align-items:flex-end;">
                    <div class="field">
                        <label>@L["SB_TripDate"]</label>
                        <input class="fc" type="date" name="TripDate" value="@tripDateValue" />
                    </div>
                    <div class="field">
                        <label>@L["SB_RouteFrom"]</label>
                        <select class="fc" name="RouteFrom" id="routeFrom" required>
                            <option value="">@L["SB_SelectRouteFrom"]</option>
                            @foreach (var loc in Model.Locations ?? new List<string>())
                            {
                                <option value="@loc" selected="@(Model.RouteFrom == loc)">@loc</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>@L["SB_RouteTo"]</label>
                        <select class="fc" name="RouteTo" id="routeTo" required>
                            <option value="">@L["SB_SelectRouteTo"]</option>
                            @foreach (var loc in Model.Locations ?? new List<string>())
                            {
                                <option value="@loc" selected="@(Model.RouteTo == loc)">@loc</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>@L["SB_SeatsCount"]</label>
                        <input class="fc" type="number" min="1" step="1" name="RequiredSeats" value="@(Model.RequiredSeats < 1 ? 1 : Model.RequiredSeats)" required />
                    </div>
                    <div class="field" style="display:flex;align-items:flex-end;">
                        <button class="btn btn-primary" type="submit">@L["SB_BtnShowTrips"]</button>
                    </div>
                </div>
            </form>

            @if (string.IsNullOrWhiteSpace(Model.RouteFrom) || string.IsNullOrWhiteSpace(Model.RouteTo))
            {
                <p class="empty-msg">@L["SB_SelectRoute"]</p>
            }
            else if (Model.Buses == null || !Model.Buses.Any())
            {
                <p class="empty-msg">@L["SB_NoTrips"]</p>
            }
            else
            {
                if (Model.Buses.All(x => x.IsFallbackOption))
                {
                    <div class="info-box amber">@L["SB_FallbackInfo"]</div>
                }
                <div class="bus-cards">
                    @foreach (var b in Model.Buses)
                    {
                        var selected = Model.SelectedBusId == b.BusId && Model.SelectedTripId == b.TripId;
                        <a class="bus-card @(selected ? "selected" : "") @(b.HasTrip ? "trip-card-ready" : "trip-card-empty")"
                           asp-controller="Transportation" asp-action="SeatBookingBound"
                           asp-route-ActiveTab="bookTab" asp-route-TripDate="@tripDateValue"
                           asp-route-RouteFrom="@Model.RouteFrom" asp-route-RouteTo="@Model.RouteTo"
                           asp-route-RequiredSeats="@Model.RequiredSeats" asp-route-Direction="@b.Direction"
                           asp-route-SelectedBusId="@b.BusId" asp-route-SelectedTripId="@b.TripId">
                            <div class="trip-card-head">
                                <div>
                                    <div class="bc-name">🚌 @b.BusName</div>
                                    @if (!string.IsNullOrWhiteSpace(b.PlateNumber))
                                    {
                                        <div class="trip-card-meta">@L["SB_Plate"] @b.PlateNumber</div>
                                    }
                                    <div class="trip-card-meta">@L["SB_Direction"] <strong>@DirTextEn(b.Direction)</strong></div>
                                    @if (b.TripDate.HasValue)
                                    {
                                        <div class="trip-card-meta">@L["SB_Date"] @b.TripDate.Value.ToString("yyyy-MM-dd")</div>
                                    }
                                </div>
                                @if (!b.HasTrip)
                                {
                                    <span class="bc-new bc-create trip-card-badge">@L["SB_NewTrip"]</span>
                                }
                                else
                                {
                                    <span class="bc-new bc-enough trip-card-badge">@L["SB_AvailTrip"]</span>
                                }
                            </div>
                            <div class="trip-card-route"><span>@b.FromLocation</span><span>→</span><span>@b.ToLocation</span></div>
                            <div class="bc-stats">
                                <span class="bc-stat bc-dir">@DirTextEn(b.Direction)</span>
                                <span class="bc-stat total">@L["SB_Total"] @b.TotalSeats</span>
                                @if (b.ClientReserved > 0){<span class="bc-stat client">@L["SB_Clients"] @b.ClientReserved</span>}
                                @if (b.CompanyReserved > 0){<span class="bc-stat company">@L["SB_Companies"] @b.CompanyReserved</span>}
                                <span class="bc-stat avail">@L["SB_Available"] @b.AvailableSeats</span>
                                <span class="bc-stat @(b.AvailableSeats >= Model.RequiredSeats ? "avail" : "zero")">@L["SB_Required"] @Model.RequiredSeats</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        @if (Model.SeatMap != null)
        {
            var map = Model.SeatMap;
            var cellSize = map.Columns >= 8 ? 46 : map.Columns >= 6 ? 50 : 54;
            var gap = map.Columns >= 8 ? 5 : 7;
            var busWidth = map.Columns * cellSize + (map.Columns - 1) * gap + 82;
            var byPos = map.Seats.ToDictionary(x => $"{x.RowNumber}_{x.ColumnNumber}", x => x);

            <form asp-controller="Transportation" asp-action="SeatBookingBoundBook" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="BusId" value="@map.BusId" />
                <input type="hidden" name="TripId" value="@(map.TripId?.ToString() ?? string.Empty)" />
                <input type="hidden" name="TripDate" value="@tripDateValue" />
                <input type="hidden" name="Direction" value="@hiddenDirection" />
                <input type="hidden" name="RequiredSeats" value="@Model.RequiredSeats" />
                <input type="hidden" name="ClientTripType" value="@autoClientTripType" />

                <div class="panel">
                    <h2 class="panel-title">@L["SB_BookDetails"]</h2>
                    @if (!map.TripId.HasValue)
                    {
                        <div class="info-box amber">⚠️ @L["SB_NoSeatsWarning"]</div>
                    }
                    <div class="grid-3" style="margin-bottom:14px;">
                        <div class="field">
                            <label>@L["SB_Company"]</label>
                            <select class="fc" name="CompanyId" required>
                                <option value="">@L["SB_SelectCompany"]</option>
                                @foreach (var c in Model.Companies ?? new List<SelectListItem>())
                                {
                                    <option value="@c.Value">@c.Text</option>
                                }
                            </select>
                        </div>
                        <div class="field"><label>@L["SB_PricePerSeat"]</label><input class="fc" type="number" min="0" step="0.01" name="PricePerSeat" value="0" /></div>
                        <div class="field"><label>@L["SB_Notes"]</label><input class="fc" name="Notes" placeholder='@L["SB_NotesOptional"].Value' /></div>
                    </div>
                    <fieldset class="client-section">
                        <legend>@L["SB_ClientInfo"]</legend>
                        <div class="grid-3">
                            <div class="field"><label>@L["SB_ClientTripType"]</label><input class="fc" value="@DirTextEn(Model.Direction)" readonly /></div>
                            <div class="field"><label>@L["SB_ClientName"]</label><input class="fc" name="ClientName" placeholder='@L["SB_ClientName"].Value' required/></div>
                            <div class="field"><label>@L["SB_ClientPhone"]</label><input class="fc" name="ClientPhone" placeholder="01xxxxxxxxx" maxlength="11" required/></div>
                        </div>
                    </fieldset>
                    <div class="grid-2" style="margin-bottom:16px;">
                        <div class="field"><label>@L["SB_FromLocation"]</label><input class="fc" list="locList" name="FromLocation" value="@(string.IsNullOrWhiteSpace(Model.RouteFrom) ? map.FromLocation : Model.RouteFrom)" required /></div>
                        <div class="field"><label>@L["SB_ToLocation"]</label><input class="fc" list="locList" name="ToLocation" value="@(string.IsNullOrWhiteSpace(Model.RouteTo) ? map.ToLocation : Model.RouteTo)" required /></div>
                    </div>
                    <h2 class="panel-title">@L["SB_SeatMap"] - @map.BusName</h2>
                    <div class="bus-shell">
                        <div class="bus-stage" style="--cols:@map.Columns;--cell-size:@(cellSize)px;--cell-gap:@(gap)px;--bus-width:@(busWidth)px;">
                            <div class="bus-nose"><div class="bus-windshield"></div></div>
                            <div class="bus-body">
                                <div class="bus-meta"><span>@map.BusName</span><span>@DirTextEn(Model.Direction)</span><span>@map.Rows × @map.Columns</span></div>
                                <div class="bus-grid">
                                    @for (var r = 1; r <= map.Rows; r++)
                                    {
                                        for (var c = 1; c <= map.Columns; c++)
                                        {
                                            var key = $"{r}_{c}";
                                            if (!byPos.TryGetValue(key, out var seat))
                                            {
                                                <div class="bus-cell empty"></div>
                                                continue;
                                            }
                                            var css = SeatCss(seat.SeatType);
                                            var label = string.IsNullOrWhiteSpace(seat.SeatLabel) ? seat.SeatNumber.ToString() : seat.SeatLabel;
                                            var extra = !seat.IsActive ? "disabled-seat" : seat.IsClientReserved ? "reserved-seat" : seat.IsCompanyReserved ? "company-reserved" : seat.IsSelectable ? "selectable" : "";
                                            if (seat.IsSelectable)
                                            {
                                                <label><input class="seat-check" type="checkbox" name="SeatIds" value="@seat.SeatId" /><span class="bus-cell @css @extra">@label</span></label>
                                            }
                                            else
                                            {
                                                <div class="bus-cell @css @extra">@label</div>
                                            }
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div style="margin-top:18px;display:flex;gap:12px;flex-wrap:wrap;">
                        <button class="btn btn-primary" type="submit">@L["SB_BtnConfirm"]</button>
                        <a class="btn btn-light" asp-controller="Transportation" asp-action="SeatBookingBound">@L["SB_BtnReset"]</a>
                    </div>
                </div>
            </form>
        }
    </section>

    @* ═══════════════ TRANSFER TAB ═══════════════ *@
    <section id="transferTab" class="csb-tab" style="display:@(activeTab == "transferTab" ? "" : "none")">
        <div class="dashboard-filter-card">
            <h2 class="panel-title">@L["SB_TransferTitle"]</h2>
            <form asp-controller="Transportation" asp-action="SeatBookingBoundFindTransfer" method="get">
                <input type="hidden" name="ActiveTab" value="transferTab" />
                <div class="grid" style="margin-bottom:14px;align-items:flex-end;">
                    <div class="field"><label>@L["SB_TripDate"]</label><input class="fc" type="date" name="TransferTripSearch.TripDate" value="@(transferSearch.TripDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" required /></div>
                    <div class="field"><label>@L["SB_RouteFrom"]</label><select class="fc" name="TransferTripSearch.RouteFrom" required><option value="">@L["SB_SelectRouteFrom"]</option>@foreach (var loc in Model.Locations ?? new List<string>()){<option value="@loc" selected="@(transferSearch.RouteFrom == loc)">@loc</option>}</select></div>
                    <div class="field"><label>@L["SB_RouteTo"]</label><select class="fc" name="TransferTripSearch.RouteTo" required><option value="">@L["SB_SelectRouteTo"]</option>@foreach (var loc in Model.Locations ?? new List<string>()){<option value="@loc" selected="@(transferSearch.RouteTo == loc)">@loc</option>}</select></div>
                    <div class="field" style="display:flex;align-items:flex-end;"><button class="btn btn-primary" type="submit">@L["SB_BtnShowTransfer"]</button></div>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(transferSearch.RouteFrom) && !string.IsNullOrWhiteSpace(transferSearch.RouteTo))
            {
                if (Model.TransferTrips == null || !Model.TransferTrips.Any())
                {
                    <p class="empty-msg">@L["SB_NoTransferTrips"]</p>
                }
                else
                {
                    <h3 class="panel-title" style="font-size:16px;">@L["SB_AvailableTrips"]</h3>
                    <div class="bus-cards">
                        @foreach (var t in Model.TransferTrips)
                        {
                            var selected = transferSearch.SelectedTripId == t.TripId;
                            <a class="bus-card @(selected ? "selected" : "") trip-card-ready" asp-controller="Transportation" asp-action="SeatBookingBoundFindTransfer" asp-route-ActiveTab="transferTab" asp-route-TransferTripSearch.TripDate="@t.TripDate.ToString("yyyy-MM-dd")" asp-route-TransferTripSearch.RouteFrom="@transferSearch.RouteFrom" asp-route-TransferTripSearch.RouteTo="@transferSearch.RouteTo" asp-route-TransferTripSearch.SelectedTripId="@t.TripId">
                                <div class="trip-card-head"><div><div class="bc-name">🚌 @t.BusName</div><div class="trip-card-meta">@L["SB_Direction"] <strong>@t.DirectionText</strong></div><div class="trip-card-meta">@L["SB_Date"] @t.TripDate.ToString("yyyy-MM-dd")</div></div><span class="bc-new bc-enough trip-card-badge">@L["SB_Trip"]</span></div>
                                <div class="trip-card-route"><span>@t.FromLocation</span><span>→</span><span>@t.ToLocation</span></div>
                                <div class="bc-stats"><span class="bc-stat client">@L["SB_Bookings"] @t.ClientBookingsCount</span><span class="bc-stat avail">@L["SB_ClientSeats"] @t.ClientSeatsCount</span>@if (t.CompanySeatsCount > 0){<span class="bc-stat company">@L["SB_CompanySeats"] @t.CompanySeatsCount</span>}</div>
                            </a>
                        }
                    </div>
                }
            }
        </div>

        @if (Model.TransferTripDetails != null)
        {
            var d = Model.TransferTripDetails;
            <div class="panel">
                <h2 class="panel-title">@L["SB_TripDetails"]</h2>
                <div class="sum-strip" style="margin-bottom:16px;">
                    <div class="sum-card"><small>@L["SB_Trip"]</small><strong style="font-size:14px;">@d.BusName</strong></div>
                    <div class="sum-card"><small>@L["SB_Route"]</small><strong class="route-cell" style="font-size:14px;"><span class="route-text"><bdi>@d.FromLocation</bdi><span class="route-arrow">→</span><bdi>@d.ToLocation</bdi></span></strong></div>
                    <div class="sum-card"><small>@L["SB_Bookings"]</small><strong>@d.BookingsCount</strong></div>
                    <div class="sum-card"><small>@L["SB_TotalSeats"]</small><strong>@d.SeatsCount</strong></div>
                    <div class="sum-card"><small>@L["SB_CompanySeats"]</small><strong>@d.CompanySeatsCount</strong></div>
                </div>
                @if ((d.PassengerSeats == null || !d.PassengerSeats.Any()) && (d.CompanySeats == null || !d.CompanySeats.Any()))
                {
                    <p class="empty-msg">@L["SB_NoSeats"]</p>
                }
                else
                {
                    <form asp-controller="Transportation" asp-action="SeatBookingBoundTransfer" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TripId" value="@d.TripId" />
                        <input type="hidden" name="ExternalTripDate" value="@d.TripDate.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="FromLocation" value="@d.FromLocation" />
                        <input type="hidden" name="ToLocation" value="@d.ToLocation" />

                        @if (d.PassengerSeats != null && d.PassengerSeats.Any())
                        {
                            <h3 class="panel-title" style="font-size:16px;margin-top:4px;">@L["SB_ClientSeatsTitle"]</h3>
                            <div class="tw" style="margin-bottom:16px;"><table><thead><tr><th>@L["SB_ColCheck"]</th><th>@L["SB_ColCode"]</th><th>@L["SB_ColClient"]</th><th>@L["SB_ColPhone"]</th><th>@L["SB_ColSeat"]</th><th>@L["SB_ColDirection"]</th><th>@L["SB_ColRoute"]</th><th>@L["SB_ColPrice"]</th><th>@L["SB_ColStatus"]</th></tr></thead><tbody>
                                @foreach (var s in d.PassengerSeats)
                                {
                                    <tr class="tr-seat-row @(s.AlreadyTransferred ? "transferred" : "")"><td>@if (s.AlreadyTransferred){<span class="tag tag-trip">@L["SB_TagTransferred"]</span>}else{<input type="checkbox" name="BookingSeatIds" value="@s.BookingSeatId" />}</td><td><b>@s.BookingCode</b></td><td>@s.ClientName</td><td>@(string.IsNullOrWhiteSpace(s.ClientPhone) ? "—" : s.ClientPhone)</td><td><b>@s.SeatLabel</b></td><td>@s.DirectionText</td><td class="route-cell"><span class="route-text"><bdi>@s.FromLocation</bdi><span class="route-arrow">→</span><bdi>@s.ToLocation</bdi></span></td><td class="ok">@s.SeatPrice.ToString("N2")</td><td>@if (s.AlreadyTransferred){<span class="tag tag-trip">@L["SB_TagTransferredTo"] @s.TransferredToCompany</span>}else{<span class="tag tag-in">@L["SB_TagAvailable"]</span>}</td></tr>
                                }
                            </tbody></table></div>
                        }

                        @if (d.CompanySeats != null && d.CompanySeats.Any())
                        {
                            <h3 class="panel-title" style="font-size:16px;margin-top:18px;">@L["SB_CompSeatsTitle"]</h3>
                            <div class="tw" style="margin-bottom:16px;"><table><thead><tr><th>@L["SB_ColCheck"]</th><th>@L["SB_Company"]</th><th>@L["SB_ColCompPhone"]</th><th>@L["SB_ColSeat"]</th><th>@L["SB_ColCompClient"]</th><th>@L["SB_ColClientPhone"]</th><th>@L["SB_ColRoute"]</th><th>@L["SB_ColPrice"]</th><th>@L["SB_ColStatus"]</th></tr></thead><tbody>
                                @foreach (var cs in d.CompanySeats)
                                {
                                    <tr><td><input type="checkbox" name="CompanySeatBookingIds" value="@cs.CompanySeatBookingId" /></td><td><b>@cs.CompanyName</b></td><td>@cs.CompanyPhone</td><td><b>@cs.SeatLabel</b></td><td>@(string.IsNullOrWhiteSpace(cs.ClientName) ? "—" : cs.ClientName)</td><td>@(string.IsNullOrWhiteSpace(cs.ClientPhone) ? "—" : cs.ClientPhone)</td><td class="route-cell"><span class="route-text"><bdi>@cs.FromLocation</bdi><span class="route-arrow">→</span><bdi>@cs.ToLocation</bdi></span></td><td class="ok">@cs.PricePerSeat.ToString("N2")</td><td><span class="tag tag-trip">@L["SB_TagCompanyBooked"]</span></td></tr>
                                }
                            </tbody></table></div>
                        }

                        <div class="grid-3" style="margin-bottom:14px;">
                            <div class="field"><label>@L["SB_ExtCompany"]</label><select class="fc" name="CompanyId" required><option value="">@L["SB_SelectCompany"]</option>@foreach (var c in Model.Companies ?? new List<SelectListItem>()){<option value="@c.Value">@c.Text</option>}</select></div>
                            <div class="field"><label>@L["SB_PricePerSeat"]</label><input class="fc" type="number" min="0" step="0.01" name="PricePerSeat" value="0" /></div>
                            <div class="field"><label>@L["SB_Notes"]</label><input class="fc" name="Notes" placeholder='@L["SB_NotesOptional"].Value' /></div>
                        </div>
                        <button class="btn btn-primary" type="submit">@L["SB_BtnTransfer"]</button>
                    </form>
                }
            </div>
        }
    </section>

    @* ═══════════════ SEARCH TAB ═══════════════ *@
    <section id="searchTab" class="csb-tab" style="display:@(activeTab == "searchTab" ? "" : "none")">
        <div class="dashboard-filter-card">
            <h2 class="panel-title">@L["SB_SearchTitle"]</h2>
            <form asp-controller="Transportation" asp-action="SeatBookingBoundSearch" method="get">
                <input type="hidden" name="ActiveTab" value="searchTab" />
                <div class="grid" style="margin-bottom:14px;">
                    <div class="field"><label>@L["SB_Company"]</label><select class="fc" name="Search.CompanyId"><option value="">@L["SB_AllCompanies"]</option>@foreach (var c in Model.Companies ?? new List<SelectListItem>()){<option value="@c.Value" selected="@(search.CompanyId?.ToString() == c.Value)">@c.Text</option>}</select></div>
                    <div class="field"><label>@L["SB_DateFrom"]</label><input class="fc" type="date" name="Search.DateFrom" value="@search.DateFrom?.ToString("yyyy-MM-dd")" /></div>
                    <div class="field"><label>@L["SB_DateTo"]</label><input class="fc" type="date" name="Search.DateTo" value="@search.DateTo?.ToString("yyyy-MM-dd")" /></div>
                    <div class="field"><label>@L["SB_Location"]</label><input class="fc" list="locList" name="Search.Location" value="@search.Location" /></div>
                    <div class="field"><label>@L["SB_PayStatus"]</label><select class="fc" name="Search.PaymentStatus"><option value="All" selected="@(search.PaymentStatus == CompanySeatPaymentStatus.All)">@L["SB_PayAll"]</option><option value="Paid" selected="@(search.PaymentStatus == CompanySeatPaymentStatus.Paid)">@L["SB_PayPaid"]</option><option value="Unpaid" selected="@(search.PaymentStatus == CompanySeatPaymentStatus.Unpaid)">@L["SB_PayUnpaid"]</option><option value="Partial" selected="@(search.PaymentStatus == CompanySeatPaymentStatus.Partial)">@L["SB_PayPartial"]</option></select></div>
                    <div class="field" style="display:flex;align-items:flex-end;"><button class="btn btn-primary" type="submit">@L["SB_BtnSearch"]</button></div>
                </div>
            </form>
        </div>

        @if (activeTab == "searchTab")
        {
            var groups = Model.SearchResults ?? new List<CompanyTripSeatSummaryDTO>();
            var rows = groups.SelectMany(g => (g.Seats ?? new List<CompanySeatBookingItemDTO>()).Select(s => new { Group = g, Seat = s })).OrderByDescending(x => x.Group.TripDate).ThenBy(x => x.Group.CompanyName).ThenBy(x => x.Seat.SeatNumber).ToList();

            <div class="sum-strip" style="margin-bottom:14px;">
                @{
                    var totalSearchSeats = rows.Sum(x => Math.Max(1, x.Seat.SeatsCount));
                    var totalSearchPrice = rows.Sum(x => x.Seat.TotalPrice);
                }

                <div class="sum-card"><small>@L["SB_SrRows"]</small><strong>@rows.Count</strong></div>
                <div class="sum-card"><small>@L["SB_SrSeats"]</small><strong>@totalSearchSeats</strong></div>
                <div class="sum-card"><small>@L["SB_SrPrice"]</small><strong>@totalSearchPrice.ToString("N2")</strong></div>
                <div class="sum-card"><small>@L["SB_SrPaid"]</small><strong class="ok">@groups.Sum(x => x.TotalPaid).ToString("N2")</strong></div>
                <div class="sum-card"><small>@L["SB_SrRemaining"]</small><strong class="bad">@groups.Sum(x => x.TotalRemaining).ToString("N2")</strong></div>
            </div>

            <div class="panel">
                @if (!rows.Any())
                {
                    <p class="empty-msg">@L["SB_NoResults"]</p>
                }
                else
                {
                    <form id="bulkDeleteForm" asp-controller="Transportation" asp-action="SeatBookingBoundDelete" method="post" onsubmit="return confirmBulkDelete();">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="companyId" value="@search.CompanyId" />
                        <input type="hidden" name="dateFrom" value="@search.DateFrom?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="dateTo" value="@search.DateTo?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="location" value="@search.Location" />
                        <input type="hidden" name="paymentStatus" value="@search.PaymentStatus" />
                        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;align-items:center;">
                            <button class="btn btn-danger" type="submit">@L["SB_BtnDeleteSel"]</button>
                            <button class="btn btn-light" type="button" onclick="openForceDeleteModal()">@L["SB_BtnForceDelete"]</button>
                            <button class="btn btn-light" type="button" onclick="toggleAllSearchRows(this)">@L["SB_BtnSelectAll"]</button>
                            <span style="font-weight:900;color:var(--mu);">@L["SB_HintDelete"]</span>
                        </div>
                        <div class="tw"><table><thead><tr>
                            <th>@L["SB_ColCheck"]</th><th>@L["SB_ColDate"]</th><th>@L["SB_Company"]</th>
                            <th>@L["SB_ColBus"]</th><th>@L["SB_ColBusRoute"]</th><th>@L["SB_ColSeatLoc"]</th>
                            <th>@L["SB_ColSeat"]</th><th>@L["SB_ColType"]</th><th>@L["SB_ColClient"]</th>
                            <th>@L["SB_ColPriceSeat"]</th><th>@L["SB_ColPaidTrip"]</th><th>@L["SB_ColRemTrip"]</th>
                        </tr></thead><tbody>
                            @foreach (var row in rows)
                            {
                                var g = row.Group;
                                var s = row.Seat;
                                <tr><td><input class="search-row-check" type="checkbox" name="bookingIds" value="@s.BookingId" /></td><td>@g.TripDate.ToString("yyyy-MM-dd")</td><td>@g.CompanyName</td><td>@g.BusName</td><td class="route-cell"><span class="route-text"><bdi>@g.TripFromLocation</bdi><span class="route-arrow">→</span><bdi>@g.TripToLocation</bdi></span></td><td class="route-cell"><span class="route-text"><bdi>@g.FromLocation</bdi><span class="route-arrow">→</span><bdi>@g.ToLocation</bdi></span></td>
                                <td>
                                    @if (s.BookingDirection == CompanySeatBookingDirection.Outbound)
                                    {
                                        <b>@s.SeatsCount مقعد</b>
                                    }
                                    else
                                    {
                                        <b>@(string.IsNullOrWhiteSpace(s.SeatLabel) ? s.SeatsCount.ToString() : s.SeatLabel)</b>
                                    }
                                </td>                                    
                                <td>@if (s.IsTransferredToCompany){<span class="tag tag-trip">🔄 @s.TransferStatusText</span>}else{<span class="tag tag-in">📥 @g.BookingDirection</span>}</td><td>@if (!string.IsNullOrWhiteSpace(s.ClientName)){<div>@s.ClientName @if (!string.IsNullOrWhiteSpace(s.ClientPhone)){<span>(@s.ClientPhone)</span>}<br /><span>[@TripTypeText(s.ClientTripType)]</span></div>}else{<span style="color:var(--mu);">—</span>}</td><td>
                                    <div>@s.PricePerSeat.ToString("N2") / مقعد</div>
                                    @if (s.SeatsCount > 1)
                                    {
                                        <small style="color:var(--mu);font-weight:900;">
                                            الإجمالي: @s.TotalPrice.ToString("N2")
                                        </small>
                                    }
                                </td>
                                <td class="ok">@g.TotalPaid.ToString("N2")</td><td class="@(g.TotalRemaining > 0 ? "bad" : "ok")">@g.TotalRemaining.ToString("N2")</td></tr>
                                                }
                        </tbody></table></div>
                    </form>
                }
            </div>
        }
    </section>
</div>

@* ═══════════════ FORCE DELETE MODAL ═══════════════ *@
<div id="forceDeleteModal" class="force-modal" style="display:none;">
    <div class="force-modal-box">
        <div class="force-modal-head">
            <h3>@L["SB_ForceTitle"]</h3>
            <button type="button" onclick="closeForceDeleteModal()">×</button>
        </div>
        <div id="forceDeleteBody" class="force-modal-body">
            <div class="force-delete-loader">@L["SB_ForceLoading"]</div>
        </div>
        <form id="forceDeleteForm" asp-controller="Transportation" asp-action="SeatBookingBoundForceDelete" method="post">
            @Html.AntiForgeryToken()
            <div id="forceDeleteIds"></div>
            <input type="hidden" name="companyId" value="@search.CompanyId" />
            <input type="hidden" name="dateFrom" value="@search.DateFrom?.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="dateTo" value="@search.DateTo?.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="location" value="@search.Location" />
            <input type="hidden" name="paymentStatus" value="@search.PaymentStatus" />
            <div class="force-modal-actions">
                <button type="button" class="btn btn-light" onclick="closeForceDeleteModal()">@L["SB_ForceBtnCancel"]</button>
                <button type="submit" class="btn btn-danger">@L["SB_ForceBtnConfirm"]</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function showTab(id, btn){
    document.querySelectorAll('.csb-tab').forEach(x => x.style.display = 'none');
    document.querySelectorAll('.tab-btn').forEach(x => x.classList.remove('active'));

    const tab = document.getElementById(id);
    if(tab) tab.style.display = '';

    if(btn) btn.classList.add('active');
}

function toggleAllSearchRows(btn){
    const checks = document.querySelectorAll('.search-row-check');
    const shouldCheck = Array.from(checks).some(x => !x.checked);

    checks.forEach(x => x.checked = shouldCheck);

    if(btn){
        btn.innerText = shouldCheck ? 'Deselect All' : 'Select All';
    }
}

function getSelectedBookingIds(){
    return Array.from(document.querySelectorAll('.search-row-check:checked'))
        .map(x => x.value)
        .filter(x => x && x !== '00000000-0000-0000-0000-000000000000');
}

function confirmBulkDelete(){
    const selected = getSelectedBookingIds();

    if(selected.length === 0){
        alert('Select at least one seat to delete.');
        return false;
    }

    return confirm(`Are you sure you want to delete ${selected.length} seat booking(s)?`);
}

function closeForceDeleteModal(){
    const modal = document.getElementById('forceDeleteModal');
    if(modal) modal.style.display = 'none';
}

function htmlEncode(value){
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

async function openForceDeleteModal(){
    const ids = getSelectedBookingIds();

    if(ids.length === 0){
        alert('Select at least one seat to force delete.');
        return;
    }

    const tokenInput = document.querySelector('#bulkDeleteForm input[name="__RequestVerificationToken"]')
        || document.querySelector('input[name="__RequestVerificationToken"]');

    const token = tokenInput ? tokenInput.value : '';

    const modal = document.getElementById('forceDeleteModal');
    const body = document.getElementById('forceDeleteBody');
    const idsBox = document.getElementById('forceDeleteIds');

    modal.style.display = 'grid';
    body.innerHTML = '<div class="force-delete-loader">Loading...</div>';
    idsBox.innerHTML = '';

    ids.forEach(id => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'bookingIds';
        input.value = id;
        idsBox.appendChild(input);
    });

    try{
        const response = await fetch('@Url.Action("SeatBookingBoundForceDeleteDetails", "Transportation")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(ids)
        });

        let result;
        try{
            result = await response.json();
        }
        catch{
            body.innerHTML = '<div class="force-warning">Failed to load force delete details.</div>';
            return;
        }

        if(!response.ok || !result.success){
            body.innerHTML = `<div class="force-warning">${htmlEncode(result.message || 'Failed to load force delete details.')}</div>`;
            return;
        }

        const data = result.data || {};
        const seats = data.seats || [];

        const rows = seats.map(s => `
            <tr>
                <td>${htmlEncode(s.tripDate ? String(s.tripDate).substring(0,10) : '-')}</td>
                <td>${htmlEncode(s.companyName || '-')}</td>
                <td>${htmlEncode(s.busName || '-')}</td>
                <td class="route-cell">${htmlEncode(s.route || '-')}</td>
                <td>${htmlEncode(s.seatLabel || '-')}</td>
                <td>${htmlEncode(s.clientName || '-')}</td>
                <td>${htmlEncode(s.clientPhone || '-')}</td>
                <td>${htmlEncode(s.type || '-')}</td>
            </tr>
        `).join('');

        body.innerHTML = `
            <div class="force-warning">
                <div class="force-danger-text">Warning: This is a permanent delete.</div>
                This action will permanently delete the selected booking and all related transfer/conflict records.
                Use it only if you want to remove everything from the database and enter the booking again from scratch.
            </div>

            <div class="force-muted">
                Selected booking(s): ${ids.length}. Related/conflict row(s): ${seats.length}.
            </div>

            <div class="tw">
                <table class="force-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Company</th>
                            <th>Bus</th>
                            <th>Route</th>
                            <th>Seat</th>
                            <th>Client</th>
                            <th>Phone</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${rows || '<tr><td colspan="8">No details found.</td></tr>'}
                    </tbody>
                </table>
            </div>
        `;
    }
    catch(e){
        body.innerHTML = '<div class="force-warning">Failed to load force delete details.</div>';
    }
}


function setupBottomTableScrollbars(){
    document.querySelectorAll('.tw').forEach(function(tableWrap){
        if(tableWrap.dataset.scrollbarReady === '1') return;
        tableWrap.dataset.scrollbarReady = '1';

        const table = tableWrap.querySelector('table');
        if(!table) return;

        const bar = document.createElement('div');
        bar.className = 'tw-scrollbar';

        const inner = document.createElement('div');
        inner.className = 'tw-scrollbar-inner';
        bar.appendChild(inner);

        tableWrap.insertAdjacentElement('afterend', bar);

        let locked = false;

        function refreshWidth(){
            const realWidth = Math.max(
                table.scrollWidth,
                table.offsetWidth,
                tableWrap.scrollWidth
            );

            inner.style.width = realWidth + 'px';

            if(realWidth <= tableWrap.clientWidth + 2){
                bar.style.display = 'none';
            }else{
                bar.style.display = 'block';
            }
        }

        tableWrap.addEventListener('scroll', function(){
            if(locked) return;
            locked = true;
            bar.scrollLeft = tableWrap.scrollLeft;
            locked = false;
        });

        bar.addEventListener('scroll', function(){
            if(locked) return;
            locked = true;
            tableWrap.scrollLeft = bar.scrollLeft;
            locked = false;
        });

        refreshWidth();
        setTimeout(refreshWidth, 150);
        setTimeout(refreshWidth, 500);
        window.addEventListener('resize', refreshWidth);
    });
}

if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', setupBottomTableScrollbars);
}else{
    setupBottomTableScrollbars();
}

</script>
}