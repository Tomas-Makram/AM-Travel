/* =========================
   TABLE SCROLLBAR - ADDED / FIXED
   One native horizontal scrollbar under each table.
   No logic or form fields changed.
========================= */
.tw{
    width:100%;
    max-width:100%;
    min-width:0;
    display:block;
    overflow-x:auto !important;
    overflow-y:hidden !important;
    direction:ltr;
    padding-bottom:14px;
    margin-bottom:6px;
    -webkit-overflow-scrolling:touch;
    scroll-behavior:smooth;
    scrollbar-gutter:stable;
}
.tw::-webkit-scrollbar{height:14px}
.tw::-webkit-scrollbar-track{background:var(--input);border-radius:999px;border:1px solid var(--ln)}
.tw::-webkit-scrollbar-thumb{background:linear-gradient(135deg,var(--or),var(--or2));border-radius:999px;border:2px solid var(--input)}
.tw::-webkit-scrollbar-thumb:hover{background:linear-gradient(135deg,#ff8f33,#ffbb5c)}
.tw{scrollbar-width:thin;scrollbar-color:var(--or) var(--input)}
.tw table{
    direction:ltr;
    width:max-content !important;
    min-width:1500px !important;
    max-width:none !important;
    table-layout:auto;
    border-collapse:separate;
    border-spacing:0 5px;
}
.tw th{text-align:left;color:var(--mu);font-size:11px;font-weight:1000;padding:0 12px 6px;white-space:nowrap;text-transform:uppercase;letter-spacing:.04em;transition:color .3s}
