.tag-in{background:rgba(7,148,85,.12);color:var(--gr)}
.tag-trip{background:rgba(255,122,24,.12);color:var(--or)}
.ok{color:var(--gr);font-weight:1000}
.bad{color:var(--re);font-weight:1000}
.empty-msg{text-align:center;color:var(--mu);font-weight:1000;padding:26px;border:1px dashed var(--ln);border-radius:20px;background:var(--sf2);margin:0;font-size:13px;transition:background .3s,border-color .3s,color .3s}
.tr-seat-row.transferred{opacity:.55}
.client-section{border:1px solid var(--ln);border-radius:18px;padding:14px;margin-bottom:16px;transition:border-color .3s}
.client-section legend{font-weight:1000;color:var(--dk);padding:0 8px;transition:color .3s}
.force-modal{position:fixed;inset:0;z-index:9999;background:rgba(15,23,42,.72);display:grid;place-items:center;padding:20px}
.force-modal-box{width:min(980px,100%);max-height:90vh;overflow:auto;background:var(--card);border:1px solid var(--ln);border-radius:24px;box-shadow:0 30px 90px rgba(0,0,0,.35);transition:background .3s,border-color .3s}
.force-modal-head{display:flex;justify-content:space-between;align-items:center;padding:18px 22px;border-bottom:1px solid var(--ln)}
.force-modal-head h3{margin:0;color:var(--dk);font-weight:1000;transition:color .3s}
.force-modal-head button{width:38px;height:38px;border:0;border-radius:12px;background:rgba(220,38,38,.12);color:var(--re);font-size:24px;font-weight:1000;cursor:pointer}
.force-modal-body{padding:20px 22px;color:var(--text);transition:color .3s}
.force-warning{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.3);color:#d97706;padding:14px 16px;border-radius:16px;font-weight:900;margin-bottom:16px}
.force-table{width:max-content!important;min-width:1400px!important;max-width:none!important;border-collapse:separate;border-spacing:0}
.force-table th,.force-table td{padding:10px 12px;border-bottom:1px solid var(--ln);color:var(--text);text-align:left;font-size:13px}
.force-modal-actions{padding:18px 22px;border-top:1px solid var(--ln);display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap}
.force-delete-loader{font-weight:1000;color:var(--dk);padding:10px 0;transition:color .3s}
.force-danger-text{color:var(--re);font-weight:1000}
.force-muted{color:var(--mu);font-weight:900;font-size:13px;margin-bottom:12px;transition:color .3s}
@@media(max-width:900px){.grid,.grid-3,.sum-strip,.summary-grid{grid-template-columns:1fr 1fr}.grid-2{grid-template-columns:1fr}.bus-cards{grid-template-columns:1fr}}
@@media(max-width:650px){.dashboard-hero{padding:24px;border-radius:24px}.dashboard-actions{flex-direction:column}.dashboard-btn{width:100%}.dashboard-avatar-wrap{width:112px;height:112px;border-radius:32px}.dashboard-avatar{width:88px;height:88px;font-size:34px;border-radius:27px}.grid,.grid-3,.grid-2,.sum-strip,.summary-grid{grid-template-columns:1fr}}


