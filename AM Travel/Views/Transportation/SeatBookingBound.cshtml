@using BusinessLayer.DTOs.CompanyBookSeat
@using DataLayer.Models
@using BusinessLayer.DTOs.Company
@using Microsoft.AspNetCore.Mvc.Rendering
@model BusinessLayer.DTOs.CompanyBookSeat.SeatBookingBoundPageDTO

@{
    ViewData["Title"] = L["SB_PageTitle"];

    var activeTab = string.IsNullOrWhiteSpace(Model.ActiveTab) ? "bookTab" : Model.ActiveTab;
    var hiddenDirection = Model.Direction;
    var search = Model.Search ?? new CompanySeatBookingSearchDTO();
    var transferSearch = Model.TransferTripSearch ?? new TransferTripSearchDTO();

    var successMessage = TempData["Success"]?.ToString() ?? ViewBag.SuccessMessage as string;
    var errorMessage = TempData["Error"]?.ToString() ?? ViewBag.ErrorMessage as string;

    var currentName = ViewBag.Name as string ?? User.Identity?.Name ?? "Account";
    var role = User.IsInRole("Admin") ? "Administrator Account" :
               User.IsInRole("Helper") ? "Helper Account" :
               User.IsInRole("Viewer") ? "Viewer Account" :
               "User Account";

    var initials = currentName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(x => x[0])
        .Aggregate("", (a, b) => a + b)
        .ToUpper();

    if (string.IsNullOrWhiteSpace(initials)) initials = "AM";

    var tripDateValue = Model.TripDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd");

    string DirTextEn(TripDirection d) => d == TripDirection.Return ? "Return" : "Go";

    string SeatCss(SeatType t) => t switch
    {
        SeatType.Normal => "seat",
        SeatType.VIP => "vip",
        SeatType.Driver => "driver",
        SeatType.Assistant => "assistant",
        SeatType.Aisle => "road",
        SeatType.Door => "road",
        SeatType.Bathroom => "wc",
        _ => "empty"
    };

    string TripTypeText(TransportationTripType t) => t switch
    {
        TransportationTripType.Return => "Return",
        TransportationTripType.RoundTrip => "Round Trip",
        _ => "Go"
    };

    var autoClientTripType = Model.Direction == TripDirection.Return
        ? TransportationTripType.Return
        : TransportationTripType.Departure;
}

<style>
:root{
    --or:#ff7a18;--or2:#ffad42;--dk:#172033;--mu:#667085;--ln:#f0d8c2;
