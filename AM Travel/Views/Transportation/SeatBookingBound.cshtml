.tw td:first-child{border-left:1px solid var(--ln);border-radius:12px 0 0 12px}
.tw td:last-child{border-right:1px solid var(--ln);border-radius:0 12px 12px 0}
.tw tbody tr:hover td{background:var(--card)}
.route-cell{direction:ltr!important;unicode-bidi:isolate;white-space:nowrap}
.route-cell .route-text{display:inline-flex;align-items:center;gap:7px;direction:ltr;unicode-bidi:isolate}
.route-cell bdi{direction:auto;unicode-bidi:isolate}
.route-cell .route-arrow{direction:ltr;color:var(--mu);font-weight:1000}
.force-table{min-width:1400px!important}
