.bc-stat.total{background:var(--input);color:var(--text)}
.bc-stat.client{background:rgba(220,38,38,.12);color:var(--re)}
.bc-stat.company{background:rgba(245,158,11,.12);color:#d97706}
.bc-stat.avail{background:rgba(7,148,85,.12);color:var(--gr)}
.bc-stat.zero{background:var(--input);color:var(--mu)}
.bc-new{padding:3px 8px;border-radius:999px;font-size:10px;font-weight:1000;background:rgba(124,58,237,.12);color:var(--vi)}
.bc-enough{background:rgba(7,148,85,.12);color:var(--gr)}
.bc-create{background:rgba(255,122,24,.12);color:var(--or)}
