@model List<BusinessLayer.DTOs.Company.CompanyDTO>

@{
    ViewData["Title"] = L["Co_Title"];

    string fullName = Convert.ToString(ViewBag.Name) ?? "User";
    var cleanName = fullName.Trim().Replace("  ", " ");

    var userName = string.Join("", cleanName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(userName)) userName = "U";

    string currentSearch = Convert.ToString(ViewBag.Search) ?? "";
    string currentStatus = Convert.ToString(ViewBag.Status) ?? "all";
}

<style>
    :root {
        --co-hero-bg: linear-gradient(135deg, #ff7a18, #ffad42);
        --co-hero-glow: rgba(255,122,24,.18);
        --co-hero-text: #fff;
        --co-hero-sub: rgba(255,255,255,.92);
        --co-card-bg: #fff;
        --co-card-border: #f0d8c2;
        --co-card-shadow: rgba(255,122,24,.09);
        --co-label: #667085;
        --co-input-bg: #fffaf5;
        --co-input-border: #f3dfcc;
        --co-input-text: #172033;
        --co-row-bg: #fffaf5;
        --co-row-border: #f3dfcc;
        --co-row-text: #172033;
        --co-row-hover: #fff5eb;
        --co-th-txt: #667085;
        --co-active-bg: rgba(18,183,106,.12);
        --co-active-txt: #12b76a;
        --co-inactive-bg: #f2f4f7;
        --co-inactive-txt: #667085;
        --co-edit-bg: #fff;
        --co-edit-border: #f3dfcc;
        --co-edit-txt: #ff7a18;
        --co-delete-bg: rgba(240,68,56,.10);
        --co-delete-txt: #f04438;
        --co-reset-bg: #fff;
        --co-reset-border: #f3dfcc;
        --co-reset-txt: #ff7a18;
        --co-empty-txt: #98a2b3;
    }

    html[data-theme="dark"] {
        --co-hero-bg: linear-gradient(135deg, #c45c0a, #d97c2a);
        --co-hero-glow: rgba(196,92,10,.22);
        --co-hero-text: #f5f0eb;
        --co-hero-sub: rgba(245,240,235,.85);
        --co-card-bg: #1a2236;
        --co-card-border: #283148;
        --co-card-shadow: rgba(0,0,0,.35);
        --co-label: #7a8ba0;
        --co-input-bg: #212c3f;
        --co-input-border: #3a4d66;
        --co-input-text: #c4cedb;
        --co-row-bg: #212c3f;
        --co-row-border: #283148;
        --co-row-text: #dce3ed;
        --co-row-hover: #263042;
        --co-th-txt: #7a8ba0;
        --co-active-bg: rgba(18,183,106,.16);
        --co-active-txt: #34d399;
        --co-inactive-bg: rgba(122,139,160,.15);
        --co-inactive-txt: #7a8ba0;
        --co-edit-bg: #252d3f;
        --co-edit-border: #3a4d66;
        --co-edit-txt: #f6ba72;
        --co-delete-bg: rgba(248,113,113,.12);
        --co-delete-txt: #f87171;
        --co-reset-bg: #212c3f;
        --co-reset-border: #3a4d66;
        --co-reset-txt: #f6ba72;
        --co-empty-txt: #5a6a7e;
    }

    .transport-page {
        display: grid;
        gap: 20px;
    }

    .transport-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--co-hero-text);
        background: var(--co-hero-bg);
        box-shadow: 0 24px 70px var(--co-hero-glow);
    }

    .transport-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 26%);
        pointer-events: none;
    }

    .transport-hero::after {
        content: "";
        position: absolute;
        width: 260px;
        height: 260px;
        right: -90px;
        bottom: -110px;
        border-radius: 50%;
        background: rgba(255,255,255,.12);
    }

    .transport-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .transport-title {
        display: grid;
        gap: 10px;
    }

    .transport-badge {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--co-hero-text);
    }

    .transport-title h1 {
        margin: 0;
        font-size: clamp(34px,5vw,54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--co-hero-text);
    }

    .transport-title p {
        margin: 0;
        color: var(--co-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    .transport-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        flex-shrink: 0;
    }

    .transport-avatar-wrap::before {
        content: "";
        position: absolute;
        inset: -7px;
        border-radius: 44px;
        border: 3px solid rgba(255,255,255,.22);
    }

    .transport-avatar-wrap::after {
        content: "";
        position: absolute;
        inset: -7px;
        border-radius: 44px;
        border: 3px solid transparent;
        border-top-color: #fff;
        border-right-color: rgba(255,255,255,.72);
        animation: transport-avatar-spin 4s linear infinite;
    }

    .transport-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)), linear-gradient(135deg,#fff,#fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .transport-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
    }

    @@keyframes transport-avatar-spin {
        to { transform: rotate(360deg); }
    }

    .transport-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .transport-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
    }

    .transport-btn:hover {
        transform: translateY(-2px);
    }

    .btn-white {
        background: #fff;
        color: #ff7a18;
        box-shadow: 0 14px 30px rgba(0,0,0,.12);
    }

    .btn-glass {
        background: rgba(255,255,255,.16);
        color: var(--co-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

    .filter-card {
        background: var(--co-card-bg);
        border: 1px solid var(--co-card-border);
        border-radius: 26px;
        padding: 18px;
        box-shadow: 0 18px 42px var(--co-card-shadow);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 1fr 220px auto auto;
        gap: 12px;
        align-items: end;
    }

    .filter-group {
        display: grid;
        gap: 7px;
    }

    .filter-group label {
        color: var(--co-label);
        font-size: 13px;
        font-weight: 900;
    }

    .filter-input,
    .filter-select {
        min-height: 46px;
        border-radius: 16px;
        border: 1px solid var(--co-input-border);
        padding: 0 14px;
        outline: none;
        font-weight: 900;
        color: var(--co-input-text);
        background: var(--co-input-bg);
        font-size: 14px;
        width: 100%;
        box-sizing: border-box;
    }

    .filter-input:focus,
    .filter-select:focus {
        border-color: rgba(255,122,24,.55);
        background: var(--co-card-bg);
        box-shadow: 0 0 0 4px rgba(255,122,24,.09);
    }

    .filter-input::placeholder {
        color: var(--co-label);
        opacity: .7;
    }

    .filter-select option {
        background: #fff;
        color: #172033;
    }

    .filter-btn {
        min-height: 46px;
        padding: 0 18px;
        border-radius: 16px;
        border: none;
        background: linear-gradient(135deg,#ff7a18,#ffad42);
        color: #fff;
        font-weight: 900;
        font-size: 14px;
        cursor: pointer;
        white-space: nowrap;
        box-shadow: 0 8px 22px rgba(255,122,24,.20);
    }

    .reset-btn {
        min-height: 46px;
        padding: 0 18px;
        border-radius: 16px;
        border: 1px solid var(--co-reset-border);
        background: var(--co-reset-bg);
        color: var(--co-reset-txt);
        font-weight: 900;
        font-size: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .table-card {
        background: var(--co-card-bg);
        border: 1px solid var(--co-card-border);
        border-radius: 30px;
        padding: 24px;
        box-shadow: 0 18px 42px var(--co-card-shadow);
        overflow: hidden;
    }

    .table-wrap {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 12px;
    }

    .table-wrap::-webkit-scrollbar {
        height: 12px;
    }

    .table-wrap::-webkit-scrollbar-track {
        background: rgba(255,255,255,.08);
        border-radius: 999px;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background: #9ca3af;
        border-radius: 999px;
    }

    .transport-table {
        width: 100%;
        min-width: 1050px;
        table-layout: fixed;
        border-collapse: separate;
        border-spacing: 0 12px;
    }

    .transport-table th {
        text-align: center;
        color: var(--co-th-txt);
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .05em;
        padding: 0 12px 6px;
        white-space: nowrap;
    }

    .transport-table td {
        background: var(--co-row-bg);
        border-top: 1px solid var(--co-row-border);
        border-bottom: 1px solid var(--co-row-border);
        padding: 16px 12px;
        color: var(--co-row-text);
        font-weight: 800;
        font-size: 14px;
        vertical-align: middle;
        text-align: center;
        white-space: nowrap;
        height: 82px;
    }

    .transport-table tbody tr:hover td {
        background: var(--co-row-hover);
    }

    .transport-table td:first-child {
        border-left: 1px solid var(--co-row-border);
        border-radius: 18px 0 0 18px;
    }

    .transport-table td:last-child {
        border-right: 1px solid var(--co-row-border);
        border-radius: 0 18px 18px 0;
    }

    html[dir="rtl"] .transport-table td:first-child,
    body[dir="rtl"] .transport-table td:first-child {
        border-left: 0;
        border-right: 1px solid var(--co-row-border);
        border-radius: 0 18px 18px 0;
    }

    html[dir="rtl"] .transport-table td:last-child,
    body[dir="rtl"] .transport-table td:last-child {
        border-right: 0;
        border-left: 1px solid var(--co-row-border);
        border-radius: 18px 0 0 18px;
    }

    .col-company { width: 190px; }
    .col-phone { width: 190px; }
    .col-notes { width: 340px; }
    .col-status { width: 150px; }
    .col-actions { width: 300px; }

    .cell-text {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .notes-box {
        max-height: 70px;
        overflow-y: auto;
        overflow-x: hidden;
        text-align: start;
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        line-height: 1.7;
        padding-inline-end: 8px;
    }

    .notes-box::-webkit-scrollbar {
        width: 6px;
    }

    .notes-box::-webkit-scrollbar-thumb {
        background: var(--co-input-border);
        border-radius: 999px;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
        white-space: nowrap;
    }

    .pill-active {
        color: var(--co-active-txt);
        background: var(--co-active-bg);
    }

    .pill-inactive {
        color: var(--co-inactive-txt);
        background: var(--co-inactive-bg);
    }

    .table-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }

    .table-actions form {
        margin: 0;
    }

    .edit-btn {
        min-height: 38px;
        padding: 0 13px;
        border-radius: 13px;
        background: var(--co-edit-bg);
        color: var(--co-edit-txt);
        border: 1px solid var(--co-edit-border);
        font-weight: 900;
        font-size: 13px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        white-space: nowrap;
    }

    .delete-btn {
        min-height: 38px;
        padding: 0 13px;
        border-radius: 13px;
        border: none;
        background: var(--co-delete-bg);
        color: var(--co-delete-txt);
        font-weight: 900;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
    }

    .empty-box {
        padding: 30px;
        text-align: center;
        color: var(--co-empty-txt);
        font-weight: 900;
    }

    @@media (max-width: 900px) {
        .filter-form {
            grid-template-columns: 1fr;
        }

        .transport-actions {
            flex-direction: column;
        }

        .transport-btn {
            width: 100%;
        }
    }

    @@media (max-width: 650px) {
        .transport-avatar-wrap {
            width: 112px;
            height: 112px;
            border-radius: 32px;
        }

        .transport-avatar-wrap::before,
        .transport-avatar-wrap::after {
            border-radius: 38px;
        }

        .transport-avatar {
            width: 88px;
            height: 88px;
            font-size: 34px;
            border-radius: 27px;
        }
    }
</style>

<div class="transport-page">

    <section class="transport-hero">
        <div class="transport-hero-inner">
            <div class="transport-title">
                <span class="transport-badge">@L["Co_Badge"]</span>
                <h1>@L["Co_Heading"]</h1>
                <p>@L["Co_Subtitle"]</p>
            </div>

            <div class="transport-avatar-wrap">
                <div class="transport-avatar">@userName</div>
                <span class="transport-avatar-status"></span>
            </div>
        </div>

        <div class="transport-actions">
            <a class="transport-btn btn-white" asp-action="CreateCompany">@L["Co_NewCompany"]</a>
            <a class="transport-btn btn-glass" asp-action="Buses">@L["Co_Buses"]</a>
            <a class="transport-btn btn-glass" asp-action="Trips">@L["Co_Trips"]</a>
        </div>
    </section>

    <section class="filter-card">
        <form class="filter-form" asp-action="Companies" method="get">

            <div class="filter-group">
                <label>@L["Co_FilterLabel"]</label>
                <input class="filter-input"
                       type="text"
                       name="search"
                       value="@currentSearch"
                       placeholder="@L["Co_FilterPH"]" />
            </div>

            <div class="filter-group">
                <label>@L["Co_FilterStatus"]</label>
                <select class="filter-select" name="status">
                    <option value="all" selected="@(currentStatus == "all")">@L["Co_StatusAll"]</option>
                    <option value="active" selected="@(currentStatus == "active")">@L["Co_StatusActive"]</option>
                    <option value="inactive" selected="@(currentStatus == "inactive")">@L["Co_StatusInactive"]</option>
                </select>
            </div>

            <button class="filter-btn" type="submit">@L["Co_FilterApply"]</button>
            <a class="reset-btn" asp-action="Companies">@L["Co_FilterReset"]</a>

        </form>
    </section>

    <section class="table-card">
        <div class="table-wrap">
            <table class="transport-table">
                <thead>
                    <tr>
                        <th class="col-company">@L["Co_ColCompany"]</th>
                        <th class="col-phone">@L["Co_ColPhone"]</th>
                        <th class="col-notes">@L["Co_ColNotes"]</th>
                        <th class="col-status">@L["Co_ColStatus"]</th>
                        <th class="col-actions">@L["Co_ColActions"]</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-box">@L["Co_NoResults"]</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="col-company" title="@item.Name">
                                    <span class="cell-text">@item.Name</span>
                                </td>

                                <td class="col-phone" title="@item.PhoneNumber">
                                    <span class="cell-text">
                                        @(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "-" : item.PhoneNumber)
                                    </span>
                                </td>

                                <td class="col-notes" title="@item.Notes">
                                    <div class="notes-box">
                                        @(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)
                                    </div>
                                </td>

                                <td class="col-status">
                                    <span class="pill @(item.IsActive ? "pill-active" : "pill-inactive")">
                                        @(item.IsActive ? L["Co_PillActive"].Value : L["Co_PillInactive"].Value)
                                    </span>
                                </td>

                                <td class="col-actions">
                                    <div class="table-actions">
                                        <form asp-action="ChangeCompanyStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="companyId" value="@item.CompanyId" />
                                            <button class="edit-btn" type="submit">
                                                @(item.IsActive ? L["Co_BtnSetInactive"].Value : L["Co_BtnSetActive"].Value)
                                            </button>
                                        </form>

                                        <a class="edit-btn"
                                           asp-action="EditCompany"
                                           asp-route-id="@item.CompanyId">
                                            @L["Co_BtnEdit"]
                                        </a>

                                        <form asp-action="DeleteCompany" asp-route-id="@item.CompanyId" method="post">
                                            @Html.AntiForgeryToken()
                                            <button class="delete-btn"
                                                    type="submit">
                                                @L["Co_BtnDelete"]
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>