@using AM_Travel.Resources
@using Microsoft.Extensions.Localization

@inject IStringLocalizer<SharedResource> L

@model List<BusinessLayer.DTOs.Bus.BusDTO>

@{
    ViewData["Title"] = L["Bus_Title"];

    string currentSearch = Convert.ToString(ViewBag.Search) ?? "";
    string currentStatus = Convert.ToString(ViewBag.Status) ?? "all";
    string currentTripType = Convert.ToString(ViewBag.TripType) ?? "all";
    string currentLocation = Convert.ToString(ViewBag.Location) ?? "";
    var locations = ViewBag.Locations as List<string> ?? new List<string>();

    string fullName = Convert.ToString(ViewBag.Name) ?? "User";
    var cleanName = fullName.Trim().Replace("  ", " ");

    var userName = string.Join("", cleanName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(userName)) userName = "U";
}

<style>
    :root {
        --bb-hero-bg: linear-gradient(135deg, #ff7a18, #ffad42);
        --bb-hero-glow: rgba(255,122,24,.18);
        --bb-hero-text: #fff;
        --bb-hero-sub: rgba(255,255,255,.95);
        --bb-card-bg: #fff;
        --bb-card-border: #f0d8c2;
        --bb-card-shadow: rgba(255,122,24,.10);
        --bb-label: #667085;
        --bb-input-bg: #fffaf5;
        --bb-input-border: #f3dfcc;
        --bb-input-text: #172033;
        --bb-row-bg: #fffaf5;
        --bb-row-border: #f3dfcc;
        --bb-row-text: #172033;
        --bb-row-sub: #667085;
        --bb-row-hover: #fff5eb;
        --bb-stat-bg: #fff;
        --bb-stat-border: #f3dfcc;
        --bb-stat-label: #667085;
