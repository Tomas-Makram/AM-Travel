        --bb-inactive-txt: #667085;
        --bb-btn-show-bg: #ff7a18;
        --bb-btn-show-txt: #fff;
        --bb-btn-det-bg: #172033;
        --bb-btn-det-txt: #fff;
        --bb-btn-light-bg: #fffaf5;
        --bb-btn-light-bdr: #f3dfcc;
        --bb-btn-light-txt: #ff7a18;
        --bb-empty-txt: #98a2b3;
        --bb-modal-bg: #fff;
        --bb-modal-border: #f3dfcc;
        --bb-modal-head-txt: #172033;
        --bb-modal-close-bg: #fffaf5;
        --bb-modal-close-bdr: #f3dfcc;
        --bb-modal-close-txt: #ff7a18;
        --bb-modal-route-bg: #fffaf5;
        --bb-modal-route-bdr: #f3dfcc;
        --bb-modal-route-lbl: #667085;
        --bb-modal-route-val: #172033;
        --bb-design-bg: #fffaf5;
        --bb-grid-bg: #fffaf5;
        --bb-grid-border: #f3dfcc;
        --bb-cell-bg: #fff;
        --bb-cell-border: #f0c9a5;
        --bb-cell-empty-dot: #ffd5b4;
