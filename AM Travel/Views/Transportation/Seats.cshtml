@using DataLayer.Models

@model List<BusinessLayer.DTOs.Trip.TripSeatStatusDTO>

@{
    ViewData["Title"] = L["Seats_Title"];

    var tripId = Context.Request.Query["tripId"].ToString();

    var rows = Model.Any() ? Model.Max(x => x.RowNumber) : 0;
    var cols = Model.Any() ? Model.Max(x => x.ColumnNumber) : 0;

    var firstSeat = Model.FirstOrDefault();
    var generalRouteFrom = string.IsNullOrWhiteSpace(firstSeat?.GeneralRouteFrom) ? "-" : firstSeat.GeneralRouteFrom;
    var generalRouteTo   = string.IsNullOrWhiteSpace(firstSeat?.GeneralRouteTo)   ? "-" : firstSeat.GeneralRouteTo;
    var generalTripRoute = string.IsNullOrWhiteSpace(firstSeat?.TripRouteText)    ? "-" : firstSeat.TripRouteText;

    var seatsMap = Model.ToDictionary(x => $"{x.RowNumber}_{x.ColumnNumber}", x => x);

    var bookings = Model
        .Where(x => x.IsReserved)
        .GroupBy(x => x.IsCompanyBooking
            ? $"C_{(string.IsNullOrWhiteSpace(x.CompanyBookingGroupKey) ? x.CompanySeatBookingId.ToString() : x.CompanyBookingGroupKey)}"
            : $"B_{x.BookingId}")
        .Select(g => new
        {
            First = g.First(),
            Seats = g.OrderBy(x => x.RowNumber).ThenBy(x => x.ColumnNumber).ToList()
        })
        .OrderBy(x => x.First.IsCompanyBooking)
        .ThenBy(x => x.First.CompanyName)
        .ThenBy(x => x.First.ReservedByClient)
        .ToList();

    var totalSeats     = Model.Count(x => x.IsActive && (x.SeatType == SeatType.Normal || x.SeatType == SeatType.VIP));
    var reservedSeats  = Model.Count(x => x.IsReserved);
    var availableSeats = Math.Max(0, totalSeats - reservedSeats);

    string userName = Convert.ToString(ViewBag.Name) ?? "User";
    var cleanName   = userName.Trim().Replace("  ", " ");
    var initials    = string.Join("", cleanName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper();
    if (string.IsNullOrWhiteSpace(initials)) initials = "AM";

    var busWidth = (cols * 70) + ((cols > 1 ? cols - 1 : 0) * 8) + 98;

    // ═══════════════════════════════════════════════════════════════════════
    // Helper: translates hardcoded English strings from Manager into
    // the current UI language — NO Model/Function changes needed
    // ═══════════════════════════════════════════════════════════════════════
    string TranslateRoute(string? raw) => raw?.Trim() switch
    {
        "Go"         => L["Seats_RouteGo"].Value,
        "Return"     => L["Seats_RouteReturn"].Value,
        "Departure"  => L["Seats_RouteGo"].Value,
        _            => raw ?? "-"
    };

    string TranslateTripType(string? raw) => raw?.Trim() switch
    {
        "Go"                                  => L["Seats_TripTypeGo"].Value,
        "Return"                              => L["Seats_TripTypeReturn"].Value,
        "Departure"                           => L["Seats_TripTypeGo"].Value,
        "RoundTrip"                           => L["Seats_TripTypeRound"].Value,
        "Inbound"                             => L["Seats_RouteGo"].Value,
        "Outbound"                            => L["Seats_RouteReturn"].Value,
        var s when s != null
            && s.Contains("Round", StringComparison.OrdinalIgnoreCase)
                                              => L["Seats_TripTypeRound"].Value,
        _                                    => raw ?? "-"
    };
}

