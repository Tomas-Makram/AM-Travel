    /* ── Money ───────────────────────────────────────────────────────────── */
    .money-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
    .money-box  { background: var(--ts-money-bg); border: 1px solid var(--ts-money-border); border-radius: 14px; padding: 12px 14px; }
    .money-box small  { display: block; color: var(--ts-money-label); margin-bottom: 6px; font-weight: 800; font-size: 12px; }
    .money-box strong { color: var(--ts-book-text); font-weight: 1000; font-size: 16px; }
    .money-box .danger  { color: #f87171 !important; }
    .money-box .success { color: #34d399 !important; }
    .details-btn { min-height: 40px; border-radius: 14px; padding: 0 16px; border: 1px solid var(--ts-details-border); color: var(--ts-details-txt); text-decoration: none; display: inline-flex; align-items: center; justify-content: center; font-weight: 900; font-size: 14px; transition: .2s ease; }
    .details-btn:hover { transform: translateY(-1px); }

    @@media (max-width: 1100px) {
        .ts-layout  { grid-template-columns: 1fr; }
        .ts-summary { grid-template-columns: repeat(3,1fr); }
        .money-grid { grid-template-columns: repeat(2,1fr); }
    }
    @@media (max-width: 650px) {
        .ts-summary { grid-template-columns: 1fr; }
        .money-grid { grid-template-columns: 1fr; }
        .ts-actions { flex-direction: column; }
        .ts-btn     { width: 100%; }
        .ts-route-card { flex-direction: column; align-items: flex-start; }
        .ts-avatar-wrap { width: 112px; height: 112px; border-radius: 32px; }
        .ts-avatar-wrap::before, .ts-avatar-wrap::after { border-radius: 38px; }
        .ts-avatar { width: 88px; height: 88px; font-size: 34px; border-radius: 27px; }
    }
</style>

<div class="ts-page">

    @* ── Hero ── *@
    <section class="ts-hero">
        <div class="ts-hero-inner">
            <div>
                <span class="ts-badge">@L["Seats_Badge"]</span>
                <h1>@L["Seats_Heading"]</h1>
                <p>@L["Seats_Subtitle"]</p>
            </div>
            <div class="ts-avatar-wrap">
                <div class="ts-avatar">@initials</div>
                <span class="ts-avatar-status"></span>
            </div>
        </div>
        <div class="ts-actions">
            <a class="ts-btn ts-btn-white" asp-action="Trips">@L["Seats_BackToTrips"]</a>
            <a class="ts-btn ts-btn-glass" asp-action="Buses">@L["Seats_Buses"]</a>
            <a class="ts-btn ts-btn-glass" asp-action="Companies">@L["Seats_Companies"]</a>
            <a class="ts-btn ts-btn-glass" asp-action="DownloadTripSeatsPdf" asp-route-tripId="@tripId" target="_blank">@L["Seats_DownloadPdf"]</a>
        </div>
    </section>

    @* ── Route card ── *@
    <section class="ts-route-card">
        <span class="ts-route-label">@L["Seats_GeneralRoute"]</span>
        <div class="ts-route-content">

            <div class="route-side">
                <span class="route-type-pill">
                    @TranslateRoute(generalTripRoute)
                </span>
            </div>

            <div class="route-center">
                <span class="route-date">
                    @Model.FirstOrDefault()?.TripDate.ToString("dd/MM/yyyy")
                </span>
            </div>

            <div class="route-side route-line">
                <span class="route-part">@generalRouteFrom</span>
                <span class="route-arrow">→</span>
                <span class="route-part">@generalRouteTo</span>
            </div>

        </div>
    </section>

    @* ── Summary ── *@
    <section class="ts-summary">
        <div class="ts-stat"><small>@L["Seats_TotalSeats"]</small><strong>@totalSeats</strong></div>
        <div class="ts-stat"><small>@L["Seats_Reserved"]</small><strong>@reservedSeats</strong></div>
        <div class="ts-stat"><small>@L["Seats_Available"]</small><strong>@availableSeats</strong></div>
    </section>

    @* ── Layout ── *@
    <section class="ts-layout">

        @* Bus stage *@
        <div class="ts-card">
            <div class="ts-legend">
                <span><i class="ts-dot dot-orange"></i>@L["Seats_LegendAvailable"]</span>
                <span><i class="ts-dot dot-green"></i>@L["Seats_LegendClient"]</span>
                <span><i class="ts-dot dot-blue"></i>@L["Seats_LegendCompany"]</span>
                <span><i class="ts-dot dot-yellow"></i>@L["Seats_LegendVIP"]</span>
                <span><i class="ts-dot dot-gray"></i>@L["Seats_LegendDisabled"]</span>
            </div>

            <div class="bb-bus-stage"
                 style="--bb-cols:@cols; --bb-cell-size:70px; --bb-cell-gap:8px; --bb-bus-width:@(busWidth)px;">
                <div class="bb-bus-nose">
                    <div class="bb-windshield"></div>
                    <div class="bb-headlight left"></div>
                    <div class="bb-headlight right"></div>
                </div>
                <div class="bb-body-wrap">
                    <div class="bb-wheel left top"></div><div class="bb-wheel left bottom"></div>
                    <div class="bb-wheel right top"></div><div class="bb-wheel right bottom"></div>
                    <div class="bb-bus-body">
                        <div class="bb-side-rail left"></div>
                        <div class="bb-side-rail right"></div>
                        <div class="bb-meta">
                            <span>@L["Seats_FrontEntrance"]</span>
                            <span>@rows × @cols</span>
                        </div>
                        <div class="bb-grid">
                            @for (var r = 1; r <= rows; r++)
                            {
                                for (var c = 1; c <= cols; c++)
                                {
                                    var key = $"{r}_{c}";
                                    seatsMap.TryGetValue(key, out var seat);
                                    if (seat == null) { <div class="bb-cell empty"></div> }
                                    else
                                    {
                                        var seatText = string.IsNullOrWhiteSpace(seat.SeatLabel) ? seat.SeatNumber.ToString() : seat.SeatLabel;
                                        var css =
                                            seat.SeatType == SeatType.Driver    ? "driver" :
                                            seat.SeatType == SeatType.Assistant ? "assistant" :
                                            seat.SeatType == SeatType.Bathroom  ? "wc" :
                                            seat.IsReserved && seat.IsCompanyBooking ? "company-reserved" :
                                            seat.IsReserved ? "reserved" :
                                            seat.SeatType == SeatType.VIP ? "vip" : "seat";
                                        if (!seat.IsActive) css += " disabled-object";

                                        if (seat.IsReserved)
                                        {
                                            if (seat.IsCompanyBooking && seat.CompanySeatBookingId.HasValue)
                                            { <a class="bb-cell @css" title="@($"{seat.CompanyName} - {seat.ReservedByClient}")" asp-action="CompanySeatBookingDetails" asp-route-id="@seat.CompanySeatBookingId">@seatText</a> }
                                            else if (seat.BookingId.HasValue)
                                            { <a class="bb-cell @css" title="@($"{seat.ReservedByClient} - {seat.BookingCode}")" asp-controller="Bookings" asp-action="Details" asp-route-id="@seat.BookingId">@seatText</a> }
                                            else { <div class="bb-cell @css">@seatText</div> }
                                        }
                                        else
                                        {
                                            if (seat.SeatType == SeatType.Normal || seat.SeatType == SeatType.VIP || seat.SeatType == SeatType.Bathroom)
                                            {
                                                <form asp-action="ChangeSeatStatus" method="post" class="seat-status-form" title="@seatText">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="seatId"   value="@seat.SeatId" />
                                                    <input type="hidden" name="tripId"   value="@tripId" />
                                                    <input type="hidden" name="isActive" value="@(!seat.IsActive)" />
                                                    <button type="submit" class="bb-cell @css" onclick="return confirm('@L["Seats_ChangeSeatConfirm"]');">
                                                        @(seat.SeatType == SeatType.Bathroom ? "WC" : seatText)
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <div class="bb-cell @css" title="@seatText">
                                                    @(seat.SeatType == SeatType.Driver ? "DRV" : seat.SeatType == SeatType.Assistant ? "AST" : seat.SeatType == SeatType.Bathroom ? "WC" : seatText)
                                                </div>
                                            }
                                        }
                                    }
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Booking list *@
        <div class="ts-card">
            <h2 style="margin: 0 0 18px;">@L["Seats_ReservedBookings"]</h2>

            <div class="booking-list">
                @if (!bookings.Any())
                {
                    <div class="booking-item">
                        <div class="booking-head"><h3>@L["Seats_NoBookings"]</h3></div>
                    </div>
                }
                else
                {
                    foreach (var booking in bookings)
                    {
                        var b = booking.First;

                        var seatsText = string.Join(", ", booking.Seats.Select(x =>
                            string.IsNullOrWhiteSpace(x.SeatLabel) ? x.SeatNumber.ToString() : x.SeatLabel));

                        var phones = (b.PhoneNumbersText ?? string.Empty)
                            .Split(new[] { '-', ',', '/', '|' }, StringSplitOptions.RemoveEmptyEntries)
                            .Select(p => p.Trim()).Where(p => !string.IsNullOrWhiteSpace(p)).Distinct().ToList();

                        var transportTotal = booking.Seats.Sum(x => x.TransportationTotal);
                        var grandTotal     = b.IsCompanyBooking ? booking.Seats.Sum(x => x.GrandTotal)      : b.GrandTotal;
                        var remaining      = b.IsCompanyBooking ? booking.Seats.Sum(x => x.RemainingAmount) : b.RemainingAmount;

                        @* ── Translate all English strings from Manager ── *@
                        var bookingTypeRaw = !string.IsNullOrWhiteSpace(b.TripTypeText) ? b.TripTypeText
                            : b.IsCompanyBooking ? "Company"
                            : b.HasHotel && b.HasTransportation ? "HotelTransport"
                            : b.HasHotel ? "Hotel" : "Transport";

                        var bookingTypeDisplay = bookingTypeRaw switch
                        {
                            "Company"        => L["Seats_TypeCompany"].Value,
                            "HotelTransport" => L["Seats_TypeHotelTransport"].Value,
                            "Hotel"          => L["Seats_TypeHotel"].Value,
                            "Transport"      => L["Seats_TypeTransport"].Value,
                            _                => TranslateTripType(bookingTypeRaw)
                        };

                        @* TripRouteText: "Go" / "Return" from Manager → translated *@
                        var tripRouteDisplay = TranslateRoute(b.TripRouteText);

                        @* SeatRouteFrom / SeatRouteTo: location strings — not translated *@
                        var seatRouteFrom = string.IsNullOrWhiteSpace(b.SeatRouteFrom) ? "-" : b.SeatRouteFrom;
                        var seatRouteTo   = string.IsNullOrWhiteSpace(b.SeatRouteTo)   ? "-" : b.SeatRouteTo;

                        <div class="booking-item">

                            @* Head *@
                            <div class="booking-head">
                                <h3>@(b.ReservedByClient ?? "-")</h3>
                                <span class="code-pill @(b.IsCompanyBooking ? "company-pill" : "")">
                                    @(b.IsCompanyBooking ? L["Seats_CompanyBookingPill"].Value : b.BookingCode)
                                </span>
                            </div>

                            @* Meta *@
                            <div class="booking-meta">

                                <div class="meta-row">
                                    <span class="meta-label">@L["Seats_SeatsLabel"]:</span>
                                    <span class="meta-value">@seatsText</span>
                                </div>

                                <div class="meta-row">
                                    <span class="meta-label">@L["Seats_TypeLabel"]:</span>
                                    <span class="meta-value">@bookingTypeDisplay</span>
                                </div>

                                <div class="meta-row">
                                    <span class="meta-label">@L["Seats_TripRoute"]:</span>
                                    @* ← مترجم من "Go"/"Return" للغة الحالية *@
                                    <span class="meta-value">@tripRouteDisplay</span>
                                </div>

                                <div class="meta-row">
                                    <span class="meta-label">@L["Seats_BookingRoute"]:</span>
                                    <span class="route-pill">
                                        <span class="route-part">@seatRouteFrom</span>
                                        <span class="route-arrow">→</span>
                                        <span class="route-part">@seatRouteTo</span>
                                    </span>
                                </div>

                                @if (b.IsCompanyBooking && !string.IsNullOrWhiteSpace(b.CompanyName))
                                {
                                    <div class="meta-row">
                                        <span class="meta-label">@L["Seats_CompanyLabel"]:</span>
                                        <span class="meta-value">@b.CompanyName</span>
                                    </div>
                                }

                                <div class="meta-row">
                                    <span class="meta-label">@L["Seats_PhonesLabel"]:</span>
                                </div>

                                @if (phones.Any())
                                {
                                    <div class="phone-list">
                                        @foreach (var phone in phones)
                                        {
                                            <span class="phone-pill">@phone</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="meta-row"><span class="meta-value">-</span></div>
                                }

                            </div>

                            @* Money *@
                            <div class="money-grid">
                                <div class="money-box"><small>@L["Seats_Hotel"]</small><strong>@b.HotelTotal.ToString("N2")</strong></div>
                                <div class="money-box"><small>@L["Seats_Transportation"]</small><strong>@transportTotal.ToString("N2")</strong></div>
                                <div class="money-box"><small>@L["Seats_Total"]</small><strong>@grandTotal.ToString("N2")</strong></div>
                                <div class="money-box"><small>@L["Seats_Paid"]</small><strong class="success">@b.PaidAmount.ToString("N2")</strong></div>
                                <div class="money-box"><small>@L["Seats_Remaining"]</small><strong class="@(remaining > 0 ? "danger" : "success")">@remaining.ToString("N2")</strong></div>
                                <div class="money-box"><small>@L["Seats_Discount"]</small><strong>@b.Discount.ToString("N2")</strong></div>
                            </div>

                            @* Action *@
                            @if (b.IsCompanyBooking && b.CompanySeatBookingId.HasValue)
                            {
                                <a class="details-btn" asp-action="CompanySeatBookingDetails" asp-route-id="@b.CompanySeatBookingId">@L["Seats_OpenCompanyBooking"]</a>
                            }
                            else if (b.BookingId.HasValue)
                            {
                                <a class="details-btn" asp-controller="Bookings" asp-action="Details" asp-route-id="@b.BookingId">@L["Seats_OpenBookingDetails"]</a>
                            }

                        </div>
                    }
                }
            </div>
        </div>

    </section>

</div>