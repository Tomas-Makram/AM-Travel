@{
    ViewData["Title"] = "Developer Portal";
    Layout = null;

    var codeVerified = Context.Request.Cookies["DEV_CODE_VERIFIED"] == "true";

    bool codeStillValid = false;
    if (codeVerified)
    {
        var atText = Context.Request.Cookies["DEV_CODE_VERIFIED_AT"];
        if (DateTime.TryParse(atText, out var at))
            codeStillValid = DateTime.UtcNow - at <= TimeSpan.FromMinutes(15);
    }

    int stage = codeStillValid ? 2 : 1;

    var devError   = TempData["DevError"]?.ToString();
    var devSuccess = TempData["DevSuccess"]?.ToString();
    string OtpExpireMinutes = ViewBag.OtpExpireMinutes?.ToString() ?? "5";
}
<!DOCTYPE html>
<html dir="ltr" lang="en-au">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Developer Portal</title>
    <style>
        *{box-sizing:border-box;margin:0;padding:0;}
        body{
            min-height:100vh;
            display:grid;place-items:center;
            background:radial-gradient(circle at 20% 20%,#172033,#0d1421);
            font-family:'Segoe UI',system-ui,sans-serif;
            padding:20px;
        }
        .card{
            width:min(480px,100%);
            background:rgba(255,255,255,.04);
            border:1px solid rgba(255,255,255,.1);
            border-radius:32px;
            padding:36px;
            box-shadow:0 32px 80px rgba(0,0,0,.5);
            backdrop-filter:blur(12px);
        }
        .badge{
            display:inline-flex;align-items:center;gap:8px;
            padding:8px 14px;border-radius:999px;
            background:rgba(255,122,24,.15);
            border:1px solid rgba(255,122,24,.3);
            color:#ffad42;font-weight:900;font-size:13px;
            margin-bottom:18px;
        }
        h1{color:#fff;font-size:30px;font-weight:1000;margin-bottom:8px;}
        .subtitle{color:rgba(255,255,255,.5);font-size:14px;font-weight:700;margin-bottom:28px;line-height:1.6;}

        /* steps */
        .steps{display:flex;gap:6px;margin-bottom:28px;}
        .step-dot{
            flex:1;height:5px;border-radius:999px;
            background:rgba(255,255,255,.15);transition:.3s;
        }
        .step-dot.done{background:#ff7a18;}
        .step-dot.active{background:linear-gradient(90deg,#ff7a18,#ffad42);}

        .field{margin-bottom:16px;}
        label{display:block;color:rgba(255,255,255,.6);font-size:13px;font-weight:900;margin-bottom:7px;}
        input[type=text],input[type=password]{
            width:100%;padding:14px 18px;
            border-radius:16px;border:1px solid rgba(255,255,255,.12);
            background:rgba(255,255,255,.07);color:#fff;
            font-size:15px;font-weight:700;outline:none;transition:.2s;
        }
        input[type=text]:focus,input[type=password]:focus{
            border-color:#ff7a18;background:rgba(255,255,255,.1);
            box-shadow:0 0 0 4px rgba(255,122,24,.18);
        }
        input::placeholder{color:rgba(255,255,255,.3);}

        .btn{
            width:100%;padding:15px;border-radius:16px;border:none;
            font-size:15px;font-weight:1000;cursor:pointer;transition:.2s;
            margin-top:4px;
        }
        .btn-primary{background:linear-gradient(135deg,#ff7a18,#ffad42);color:#fff;box-shadow:0 12px 30px rgba(255,122,24,.25);}
        .btn-primary:hover{transform:translateY(-2px);box-shadow:0 18px 40px rgba(255,122,24,.3);}
        .btn-ghost{background:rgba(255,255,255,.06);color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.1);}
        .btn-ghost:hover{background:rgba(255,255,255,.1);}

        .alert{
            padding:13px 16px;border-radius:14px;font-size:14px;font-weight:900;
            margin-bottom:18px;
        }
        .alert-err{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#fca5a5;}
        .alert-ok {background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);color:#6ee7b7;}

        .stage-label{
            display:flex;align-items:center;gap:10px;margin-bottom:20px;
        }
        .stage-num{
            width:34px;height:34px;border-radius:50%;
            background:linear-gradient(135deg,#ff7a18,#ffad42);
            color:#fff;font-weight:1000;font-size:15px;
            display:grid;place-items:center;flex-shrink:0;
        }
        .stage-title{color:#fff;font-size:16px;font-weight:1000;}
        .stage-sub{color:rgba(255,255,255,.45);font-size:12px;}

        .otp-input{
            text-align:center;letter-spacing:10px;font-size:26px !important;
        }

        .divider{
            border:none;border-top:1px solid rgba(255,255,255,.08);
            margin:22px 0;
        }

        .info-note{
            background:rgba(255,255,255,.05);border-radius:12px;
            padding:12px 14px;color:rgba(255,255,255,.45);
            font-size:13px;line-height:1.6;margin-bottom:18px;
        }
        .info-note span{color:#ffad42;font-weight:900;}
    </style>
</head>
<body>
    <div class="card">

        <span class="badge">Developer Portal</span>
        <h1>Developer Access</h1>
        <p class="subtitle">
            @if (stage == 1)
            {
                <text>Enter the large OTP on Telegram.</text>
            }
            else
            {
                <text>An OTP has been sent — enter it to continue.</text>
            }
        </p>

        <!-- Steps indicator -->
        <div class="steps">
            <div class="step-dot @(stage >= 1 ? "active" : "")"></div>
            <div class="step-dot @(stage >= 2 ? "active" : "")"></div>
            <div class="step-dot"></div>
        </div>

        @if (!string.IsNullOrWhiteSpace(devError))
        {
            <div class="alert alert-err">@devError</div>
        }
        @if (!string.IsNullOrWhiteSpace(devSuccess))
        {
            <div class="alert alert-ok">@devSuccess</div>
        }

        @if (stage == 1)
        {
            <div class="stage-label">
                <div class="stage-num">1</div>
                <div>
                    <div class="stage-title">Secret Code</div>
                    <div class="stage-sub">Enter the secret code to send OTP</div>
                </div>
            </div>

            <form asp-action="DevPortalSendOtp" method="post">
                @Html.AntiForgeryToken()
                <div class="field">
                    <label>Secret Code</label>
                    <input type="password" name="secretCode" placeholder="Enter the code" required autofocus />
                </div>
                <button type="submit" class="btn btn-primary">Send OTP on Telegram</button>
            </form>
        }
        else
        {
            <div class="stage-label">
                <div class="stage-num">2</div>
                <div>
                    <div class="stage-title">OTP Code</div>
                    <div class="stage-sub">Verify on Telegram</div>
                </div>
            </div>

            <div class="info-note">
                An OTP code has been sent to <span>Telegram</span> The code is valid for <span>@OtpExpireMinutes minutes</span>.
            </div>

            <form asp-action="DevPortalVerifyOtp" method="post">
                @Html.AntiForgeryToken()
                <div class="field">
                    <label>OTP Code</label>
                    <input class="otp-input" type="text" name="otpCode"
                           placeholder="000000" maxlength="6"
                           inputmode="numeric" pattern="[0-9]{6}"
                           required autofocus />
                </div>
                <button type="submit" class="btn btn-primary">Verify OTP</button>
            </form>

            <hr class="divider" />

            <form asp-action="DevPortalSendOtp" method="post">
                @Html.AntiForgeryToken()
                <div class="field">
                    <label>Resend OTP — Secret Code</label>
                    <input type="password" name="secretCode" placeholder="Enter the secret code again" />
                </div>
                <button type="submit" class="btn btn-ghost">Resend OTP</button>
            </form>
        }

    </div>
</body>
</html>