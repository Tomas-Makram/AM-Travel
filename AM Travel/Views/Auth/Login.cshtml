@model BusinessLayer.DTOs.Auth.LoginDTO

@{
    ViewData["Title"] = L["Login_Title"];
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
      data-theme="@(Context.Request.Cookies["theme"] ?? "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - AM Travel</title>
    <link rel="stylesheet" href="~/css/amtravel.css" asp-append-version="true" />
</head>
<body>

<style>
    /* ── CSS Variables: Light & Dark ─────────────────────────────────────── */
    :root {
        --lg-page-bg:         #f5f7fb;
        --lg-blob1:           rgba(255,122,24,.18);
        --lg-blob2:           rgba(255,173,66,.20);
        --lg-shell-bg:        rgba(255,255,255,.86);
        --lg-shell-border:    rgba(240,216,194,.9);
        --lg-shell-shadow:    rgba(255,122,24,.18);
        --lg-art-bg:          linear-gradient(135deg, #ff7a18, #ffad42);
        --lg-panel-bg:        #fff;
        --lg-panel-radial:    rgba(255,122,24,.08);
        --lg-input-bg:        #fffaf5;
        --lg-input-border:    #f0d8c2;
        --lg-input-text:      #172033;
        --lg-label:           #172033;
        --lg-heading:         #172033;
        --lg-sub:             #667085;
        --lg-mini-badge-bg:   #fff3e6;
        --lg-mini-badge-txt:  #ff7a18;
        --lg-toggle-bg:       #fff3e6;
        --lg-toggle-txt:      #ff7a18;
        --lg-footer-txt:      #667085;
        --lg-footer-link:     #ff7a18;
    }

    html[data-theme="dark"] {
        --lg-page-bg:         #0f172a;
        --lg-blob1:           rgba(196,92,10,.14);
        --lg-blob2:           rgba(217,124,42,.14);
        --lg-shell-bg:        rgba(30,37,53,.92);
        --lg-shell-border:    rgba(45,54,80,.9);
        --lg-shell-shadow:    rgba(0,0,0,.40);
        --lg-art-bg:          linear-gradient(135deg, #c45c0a, #d97c2a);
        --lg-panel-bg:        #1e2535;
        --lg-panel-radial:    rgba(196,92,10,.08);
        --lg-input-bg:        #252d3f;
        --lg-input-border:    #3a4460;
        --lg-input-text:      #d4cbc3;
        --lg-label:           #d4cbc3;
        --lg-heading:         #e8ddd5;
        --lg-sub:             #8a96a8;
        --lg-mini-badge-bg:   rgba(196,92,10,.22);
        --lg-mini-badge-txt:  #e8925a;
        --lg-toggle-bg:       rgba(196,92,10,.22);
        --lg-toggle-txt:      #e8925a;
        --lg-footer-txt:      #8a96a8;
        --lg-footer-link:     #e8925a;
    }

    * { box-sizing: border-box; }

    body {
        margin: 0;
        background: var(--lg-page-bg);
        font-family: system-ui, -apple-system, sans-serif;
        transition: background .3s;
    }

    /* ── Page wrapper ────────────────────────────────────────────────────── */
    .login-page {
        min-height: 100vh;
        display: grid;
        place-items: center;
        position: relative;
        overflow: hidden;
        padding: 30px 16px;
    }

        .login-page::before {
            content: "";
            position: absolute;
            width: 520px;
            height: 520px;
            border-radius: 50%;
            top: -180px;
            right: -140px;
            background: var(--lg-blob1);
            filter: blur(4px);
        }

        .login-page::after {
            content: "";
            position: absolute;
            width: 360px;
            height: 360px;
            border-radius: 50%;
            bottom: -140px;
            left: -100px;
            background: var(--lg-blob2);
            filter: blur(4px);
        }

    /* ── Shell ───────────────────────────────────────────────────────────── */
    .login-shell {
        width: min(1080px, 100%);
        display: grid;
        grid-template-columns: .95fr 1.05fr;
        border-radius: 36px;
        overflow: hidden;
        background: var(--lg-shell-bg);
        border: 1px solid var(--lg-shell-border);
        box-shadow: 0 28px 90px var(--lg-shell-shadow);
        position: relative;
        z-index: 1;
        transition: background .3s, border-color .3s, box-shadow .3s;
    }

    /* ── Art panel ───────────────────────────────────────────────────────── */
    .login-art {
        position: relative;
        padding: 42px;
        color: #fff;
        background: radial-gradient(circle at 20% 15%, rgba(255,255,255,.28), transparent 25%),
                    var(--lg-art-bg);
        min-height: 620px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 34px;
    }

        .login-art::after {
            content: "";
            position: absolute;
            inset: auto -80px -80px auto;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: rgba(255,255,255,.14);
        }

    .login-brand {
        display: flex;
        align-items: center;
        gap: 14px;
        position: relative;
        z-index: 1;
    }

    .login-brand-logo {
        width: 72px;
        height: 72px;
        border-radius: 24px;
        background: #fff;
        padding: 8px;
        object-fit: contain;
        box-shadow: 0 18px 40px rgba(0,0,0,.14);
    }

    .login-brand strong {
        display: block;
        font-size: 25px;
        line-height: 1;
        color: #fff;
    }

    .login-brand small {
        display: block;
        margin-top: 6px;
        opacity: .9;
        font-weight: 700;
        color: #fff;
    }

    .login-copy {
        position: relative;
        z-index: 1;
    }

        .login-copy h1 {
            margin: 0 0 16px;
            font-size: clamp(38px, 5vw, 64px);
            line-height: 1.03;
            letter-spacing: -1.6px;
            color: #fff;
        }

        .login-copy p {
            margin: 0;
            max-width: 520px;
            font-size: 18px;
            line-height: 1.9;
            color: rgba(255,255,255,.93);
        }

    /* ── Form panel ──────────────────────────────────────────────────────── */
    .login-form-panel {
        padding: 46px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: radial-gradient(circle at top right, var(--lg-panel-radial), transparent 30%),
                    var(--lg-panel-bg);
        transition: background .3s;
    }

    .login-form-head { margin-bottom: 24px; }

    .mini-badge {
        display: inline-flex;
        padding: 8px 13px;
        border-radius: 999px;
        background: var(--lg-mini-badge-bg);
        color: var(--lg-mini-badge-txt);
        font-weight: 900;
        font-size: 13px;
        transition: background .3s, color .3s;
    }

    .login-form-head h2 {
        margin: 16px 0 8px;
        font-size: 34px;
        color: var(--lg-heading);
        letter-spacing: -.7px;
        transition: color .3s;
    }

    .login-form-head p {
        margin: 0;
        color: var(--lg-sub);
        line-height: 1.7;
        transition: color .3s;
    }

    /* ── Fields ──────────────────────────────────────────────────────────── */
    .login-form { display: grid; gap: 16px; }

    .login-field { display: grid; gap: 8px; }

        .login-field label {
            font-weight: 900;
            color: var(--lg-label);
            font-size: 14px;
            transition: color .3s;
        }

    .login-input-wrap { position: relative; }

        .login-input-wrap input {
            width: 100%;
            border: 1px solid var(--lg-input-border);
            border-radius: 18px;
            padding: 15px 16px;
            font-size: 15px;
            outline: none;
            background: var(--lg-input-bg);
            color: var(--lg-input-text);
            transition: .22s ease;
        }

            .login-input-wrap input:focus {
                border-color: rgba(255,122,24,.55);
                background: var(--lg-panel-bg);
                box-shadow: 0 0 0 5px rgba(255,122,24,.10);
            }

            .login-input-wrap input::placeholder {
                color: var(--lg-sub);
                opacity: .7;
            }

    .password-wrap input { padding-right: 56px; }

    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 13px;
        background: var(--lg-toggle-bg);
        color: var(--lg-toggle-txt);
        display: grid;
        place-items: center;
        cursor: pointer;
        transition: .2s ease;
    }

        .password-toggle:hover {
            background: #ff7a18;
            color: #fff;
        }

        .password-toggle svg { width: 20px; height: 20px; }

    /* ── Validation ──────────────────────────────────────────────────────── */
    .login-validation,
    .field-validation-error,
    .validation {
        color: #ef4444;
        font-size: 13px;
        font-weight: 700;
    }

    /* ── Submit ──────────────────────────────────────────────────────────── */
    .login-submit {
        width: 100%;
        border: none;
        border-radius: 18px;
        padding: 15px 20px;
        background: linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        font-weight: 900;
        font-size: 16px;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(255,122,24,.24);
        transition: .22s ease;
        margin-top: 4px;
    }

        .login-submit:hover {
            transform: translateY(-2px);
            filter: brightness(1.03);
        }

        .login-submit:active { transform: translateY(0); }

    /* ── Footer note ─────────────────────────────────────────────────────── */
    .login-footer-note {
        margin-top: 18px;
        text-align: center;
        color: var(--lg-footer-txt);
        font-size: 14px;
        transition: color .3s;
    }

        .login-footer-note a {
            color: var(--lg-footer-link);
            font-weight: 900;
            text-decoration: none;
            transition: color .3s;
        }

    /* ── Responsive ──────────────────────────────────────────────────────── */
    @@media (max-width: 1000px) {
        .login-shell { grid-template-columns: 1fr; }
        .login-art   { min-height: auto; }
    }

    @@media (max-width: 640px) {
        .login-page,
        .login-art,
        .login-form-panel { padding: 26px; }

        .login-copy h1 { font-size: 38px; }
    }
</style>

<div class="login-page">
    <div class="login-shell">

        @* Art panel *@
        <section class="login-art">
            <div class="login-brand">
                <img class="login-brand-logo"
                     src="~/img/Logo.jpg"
                     asp-append-version="true"
                     alt="AM Travel Logo" />
                <div>
                    <strong>AM Travel</strong>
                    <small>@L["Login_BrandTagline"]</small>
                </div>
            </div>

            <div class="login-copy">
                <h1>@L["Login_Welcome"]</h1>
                <p>@L["Login_WelcomeSub"]</p>
            </div>
        </section>

        @* Form panel *@
        <section class="login-form-panel">
            <div class="login-form-head">
                <span class="mini-badge">@L["Login_MiniBadge"]</span>
                <h2>@L["Login_FormTitle"]</h2>
                <p>@L["Login_FormSubtitle"]</p>
            </div>

            <form asp-action="Login" method="post" class="login-form">
                @Html.AntiForgeryToken()

                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div asp-validation-summary="ModelOnly" class="login-validation"></div>

                <div class="login-field">
                    <label asp-for="EmailOrPhoneOrUsernameOrNationalId">
                        @L["Login_IdentifierLabel"]
                    </label>

                    <div class="login-input-wrap">
                        <input asp-for="EmailOrPhoneOrUsernameOrNationalId"
                               placeholder="@L["Login_IdentifierPH"]"
                               autocomplete="username" />
                    </div>

                    <span asp-validation-for="EmailOrPhoneOrUsernameOrNationalId"
                          class="field-validation-error"></span>
                </div>

                <div class="login-field">
                    <label asp-for="Password">@L["Login_PasswordLabel"]</label>

                    <div class="login-input-wrap password-wrap">
                        <input asp-for="Password"
                               id="passwordInput"
                               type="password"
                               placeholder="@L["Login_PasswordPH"]"
                               autocomplete="current-password" />

                        <button type="button"
                                class="password-toggle"
                                id="togglePassword"
                                aria-label="@L["Login_ShowPassword"]">
                            <svg id="eyeIcon"
                                 xmlns="http://www.w3.org/2000/svg"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12s-3.75 6.75-9.75 6.75S2.25 12 2.25 12z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </button>
                    </div>

                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <button class="login-submit" type="submit">
                    @L["Login_Submit"]
                </button>
            </form>

            <div class="login-footer-note">
                @L["Login_BackTo"] <a asp-controller="Home" asp-action="Index">@L["Login_HomeLink"]</a>
            </div>
        </section>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const passwordInput  = document.getElementById("passwordInput");
        const togglePassword = document.getElementById("togglePassword");
        const eyeIcon        = document.getElementById("eyeIcon");

        const showLabel = "@L["Login_ShowPassword"]";
        const hideLabel = "@L["Login_HidePassword"]";

        const eyeSvg = `
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12s-3.75 6.75-9.75 6.75S2.25 12 2.25 12z" />
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`;

        const eyeOffSvg = `
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18" />
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M10.58 10.58A2 2 0 0012 14a2 2 0 001.42-.58" />
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9.88 5.55A8.6 8.6 0 0112 5.25c6 0 9.75 6.75 9.75 6.75a18.8 18.8 0 01-3.09 3.84" />
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M6.61 6.61C3.78 8.45 2.25 12 2.25 12s3.75 6.75 9.75 6.75a8.8 8.8 0 004.1-.99" />`;

        togglePassword.addEventListener("click", function () {
            const isPassword = passwordInput.type === "password";
            passwordInput.type = isPassword ? "text" : "password";
            togglePassword.setAttribute("aria-label", isPassword ? hideLabel : showLabel);
            eyeIcon.innerHTML = isPassword ? eyeOffSvg : eyeSvg;
        });
    </script>
}

</body>
</html>
