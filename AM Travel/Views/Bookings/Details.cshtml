    }

        .booking-created-user-btn:hover {
            background: #fff;
            color: #ff7a18;
            transform: translateY(-1px);
        }

        .booking-created-user-btn::before {
            content: "👤";
            font-size: 13px;
        }

    .details-created-user-btn {
        border: 1px solid rgba(255,122,24,.30);
        background: var(--bd-soft2);
        color: #ff7a18;
        border-radius: 999px;
        padding: 7px 12px;
        font-weight: 1000;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: .2s ease;
        box-shadow: 0 8px 18px rgba(255,122,24,.10);
    }

        .details-created-user-btn:hover {
            background: #ff7a18;
            color: #fff;
            transform: translateY(-1px);
        }

        .details-created-user-btn::before {
            content: "👤";
            font-size: 13px;
        }

    .user-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: none;
        place-items: center;
        padding: 18px;
        background: rgba(15,23,42,.58);
        backdrop-filter: blur(8px);
    }

        .user-modal-overlay.show {
            display: grid;
        }

    .user-modal {
        width: min(480px, 100%);
        overflow: hidden;
        border-radius: 30px;
        background: var(--bd-card);
        border: 1px solid var(--bd-card-border);
        box-shadow: 0 28px 90px rgba(15,23,42,.25);
    }

    .user-modal-head {
        position: relative;
        overflow: hidden;
        padding: 24px;
        color: #fff;
        background: var(--bd-hero-bg);
    }

        .user-modal-head::after {
            content: "";
            position: absolute;
            width: 150px;
            height: 150px;
            right: -48px;
            bottom: -70px;
            border-radius: 50%;
            background: rgba(255,255,255,.16);
        }

    .user-modal-title {
        position: relative;
        z-index: 1;
        margin: 0;
        font-size: 26px;
        font-weight: 1000;
    }

    .user-modal-subtitle {
        position: relative;
        z-index: 1;
        margin-top: 7px;
