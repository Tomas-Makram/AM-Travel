@using AM_Travel.Resources
@using Microsoft.Extensions.Localization
@model BusinessLayer.DTOs.Book.BookingDetailsDTO
@using BusinessLayer.DTOs.Book
@using DataLayer.Models
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = $"{L["BkDet_BookingWord"]} {Model.Code}";

    var bookingType =
        Model.HasHotel && Model.HasTransportation ? L["BkDet_TypeHT"].Value :
        Model.HasHotel ? L["BkDet_TypeHotelOnly"].Value :
        Model.HasTransportation ? L["BkDet_TypeTransportOnly"].Value :
        L["BkDet_TypeNA"].Value;

    var mainPhone = Model.PhoneNumbers?.FirstOrDefault(x => x.Prime)?.PhoneNumber
                 ?? Model.PhoneNumbers?.FirstOrDefault()?.PhoneNumber
                 ?? L["BkDet_TypeNA"].Value;

    string fullName = Model.CreatedBy ?? "Admin Administrator";
    var cleanName = fullName.Trim().Replace("  ", " ");

    var userName = string.Join("", cleanName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(userName))
    {
        userName = "AA";
    }

    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}

<style>
    :root {
        --bd-hero-bg: linear-gradient(135deg,#ff7a18,#ffad42);
        --bd-hero-glow: rgba(255,122,24,.18);
        --bd-hero-text: #fff;
        --bd-hero-sub: rgba(255,255,255,.92);
        --bd-glass: rgba(255,255,255,.16);
        --bd-card: #fff;
        --bd-card-border: #f0d8c2;
        --bd-card-shadow: rgba(255,122,24,.09);
        --bd-text: #172033;
        --bd-text-strong: #172033;
        --bd-muted: #667085;
        --bd-faint: #98a2b3;
        --bd-line: #f3dfcc;
        --bd-line-soft: #f7eee6;
        --bd-soft: #fffaf5;
        --bd-soft2: #fff3e6;
        --bd-soft3: #fff7ed;
        --bd-orange: #ff7a18;
        --bd-danger: #dc2626;
        --bd-success: #16a34a;
        --bd-code-bg: #eff6ff;
        --bd-code-text: #2563eb;
        --bd-ok-bg: #dcfce7;
        --bd-ok-text: #166534;
        --bd-go-bg: #eff6ff;
        --bd-go-text: #1d4ed8;
        --bd-return-bg: #fef3c7;
        --bd-return-text: #b45309;
        --bd-busshell-bg: #fff;
        --bd-buscell-bg: #fff;
        --bd-buscell-border: #f0c9a5;
        --bd-busgrid-bg: #fffaf5;
        --bd-road-a: #f2f4f7;
        --bd-road-b: #e4e7ec;
        --bd-road-border: #d0d5dd;
        --bd-loc-bg: #f0fdf4;
        --bd-loc-border: #bbf7d0;
        --bd-loc-text: #166534;
        --bd-loc-chip-bg: #dcfce7;
        --bd-loc-chip-border: #86efac;
        --bd-modal-bg: #fffaf5;
    }

    html[data-theme="dark"] {
        --bd-hero-bg: linear-gradient(135deg,#c45c0a,#d97c2a);
        --bd-hero-glow: rgba(196,92,10,.22);
        --bd-hero-text: #f5f0eb;
        --bd-hero-sub: rgba(245,240,235,.85);
        --bd-glass: rgba(255,255,255,.12);
        --bd-card: #1a2236;
        --bd-card-border: #283148;
        --bd-card-shadow: rgba(0,0,0,.35);
        --bd-text: #dce3ed;
        --bd-text-strong: #f5f7fa;
        --bd-muted: #7a8ba0;
        --bd-faint: #6b7488;
        --bd-line: #3a4d66;
        --bd-line-soft: #2e3a4f;
        --bd-soft: #212c3f;
        --bd-soft2: #3a2b18;
        --bd-soft3: #232b3b;
        --bd-danger: #f87171;
        --bd-success: #34d399;
        --bd-code-bg: #1e2a44;
        --bd-code-text: #7aa7ff;
        --bd-ok-bg: #1f3329;
        --bd-ok-text: #6ee7b7;
        --bd-go-bg: #1e2a44;
        --bd-go-text: #93b8ff;
        --bd-return-bg: #3a3320;
        --bd-return-text: #fcd34d;
        --bd-busshell-bg: #1a2236;
        --bd-buscell-bg: #212c3f;
        --bd-buscell-border: #3a4d66;
        --bd-busgrid-bg: #232b3b;
        --bd-road-a: #2a3346;
        --bd-road-b: #1f2738;
        --bd-road-border: #3a4d66;
        --bd-loc-bg: #16291f;
        --bd-loc-border: #2c5440;
        --bd-loc-text: #6ee7b7;
        --bd-loc-chip-bg: #1f3329;
        --bd-loc-chip-border: #2c5440;
        --bd-modal-bg: #1a2236;
    }

    .booking-page {
        display: grid;
        gap: 20px;
        color: var(--bd-text);
    }

    .booking-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--bd-hero-text);
        background: var(--bd-hero-bg);
        box-shadow: 0 24px 70px var(--bd-hero-glow);
    }

        .booking-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.22), transparent 26%);
            pointer-events: none;
        }

        .booking-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            right: -90px;
            bottom: -110px;
            border-radius: 50%;
            background: rgba(255,255,255,.16);
            pointer-events: none;
        }

    .booking-page[dir="rtl"] .booking-hero::after {
        right: auto;
        left: -90px;
    }

    .booking-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .booking-title {
        display: grid;
        gap: 10px;
    }

    .booking-badge {
        width: fit-content;
        padding: 8px 18px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--bd-hero-text);
    }

    .booking-title h1 {
        margin: 0;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--bd-hero-text);
    }

    .booking-title p {
        margin: 0;
        color: var(--bd-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    .booking-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.10);
        flex-shrink: 0;
    }

        .booking-avatar-wrap::before {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid rgba(255,255,255,.22);
        }

        .booking-avatar-wrap::after {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid transparent;
            border-top-color: #fff;
            border-right-color: rgba(255,255,255,.72);
            animation: booking-avatar-spin 4s linear infinite;
        }

    .booking-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)), linear-gradient(135deg, #ffffff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .booking-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
        box-shadow: 0 8px 18px rgba(18,183,106,.35);
    }

    .booking-page[dir="rtl"] .booking-avatar-status {
        right: auto;
        left: 13px;
    }

    @@keyframes booking-avatar-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .booking-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .booking-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
        border: 0;
        cursor: pointer;
    }

        .booking-btn:hover {
            transform: translateY(-2px);
        }

    .btn-white {
        background: #fff;
        color: #ff7a18;
        box-shadow: 0 14px 30px rgba(0,0,0,.12);
    }

    .btn-glass {
        background: var(--bd-glass);
        color: var(--bd-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

    .btn-report {
        background: #ffffff;
        color: #344054;
        box-shadow: 0 14px 30px rgba(0,0,0,.12);
    }

    .btn-ticket {
        background: #12b76a;
        color: #fff;
        box-shadow: 0 14px 30px rgba(18,183,106,.28);
    }

    .btn-audit {
        background: #2563eb;
        color: #fff;
        box-shadow: 0 14px 30px rgba(37,99,235,.25);
    }

    .btn-edit {
        background: #7c3aed;
        color: #fff;
        box-shadow: 0 14px 30px rgba(124,58,237,.24);
    }

    .btn-delete {
        background: #dc2626;
        color: #fff;
        box-shadow: 0 14px 30px rgba(220,38,38,.26);
    }

    .delete-inline-form {
        margin: 0;
        display: inline-flex;
    }

    .booking-btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 999px;
        background: rgba(255,255,255,.22);
        font-size: 13px;
        margin-inline-end: 8px;
    }

    .btn-white .booking-btn-icon,
    .btn-report .booking-btn-icon {
        background: rgba(255,122,24,.12);
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 14px;
    }

    .summary-card,
    .details-card {
        background: var(--bd-card);
        border: 1px solid var(--bd-card-border);
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 16px 38px var(--bd-card-shadow);
        transition: background .3s, border-color .3s;
    }

        .summary-card small {
            display: block;
            margin-bottom: 8px;
            color: var(--bd-muted);
            font-weight: 900;
        }

        .summary-card strong {
            display: block;
            color: var(--bd-text-strong);
            font-size: 28px;
            font-weight: 1000;
        }

    .content-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 18px;
    }

    .details-card {
        grid-column: span 6;
        border-radius: 30px;
        padding: 24px;
    }

        .details-card.wide {
            grid-column: span 12;
        }

        .details-card h3 {
            margin: 0 0 18px;
            color: var(--bd-text-strong);
            font-size: 21px;
            font-weight: 1000;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--bd-line);
        }

    .info-list {
        display: grid;
        gap: 10px;
    }

    .info-row {
        display: grid;
        grid-template-columns: 170px 1fr;
        gap: 12px;
        padding: 11px 0;
        border-bottom: 1px solid var(--bd-line-soft);
    }

        .info-row:last-child {
            border-bottom: 0;
        }

    .info-label {
        color: var(--bd-muted);
        font-size: 13px;
        font-weight: 900;
    }

    .info-value {
        color: var(--bd-text);
        font-weight: 900;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
        color: #ff7a18;
        background: var(--bd-soft2);
        white-space: nowrap;
    }

    .code-pill {
        color: var(--bd-code-text);
        background: var(--bd-code-bg);
        font-family: monospace;
    }

    .ok-pill {
        background: var(--bd-ok-bg);
        color: var(--bd-ok-text);
    }

    .go-pill {
        background: var(--bd-go-bg);
        color: var(--bd-go-text);
    }

    .return-pill {
        background: var(--bd-return-bg);
        color: var(--bd-return-text);
    }

    .success {
        color: var(--bd-success) !important;
    }

    .danger {
        color: var(--bd-danger) !important;
    }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 6px;
        scrollbar-width: thin;
        scrollbar-color: var(--bd-orange) var(--bd-soft2);
    }

        .table-wrap::-webkit-scrollbar {
            height: 12px;
        }

        .table-wrap::-webkit-scrollbar-track {
            background: var(--bd-soft2);
            border-radius: 999px;
        }

        .table-wrap::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg,#ff7a18,#ffad42);
            border-radius: 999px;
            border: 3px solid var(--bd-soft2);
        }

    .details-table {
        width: 100%;
        min-width: 760px;
        table-layout: fixed;
        border-collapse: separate;
        border-spacing: 0 10px;
        direction: ltr;
    }

    .booking-page[dir="rtl"] .details-table {
        direction: rtl;
    }

        .details-table th {
            color: var(--bd-muted);
            font-size: 13px;
            padding: 0 12px;
            white-space: nowrap;
            vertical-align: middle;
        }

    .booking-page:not([dir="rtl"]) .details-table th,
    .booking-page:not([dir="rtl"]) .details-table td {
        text-align: left;
    }

    .booking-page[dir="rtl"] .details-table th,
    .booking-page[dir="rtl"] .details-table td {
        text-align: right;
    }

    .details-table th,
    .details-table td {
        box-sizing: border-box;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .details-table td {
        background: var(--bd-soft);
        border-top: 1px solid var(--bd-line);
        border-bottom: 1px solid var(--bd-line);
        padding: 14px 12px;
        color: var(--bd-text);
        font-weight: 800;
        white-space: nowrap;
        vertical-align: middle;
    }

    .booking-page:not([dir="rtl"]) .details-table td:first-child {
        border-left: 1px solid var(--bd-line);
        border-radius: 18px 0 0 18px;
    }

    .booking-page:not([dir="rtl"]) .details-table td:last-child {
        border-right: 1px solid var(--bd-line);
        border-radius: 0 18px 18px 0;
    }

    .booking-page[dir="rtl"] .details-table td:first-child {
        border-right: 1px solid var(--bd-line);
        border-radius: 0 18px 18px 0;
    }

    .booking-page[dir="rtl"] .details-table td:last-child {
        border-left: 1px solid var(--bd-line);
        border-radius: 18px 0 0 18px;
    }


    .details-table .total-label {
        font-weight: 1000;
    }

    .booking-page:not([dir="rtl"]) .details-table .total-label {
        text-align: right;
    }

    .booking-page[dir="rtl"] .details-table .total-label {
        text-align: left;
    }

    .transport-card {
        background: var(--bd-soft);
        border: 1px solid var(--bd-line);
        border-radius: 28px;
        padding: 22px;
        margin-bottom: 20px;
        overflow-x: auto;
    }

    .transport-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .transport-title {
        font-size: 22px;
        color: var(--bd-text-strong);
        font-weight: 1000;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .transport-sub {
        color: var(--bd-muted);
        font-weight: 900;
        margin-top: 8px;
        line-height: 1.7;
    }

    .route-line {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .route-point {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 8px 14px;
        border-radius: 999px;
        background: var(--bd-card);
        border: 1px solid var(--bd-line);
        color: var(--bd-text);
        font-weight: 1000;
    }

    .route-arrow {
        display: inline-flex;
        width: 38px;
        height: 38px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        color: #fff;
        background: #ff7a18;
        font-weight: 1000;
    }

    .booking-page[dir="rtl"] .route-arrow {
        transform: scaleX(-1);
    }

    .trip-mini-summary {
        display: grid;
        grid-template-columns: repeat(4, minmax(150px, 1fr));
        gap: 12px;
        margin: 16px 0;
    }

    .trip-mini-card {
        background: var(--bd-card);
        border: 1px solid var(--bd-line);
        border-radius: 20px;
        padding: 14px;
    }

        .trip-mini-card small {
            display: block;
            color: var(--bd-muted);
            font-size: 12px;
            font-weight: 1000;
            margin-bottom: 7px;
        }

        .trip-mini-card strong {
            display: block;
            color: var(--bd-text-strong);
            font-size: 18px;
            font-weight: 1000;
        }

    .bus-shell {
        overflow: auto;
        padding: 20px;
        border-radius: 26px;
        border: 1px solid var(--bd-line);
        background: radial-gradient(circle at 20% 10%, rgba(255,122,24,.08), transparent 28%), var(--bd-busshell-bg);
    }

    .bus-stage {
        width: max-content;
        margin: auto;
        display: grid;
        justify-items: center;
        position: relative;
        padding: 0 45px;
        --bus-width: 420px;
        --cols: 5;
        --cell-size: 54px;
        --cell-gap: 7px;
    }

    .bus-nose {
        width: var(--bus-width);
        height: 76px;
        position: relative;
        border-radius: 54px 54px 18px 18px;
        background: linear-gradient(180deg, #ffb266 0%, #ff7a18 100%);
        border: 4px solid #ffcfaa;
        border-bottom: 0;
        box-shadow: inset 0 9px 0 rgba(255,255,255,.18), 0 16px 30px rgba(255,122,24,.14);
        z-index: 3;
    }

    .bus-windshield {
        position: absolute;
        left: 50%;
        top: 13px;
        transform: translateX(-50%);
        width: 62%;
        height: 34px;
        border-radius: 30px 30px 12px 12px;
        background: linear-gradient(135deg, #172033, #344054);
        box-shadow: inset 0 0 0 3px rgba(255,255,255,.18);
    }

    .bus-headlight {
        position: absolute;
        bottom: 12px;
        width: 28px;
        height: 15px;
        border-radius: 999px;
        background: #fff7d6;
    }

        .bus-headlight.left {
            left: 28px;
        }

        .bus-headlight.right {
            right: 28px;
        }

    .bus-body-wrap {
        position: relative;
        width: var(--bus-width);
    }

    .bus-body {
        width: var(--bus-width);
        padding: 18px;
        background: var(--bd-busshell-bg);
        border-left: 4px solid #ffcfaa;
        border-right: 4px solid #ffcfaa;
        border-bottom: 4px solid #ffcfaa;
        border-radius: 0 0 38px 38px;
        box-shadow: inset 0 0 0 8px var(--bd-soft3), 0 20px 38px rgba(255,122,24,.11);
        position: relative;
        z-index: 2;
    }

    .bus-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        padding: 0 18px;
        color: var(--bd-muted);
        font-size: 12px;
        font-weight: 1000;
        text-transform: uppercase;
    }

    .bus-grid {
        display: grid;
        gap: var(--cell-gap);
        grid-template-columns: repeat(var(--cols), var(--cell-size));
        width: max-content;
        margin: auto;
        padding: 12px;
        border-radius: 24px;
        background: var(--bd-busgrid-bg);
        border: 1px solid var(--bd-line);
    }

    .bus-cell {
        width: var(--cell-size);
        height: calc(var(--cell-size) * .82);
        border-radius: calc(var(--cell-size) * .22);
        border: 1px dashed var(--bd-buscell-border);
        background: var(--bd-buscell-bg);
        display: grid;
        place-items: center;
        user-select: none;
        font-weight: 1000;
        position: relative;
        font-size: 12px;
        color: var(--bd-text);
    }

        .bus-cell.empty::after {
            content: "";
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #ffd5b4;
        }

        .bus-cell.normal {
            background: linear-gradient(180deg, #ff9340, #ff6a00);
            color: #fff;
            border: none;
        }

        .bus-cell.vip {
            background: linear-gradient(180deg, #ffd166, #ff9f1c);
            color: #172033;
            border: none;
        }

        .bus-cell.driver {
            background: #172033;
            color: #fff;
            border: none;
        }

        .bus-cell.assistant {
            background: #7c3aed;
            color: #fff;
            border: none;
        }

        .bus-cell.road {
            background: repeating-linear-gradient(135deg, var(--bd-road-a), var(--bd-road-a) 8px, var(--bd-road-b) 8px, var(--bd-road-b) 16px);
            color: var(--bd-muted);
            border: 2px solid var(--bd-road-border);
        }

        .bus-cell.wc {
            background: #e8f3ff;
            color: #1570ef;
            border: 2px solid #84caff;
        }

        .bus-cell.door {
            background: transparent;
            border: 1px dashed var(--bd-buscell-border);
            color: transparent;
        }

        .bus-cell.disabled-seat {
            opacity: .35;
            filter: grayscale(.5);
        }

        .bus-cell.selected-booking {
            outline: 4px solid rgba(18,183,106,.55);
            box-shadow: 0 0 0 7px rgba(18,183,106,.12);
            transform: translateY(-1px);
        }

            .bus-cell.selected-booking::after {
                content: attr(data-booked-label);
                position: absolute;
                font-size: 9px;
                bottom: -16px;
                color: #16a34a;
                font-weight: 1000;
            }

    .selected-seat-list {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .seat-summary-groups {
        display: grid;
        grid-template-columns: repeat(2, minmax(260px, 1fr));
        gap: 14px;
        margin-top: 18px;
    }

    .seat-summary-card {
        background: var(--bd-card);
        border: 1px solid var(--bd-line);
        border-radius: 24px;
        padding: 18px;
        box-shadow: 0 10px 26px var(--bd-card-shadow);
    }

    .seat-summary-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .seat-summary-title {
        color: var(--bd-text-strong);
        font-size: 18px;
        font-weight: 1000;
        margin: 0;
    }

    .seat-location-box {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 10px;
        padding: 10px 14px;
        background: var(--bd-loc-bg);
        border: 1px solid var(--bd-loc-border);
        border-radius: 14px;
    }

    .seat-location-label {
        font-size: 11px;
        font-weight: 1000;
        color: var(--bd-loc-text);
        text-transform: uppercase;
        letter-spacing: .3px;
        margin-inline-end: 4px;
    }

    .seat-location-point {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        border-radius: 999px;
        background: var(--bd-loc-chip-bg);
        border: 1px solid var(--bd-loc-chip-border);
        color: var(--bd-loc-text);
        font-weight: 1000;
        font-size: 13px;
    }

    .seat-location-arrow {
        display: inline-flex;
        width: 26px;
        height: 26px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: #16a34a;
        color: #fff;
        font-size: 12px;
        font-weight: 1000;
    }

    .booking-page[dir="rtl"] .seat-location-arrow {
        transform: scaleX(-1);
    }

    .seat-chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
    }

    .seat-number-chip {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border-radius: 999px;
        background: var(--bd-loc-chip-bg);
        color: #067647;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 1000;
        border: 1px solid rgba(18,183,106,.22);
    }

    html[data-theme="dark"] .seat-number-chip {
        color: #6ee7b7;
    }

    .seat-summary-footer {
        display: grid;
        grid-template-columns: repeat(3, minmax(120px, 1fr));
        gap: 10px;
        margin-top: 16px;
    }

    .seat-summary-metric {
        background: var(--bd-soft);
        border: 1px solid var(--bd-line);
        border-radius: 18px;
        padding: 12px;
    }

        .seat-summary-metric small {
            display: block;
            color: var(--bd-muted);
            font-size: 12px;
            font-weight: 1000;
            margin-bottom: 6px;
        }

        .seat-summary-metric strong {
            color: var(--bd-text-strong);
            font-size: 17px;
            font-weight: 1000;
        }

    .seat-type-normal {
        color: #ff7a18;
    }

    .seat-type-vip {
        color: var(--bd-return-text);
    }

    .notes-box,
    .empty-box {
        background: var(--bd-soft);
        border: 1px solid var(--bd-line);
        border-radius: 22px;
        padding: 18px;
        color: var(--bd-text);
        font-weight: 800;
        line-height: 1.8;
    }

    .empty-box {
        text-align: center;
        color: var(--bd-faint);
        font-weight: 900;
        padding: 28px;
    }

    .summary-card-action {
        margin-top: 14px;
        width: 100%;
        min-height: 42px;
        border: 0;
        border-radius: 14px;
        background: #12b76a;
        color: #fff;
        font-weight: 1000;
        cursor: pointer;
        box-shadow: 0 12px 24px rgba(18,183,106,.22);
        transition: .2s ease;
    }

        .summary-card-action:hover {
            transform: translateY(-2px);
            background: #039855;
        }

    /* ── PAYMENT MODAL ── */
    .payment-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: none;
        place-items: center;
        padding: 18px;
        background: rgba(15,23,42,.58);
        backdrop-filter: blur(8px);
    }

        .payment-modal-overlay.show {
            display: grid;
        }

    .payment-modal {
        width: min(980px, 100%);
        border-radius: 30px;
        background: var(--bd-modal-bg);
        border: 1px solid var(--bd-line);
        box-shadow: 0 28px 90px rgba(15,23,42,.28);
