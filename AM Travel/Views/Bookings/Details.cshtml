        font-weight: 1000;
    }

    .payment-form-field input,
    .payment-form-field select {
        width: 100%;
        min-height: 56px;
        border: 1px solid var(--bd-line);
        border-radius: 16px;
        background: var(--bd-card);
        color: var(--bd-text);
        font-weight: 1000;
        padding: 0 16px;
