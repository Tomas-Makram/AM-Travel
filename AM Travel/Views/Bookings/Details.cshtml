    }

    /* ── USER MODAL ── */
    .booking-created-user-btn {
        border: 1px solid rgba(255,255,255,.42);
        background: rgba(255,255,255,.18);
        color: #fff;
        border-radius: 999px;
        padding: 5px 12px;
        font-weight: 1000;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
