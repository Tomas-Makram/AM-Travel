</style>

<div class="booking-page" dir="@(isRtl ? "rtl" : "ltr")">

    <section class="booking-hero">
        <div class="booking-hero-inner">
            <div class="booking-title">
                <span class="booking-badge">@L["BkDet_BookingWord"] @Model.Code</span>
                <h1>@Model.ClientName</h1>
                <p>
                    @bookingType · @L["BkDet_MainPhone"]: @mainPhone · @L["BkDet_CreatedBy"]:
                    @if (!string.IsNullOrWhiteSpace(Model.CreatedBy))
                    {
                        <button type="button" class="booking-created-user-btn" data-booking-id="@Model.BookingID" title="@L["BkDet_ViewUserContact"]">
                            @Model.CreatedBy
                        </button>
                    }
                    else { <span>-</span> }
                </p>
            </div>
            <div class="booking-avatar-wrap">
                <div class="booking-avatar">@userName</div>
                <span class="booking-avatar-status"></span>
            </div>
        </div>

        <div class="booking-actions">
            <a class="booking-btn btn-white" asp-action="Index"><span class="booking-btn-icon">←</span>@L["BkDet_BtnBack"]</a>
            <a class="booking-btn btn-report" asp-action="Report" asp-route-id="@Model.BookingID" target="_blank"><span class="booking-btn-icon">⎙</span>@L["BkDet_BtnReport"]</a>

            @if (Model.HasTransportation)
            {
                <a class="booking-btn btn-ticket" asp-action="Ticket" asp-route-id="@Model.BookingID" target="_blank"><span class="booking-btn-icon">🎟</span>@L["BkDet_BtnTicket"]</a>
            }

            <a class="booking-btn btn-audit" asp-action="Audit" asp-route-id="@Model.BookingID"><span class="booking-btn-icon">≡</span>@L["BkDet_BtnAudit"]</a>

            @if (User.IsInRole("Admin") || User.IsInRole("Helper"))
            {
                <a class="booking-btn btn-edit" asp-action="Edit" asp-route-id="@Model.BookingID"><span class="booking-btn-icon">✎</span>@L["BkDet_BtnEdit"]</a>
            }

            @if (User.IsInRole("Admin"))
            {
                <form class="delete-inline-form" asp-action="Delete" asp-route-id="@Model.BookingID" method="post" onsubmit="return confirm('@(L["BkDet_ConfirmDelete"].Value) @Model.Code?');">
                    @Html.AntiForgeryToken()
                    <button class="booking-btn btn-delete" type="submit"><span class="booking-btn-icon">🗑</span>@L["BkDet_BtnDelete"]</button>
                </form>
            }
        </div>
    </section>

    <section class="summary-grid">
        <div class="summary-card"><small>@L["BkDet_HotelTotal"]</small><strong>@Model.HotelTotal.ToString("N2")</strong></div>
        <div class="summary-card"><small>@L["BkDet_TransportTotal"]</small><strong>@Model.TransportationTotal.ToString("N2")</strong></div>
        <div class="summary-card"><small>@L["BkDet_GrandTotal"]</small><strong>@Model.GrandTotal.ToString("N2")</strong></div>
        <div class="summary-card">
            <small>@L["BkDet_Paid"]</small>
            <strong class="success">@Model.PaidAmount.ToString("N2")</strong>
            @if (User.IsInRole("Admin") || User.IsInRole("Helper"))
            {
                <button type="button" class="summary-card-action" onclick="openPaymentModal()">@L["BkDet_AddPaymentBtn"]</button>
            }
        </div>
        <div class="summary-card">
            <small>@L["BkDet_Remaining"]</small>
            <strong class="@(Model.RemainingAmount > 0 ? "danger" : "success")">@Model.RemainingAmount.ToString("N2")</strong>
        </div>
    </section>

    <section class="content-grid">

        <div class="details-card">
            <h3>@L["BkDet_ClientData"]</h3>
            <div class="info-list">
                <div class="info-row"><span class="info-label">@L["BkDet_Code"]</span><span class="info-value"><span class="pill code-pill">@Model.Code</span></span></div>
                <div class="info-row"><span class="info-label">@L["BkDet_ClientName"]</span><span class="info-value">@Model.ClientName</span></div>
                <div class="info-row"><span class="info-label">@L["BkDet_BookingType"]</span><span class="info-value"><span class="pill">@bookingType</span></span></div>
                <div class="info-row">
                    <span class="info-label">@L["BkDet_CreatedBy"]</span>
                    <span class="info-value">
                        @if (!string.IsNullOrWhiteSpace(Model.CreatedBy))
                        {
                            <button type="button" class="details-created-user-btn" data-booking-id="@Model.BookingID" title="@L["BkDet_ViewUserContact"]">
                                @Model.CreatedBy
                            </button>
                        }
                        else { <span>-</span> }
                    </span>
                </div>
                <div class="info-row"><span class="info-label">@L["BkDet_CreatedAt"]</span><span class="info-value">@Model.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</span></div>
            </div>
        </div>

        <div class="details-card">
            <h3>@L["BkDet_PhoneNumbers"]</h3>
            @if (Model.PhoneNumbers == null || !Model.PhoneNumbers.Any())
            {
                <div class="empty-box">@L["BkDet_NoPhones"]</div>
            }
            else
            {
                <div class="selected-seat-list">
                    @foreach (var phone in Model.PhoneNumbers)
                    {
                        <span class="pill @(phone.Prime ? "ok-pill" : "")">@phone.PhoneNumber @(phone.Prime ? $" - {L["BkDet_Primary"].Value}" : "")</span>
                    }
                </div>
            }
        </div>

        @if (Model.HasHotel)
        {
            <div class="details-card wide">
                <h3>@L["BkDet_HotelDetails"]</h3>
                <div class="info-list">
                    <div class="info-row"><span class="info-label">@L["BkDet_HotelName"]</span><span class="info-value">@Model.HotelName</span></div>
                    <div class="info-row"><span class="info-label">@L["BkDet_CheckIn"]</span><span class="info-value">@Model.CheckInDate.ToString("yyyy-MM-dd")</span></div>
                    <div class="info-row"><span class="info-label">@L["BkDet_CheckOut"]</span><span class="info-value">@Model.CheckOutDate.ToString("yyyy-MM-dd")</span></div>
                    <div class="info-row"><span class="info-label">@L["BkDet_Nights"]</span><span class="info-value">@Model.NightsCount</span></div>
                    <div class="info-row"><span class="info-label">@L["BkDet_Rooms"]</span><span class="info-value">@Model.NumberOfRooms - @Model.RoomTypeName</span></div>
                    <div class="info-row"><span class="info-label">@L["BkDet_Children"]</span><span class="info-value">@Model.TotalChildrenCount</span></div>
                </div>
            </div>

            @if (Model.Rooms != null && Model.Rooms.Any())
            {
                <div class="details-card wide">
                    <h3>@L["BkDet_RoomsBreakdown"]</h3>
                    <div class="table-wrap">
                        <table class="details-table">
                            <colgroup>
                                <col style="width:23%;" />
                                <col style="width:15%;" />
                                <col style="width:23%;" />
                                <col style="width:16%;" />
                                <col style="width:23%;" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>@L["BkDet_RoomType"]</th><th>@L["BkDet_Count"]</th><th>@L["BkDet_NightPrice"]</th><th>@L["BkDet_Nights"]</th><th>@L["BkDet_Total"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var room in Model.Rooms)
                                {
                                    var total = room.Count * room.NightPrice * Model.NightsCount;
                                    <tr>
                                        <td>@room.RoomType</td>
                                        <td>@room.Count</td>
                                        <td>@room.NightPrice.ToString("N2")</td>
                                        <td>@Model.NightsCount</td>
                                        <td><strong>@total.ToString("N2")</strong></td>
                                    </tr>
                                }
                                <tr>
                                    <td colspan="4" class="total-label">@L["BkDet_HotelTotal"]</td>
                                    <td><strong>@Model.HotelTotal.ToString("N2")</strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        @if (Model.HasTransportation)
        {
            <div class="details-card wide">
                <h3>@L["BkDet_TransportDetails"]</h3>

                @if (Model.TransportationTrips == null || !Model.TransportationTrips.Any())
                {
                    <div class="empty-box">@L["BkDet_NoTrips"]</div>
                }
                else
                {
                    foreach (var trip in Model.TransportationTrips)
                    {
                        var isReturn          = trip.Direction == TripDirection.Return;
                        var directionLabel    = isReturn ? L["BkDet_DirReturn"].Value : L["BkDet_DirGo"].Value;
                        var busDirectionLabel = isReturn ? L["BkDet_ReturnBus"].Value : L["BkDet_GoBus"].Value;
                        var directionClass    = isReturn ? "return-pill" : "go-pill";

                        var columns  = trip.LayoutColumns <= 0 ? 4 : trip.LayoutColumns;
                        var rows     = trip.LayoutRows    <= 0 ? 1 : trip.LayoutRows;
                        var cellSize = columns >= 8 ? 46 : columns >= 6 ? 50 : 54;
                        var gap      = columns >= 8 ? 5  : 7;
                        var busWidth = (columns * cellSize) + ((columns - 1) * gap) + 82;

                        var bookedSeatIds = trip.BookedSeats?
                            .Select(x => x.SeatId)
                            .ToHashSet() ?? new HashSet<Guid>();

                        var tripRouteFrom = string.IsNullOrWhiteSpace(trip.FromLocation) ? "-" : trip.FromLocation;
                        var tripRouteTo   = string.IsNullOrWhiteSpace(trip.ToLocation)   ? "-" : trip.ToLocation;

                        var seatGroups = (trip.BookedSeats ?? new List<BookingSeatDTO>())
                            .GroupBy(x => new
                            {
                                x.SeatType,
                                x.SeatPrice,
                                From = string.IsNullOrWhiteSpace(x.FromLocation) ? tripRouteFrom : x.FromLocation,
                                To = string.IsNullOrWhiteSpace(x.ToLocation) ? tripRouteTo : x.ToLocation,

                                x.IsTransferredToCompany,
                                x.TransferredToCompanyName,
                                x.TransferredToCompanyPhone
                            })
                            .Select(g => new
                            {
                                SeatType = g.Key.SeatType,
                                Count = g.Count(),
                                Labels = g.Select(x => string.IsNullOrWhiteSpace(x.SeatLabel)
                                                ? x.SeatNumber.ToString()
                                                : x.SeatLabel).ToList(),
                                Total = g.Sum(x => x.SeatPrice),
                                Price = g.Key.SeatPrice,
                                RouteFrom = g.Key.From,
                                RouteTo = g.Key.To,

                                IsTransferredToCompany = g.Key.IsTransferredToCompany,
                                TransferredToCompanyName = g.Key.TransferredToCompanyName,
                                TransferredToCompanyPhone = g.Key.TransferredToCompanyPhone
                            })
                            .OrderBy(x => x.IsTransferredToCompany)
                            .ThenBy(x => x.SeatType.ToString())
                            .ThenBy(x => x.Price)
                            .ToList();

                        <div class="transport-card">
                            <div class="transport-head">
                                <div>
                                    <div class="transport-title">
                                        <span class="pill @directionClass">@busDirectionLabel</span>
                                        <span>@trip.BusName</span>
                                        @if (!string.IsNullOrWhiteSpace(trip.PlateNumber))
                                        {
                                            <span>- @trip.PlateNumber</span>
                                        }
                                    </div>
                                    <div class="transport-sub">@L["BkDet_Date"]: @trip.TripDate.ToString("yyyy-MM-dd")</div>
                                    <div class="route-line">
                                        <span class="route-point">@tripRouteFrom</span>
                                        <span class="route-arrow">→</span>
                                        <span class="route-point">@tripRouteTo</span>
                                    </div>
                                </div>
                                <span class="pill ok-pill">@L["BkDet_Total"]: @trip.Total.ToString("N2")</span>
                            </div>

                            <div class="trip-mini-summary">
                                <div class="trip-mini-card"><small>@L["BkDet_Direction"]</small><strong>@directionLabel</strong></div>
                                <div class="trip-mini-card"><small>@L["BkDet_Bus"]</small><strong>@trip.BusName</strong></div>
                                <div class="trip-mini-card"><small>@L["BkDet_Plate"]</small><strong>@(string.IsNullOrWhiteSpace(trip.PlateNumber) ? "-" : trip.PlateNumber)</strong></div>
                                <div class="trip-mini-card"><small>@L["BkDet_BookedSeats"]</small><strong>@(trip.BookedSeats?.Count ?? 0)</strong></div>
                            </div>

                            <div class="bus-shell">
                                <div class="bus-stage" style="--cols:@columns;--cell-size:@(cellSize)px;--cell-gap:@(gap)px;--bus-width:@(busWidth)px;">
                                    <div class="bus-nose">
                                        <div class="bus-windshield"></div>
                                        <div class="bus-headlight left"></div>
                                        <div class="bus-headlight right"></div>
                                    </div>
                                    <div class="bus-body-wrap">
                                        <div class="bus-body">
                                            <div class="bus-meta">
                                                <span>@busDirectionLabel</span>
                                                <span>@rows x @columns</span>
                                            </div>
                                            <div class="bus-grid">
                                                @for (var r = 1; r <= rows; r++)
                                                {
                                                    for (var c = 1; c <= columns; c++)
                                                    {
                                                        var seat   = trip.BusSeats?.FirstOrDefault(x => x.RowNumber == r && x.ColumnNumber == c);
                                                        var booked = seat != null && bookedSeatIds.Contains(seat.SeatId);

                                                        if (seat == null)
                                                        {
                                                            <div class="bus-cell empty"></div>
                                                        }
                                                        else
                                                        {
                                                            var st = seat.SeatType.ToString().ToLower();
                                                            var seatClass =
                                                                st.Contains("vip")       ? "vip" :
                                                                st.Contains("driver")    ? "driver" :
                                                                st.Contains("assistant") ? "assistant" :
                                                                st.Contains("road") || st.Contains("aisle") ? "road" :
                                                                st.Contains("wc")   || st.Contains("bath")  ? "wc" :
                                                                st.Contains("door")      ? "door" : "normal";

                                                            <div class="bus-cell @seatClass @(booked ? "selected-booking" : "") @(!seat.IsActive ? "disabled-seat" : "")"
                                                                 data-booked-label="@L["BkDet_Booked"]"
                                                                 title="@seat.SeatLabel - @seat.SeatType">
                                                                @seat.SeatLabel
                                                            </div>
                                                        }
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        @if (seatGroups.Any())
                        {
                            <div class="seat-summary-groups">
                                @foreach (var group in seatGroups)
                                {
                                    var typeName  = group.SeatType.ToString();
                                    var typeClass = typeName.Equals("VIP", StringComparison.OrdinalIgnoreCase)
                                        ? "seat-type-vip" : "seat-type-normal";

                                    <div class="seat-summary-card">
                                        <div class="seat-summary-top">
                                            <h4 class="seat-summary-title @typeClass">@typeName @L["BkDet_SeatsWord"]</h4>
                                            <span class="pill @directionClass">@directionLabel</span>
                                        </div>

                                        <div class="seat-location-box">
                                            <span class="seat-location-label">📍 @L["BkDet_SeatRoute"]</span>
                                            <span class="seat-location-point">@group.RouteFrom</span>
                                            <span class="seat-location-arrow">→</span>
                                            <span class="seat-location-point">@group.RouteTo</span>
                                        </div>

                                        <div class="seat-chip-list">
                                            @foreach (var label in group.Labels)
                                            {
                                                <span class="seat-number-chip">@label</span>
                                            }
                                        </div>
                                            @if (group.IsTransferredToCompany)
                                            {
                                                <div class="mt-2" style="margin-top:14px;padding:12px 14px;border-radius:16px;background:#fef3c7;border:1px solid #fde68a;">
                                                    <span class="pill" style="background:#fff7ed;color:#92400e;">
                                                        تم تحويلها لشركة أخرى
                                                    </span>

                                                    <div style="margin-top:8px;font-weight:900;color:var(--bd-muted);">
                                                        الشركة:
                                                        <span style="color:var(--bd-text-strong);">
                                                            @(group.TransferredToCompanyName ?? "-")
                                                        </span>
                                                    </div>

                                                    <div style="margin-top:4px;font-weight:900;color:var(--bd-muted);">
                                                        رقم الشركة:
                                                        <span style="color:var(--bd-text-strong);direction:ltr;display:inline-block;">
                                                            @(group.TransferredToCompanyPhone ?? "-")
                                                        </span>
                                                    </div>
                                                </div>
                                            }
                                        <div class="seat-summary-footer">
                                            <div class="seat-summary-metric">
                                                <small>@L["BkDet_Count"]</small>
                                                <strong>@group.Count</strong>
                                            </div>
                                            <div class="seat-summary-metric">
                                                <small>@L["BkDet_PricePerSeat"]</small>
                                                <strong>@group.Price.ToString("N2")</strong>
                                            </div>
                                            <div class="seat-summary-metric">
                                                <small>@L["BkDet_Total"]</small>
                                                <strong>@group.Total.ToString("N2")</strong>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-box" style="margin-top:16px;">@L["BkDet_NoSeats"]</div>
                        }
                        </div>
                    }

                    <div class="summary-grid" style="margin-top:18px;">
                        <div class="summary-card">
                            <small>@L["BkDet_TransportTotal"]</small>
                            <strong>@Model.TransportationTotal.ToString("N2")</strong>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="details-card wide">
            <h3>@L["BkDet_Payments"]</h3>
            @if (Model.Payments == null || !Model.Payments.Any())
            {
                <div class="empty-box">@L["BkDet_NoPayments"]</div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="details-table">
                        <colgroup>
                            <col style="width:31%;" />
                            <col style="width:27%;" />
                            <col style="width:23%;" />
                            <col style="width:19%;" />
                        </colgroup>
                        <thead>
                            <tr><th>@L["BkDet_Date"]</th><th>@L["BkDet_PayType"]</th><th>@L["BkDet_Amount"]</th><th>@L["BkDet_NotesCol"]</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model.Payments)
                            {
                                <tr>
                                    <td>@payment.PaidAt.ToString("yyyy-MM-dd")</td>
                                    <td>@Html.DisplayFor(x => payment.PayType)</td>
                                    <td><strong>@payment.Amount.ToString("N2")</strong></td>
                                    <td>@(string.IsNullOrWhiteSpace(payment.Notes) ? "-" : payment.Notes)</td>
                                </tr>
                            }
                            <tr>
                                <td colspan="2" class="total-label">@L["BkDet_PaidTotal"]</td>
                                <td><strong>@Model.PaidAmount.ToString("N2")</strong></td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="details-card wide">
                <h3>@L["BkDet_Notes"]</h3>
                <div class="notes-box">@Model.Notes</div>
            </div>
        }

    </section>
</div>

<!-- USER MODAL -->
<div id="bookingUserModal" class="user-modal-overlay" onclick="closeBookingUserModal(event)">
    <div class="user-modal" onclick="event.stopPropagation()">
        <div class="user-modal-head">
            <button type="button" class="user-modal-close" onclick="hideBookingUserModal()">×</button>
            <h3 class="user-modal-title">@L["BkDet_ModalTitle"]</h3>
            <div class="user-modal-subtitle">@L["BkDet_ModalSubtitle"]</div>
        </div>
        <div class="user-modal-body">
            <div id="bookingUserLoading" class="user-modal-loading">@L["BkDet_ModalLoading"]</div>
            <div id="bookingUserError"   class="user-modal-error"   style="display:none;"></div>
            <div id="bookingUserContent"                             style="display:none;">
                <div class="user-info-row"><small>@L["BkDet_ModalUserName"]</small><strong id="bookingUserFullName">-</strong></div>
                <div class="user-info-row"><small>@L["BkDet_ModalPhone"]</small><strong id="bookingUserPhone">-</strong></div>
            </div>
        </div>
    </div>
</div>

<!-- PAYMENT MODAL -->
@if (User.IsInRole("Admin") || User.IsInRole("Helper"))
{
    <div id="paymentModalOverlay" class="payment-modal-overlay" onclick="closePaymentModal(event)">
        <div class="payment-modal" onclick="event.stopPropagation()">
            <form asp-action="AddPayment" asp-route-id="@Model.BookingID" method="post">
                @Html.AntiForgeryToken()
                <div class="payment-modal-head">
                    <div>
                        <h3 class="payment-modal-title">@L["BkDet_AddPaymentTitle"]</h3>
                        <div class="payment-modal-subtitle">@L["BkDet_BookingWord"] @Model.Code · @L["BkDet_Remaining"]: @Model.RemainingAmount.ToString("N2")</div>
                    </div>
                    <button type="button" class="payment-modal-close" onclick="hidePaymentModal()">×</button>
                </div>
                <div class="payment-modal-body">
                    <input type="hidden" name="BookingId" value="@Model.BookingID" />
                    <div class="payment-form-grid">
                        <div class="payment-form-field">
                            <label>@L["BkDet_Amount"]</label>
                            <input name="Amount" type="number" min="1"
                                   max="@Model.RemainingAmount.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                   step="0.01" value="0" required />
                        </div>
                        <div class="payment-form-field">
                            <label>@L["BkDet_PayType"]</label>
                            <select name="PayType" required asp-items="Html.GetEnumSelectList<PayType>()">
                            </select>
                        </div>
                        <div class="payment-form-field">
                            <label>@L["BkDet_PaidAt"]</label>
                            <input name="PaidAt" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="payment-form-field">
                            <label>@L["BkDet_NotesCol"]</label>
                            <input name="Notes" placeholder="@L["BkDet_PaymentNotesPH"]" maxlength="500" />
                        </div>
                    </div>
                </div>
                <div class="payment-modal-actions">
                    <button type="button" class="payment-modal-btn payment-modal-cancel" onclick="hidePaymentModal()">@L["BkDet_Cancel"]</button>
                    <button type="submit" class="payment-modal-btn payment-modal-submit">@L["BkDet_SavePayment"]</button>
                </div>
            </form>
        </div>
    </div>
}

<script>
    const BkDet_I18N = {
        loadFailed:   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["BkDet_JsLoadFailed"].Value)),
        connectFailed:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["BkDet_JsConnectFailed"].Value))
    };

    function showBookingUserModal() { document.getElementById("bookingUserModal")?.classList.add("show"); }
    function hideBookingUserModal() { document.getElementById("bookingUserModal")?.classList.remove("show"); }
    function closeBookingUserModal(e) { if (e.target?.id === "bookingUserModal") hideBookingUserModal(); }

    function setBookingUserModalLoading() {
        document.getElementById("bookingUserLoading").style.display = "";
        document.getElementById("bookingUserError").style.display   = "none";
        document.getElementById("bookingUserContent").style.display = "none";
    }

    function setBookingUserModalError(msg) {
        document.getElementById("bookingUserLoading").style.display = "none";
        document.getElementById("bookingUserContent").style.display = "none";
        const e = document.getElementById("bookingUserError");
        e.innerText = msg || BkDet_I18N.loadFailed;
        e.style.display = "";
    }

    function setBookingUserModalContent(data) {
        document.getElementById("bookingUserLoading").style.display = "none";
        document.getElementById("bookingUserError").style.display   = "none";
        document.getElementById("bookingUserContent").style.display = "";
        document.getElementById("bookingUserFullName").innerText = data.fullName    || "-";
        document.getElementById("bookingUserPhone").innerText    = data.phoneNumber || "-";
    }

    async function loadBookingUserInfo(bookingId) {
        setBookingUserModalLoading();
        showBookingUserModal();
        try {
            const url  = '@Url.Action("BookingUserInfo", "Bookings")' + '?bookingId=' + encodeURIComponent(bookingId);
            const resp = await fetch(url, { method: "GET", headers: { "X-Requested-With": "XMLHttpRequest" } });
            const data = await resp.json();
            if (!resp.ok || !data.success) { setBookingUserModalError(data.message || BkDet_I18N.loadFailed); return; }
            setBookingUserModalContent(data.data);
        } catch { setBookingUserModalError(BkDet_I18N.connectFailed); }
    }

    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".booking-created-user-btn, .details-created-user-btn").forEach(function (btn) {
            btn.addEventListener("click", function (e) {
                e.preventDefault(); e.stopPropagation();
                const id = btn.getAttribute("data-booking-id");
                if (id) loadBookingUserInfo(id);
            });
        });
    });

    function openPaymentModal()  { document.getElementById("paymentModalOverlay")?.classList.add("show"); }
    function hidePaymentModal()  { document.getElementById("paymentModalOverlay")?.classList.remove("show"); }
    function closePaymentModal(e){ if (e.target?.id === "paymentModalOverlay") hidePaymentModal(); }

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") { hidePaymentModal(); hideBookingUserModal(); }
    });
</script>
