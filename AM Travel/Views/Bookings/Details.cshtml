    }

    .payment-modal-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        padding: 22px 24px;
        color: #fff;
        background: var(--bd-hero-bg);
    }

    .payment-modal-title {
        margin: 0;
        font-size: 26px;
