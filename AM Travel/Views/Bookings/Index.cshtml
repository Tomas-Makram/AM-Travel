@using AM_Travel.Resources
@using Microsoft.Extensions.Localization
@model List<BusinessLayer.DTOs.Book.BookingListItemDTO>
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["BkList_Title"];

    var today = DateTime.Today;

    var totalBookings = Model?.Count ?? 0;
    var todayBookings = Model?.Count(x => x.CheckInDate.Date == today || x.CreatedAtUtc.Date == today) ?? 0;
    var activeBookings = Model?.Count(x => x.CheckInDate.Date <= today && x.CheckOutDate.Date >= today) ?? 0;

    string fullName = Convert.ToString(ViewBag.Name) ?? "Admin Administrator";
    var cleanName = fullName.Trim().Replace("  ", " ");

    var userName = string.Join("", cleanName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(userName))
    {
        userName = "AA";
    }

    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}

<style>
    :root {
        --bk-hero-bg: linear-gradient(135deg,#ff7a18,#ffad42);
        --bk-hero-glow: rgba(255,122,24,.18);
        --bk-hero-text: #fff;
        --bk-hero-sub: rgba(255,255,255,.92);
        --bk-glass: rgba(255,255,255,.16);
        --bk-card: #fff;
        --bk-card-border: #f0d8c2;
        --bk-card-shadow: rgba(255,122,24,.10);
        --bk-card-shadow-soft: rgba(255,122,24,.09);
        --bk-text: #172033;
        --bk-text-strong: #172033;
        --bk-muted: #667085;
        --bk-faint: #98a2b3;
        --bk-line: #f0d8c2;
        --bk-soft: #fffaf5;
        --bk-soft-line: #f3dfcc;
        --bk-input-bg: #fff;
        --bk-input-border: #f3dfcc;
        --bk-input-text: #172033;
        --bk-orange: #ff7a18;
        --bk-danger: #dc2626;
        --bk-success: #16a34a;
        --bk-pill-bg: #fff3e6;
        --bk-code-bg: #eff6ff;
        --bk-code-text: #2563eb;
        --bk-row-red-bg: #fff1f1;
        --bk-row-yellow-bg: #fef9ec;
        --bk-row-green-bg: #ecfdf5;
        --bk-scroll-track: #fff3e6;
    }

    html[data-theme="dark"] {
        --bk-hero-bg: linear-gradient(135deg,#c45c0a,#d97c2a);
        --bk-hero-glow: rgba(196,92,10,.22);
        --bk-hero-text: #f5f0eb;
        --bk-hero-sub: rgba(245,240,235,.85);
        --bk-glass: rgba(255,255,255,.12);
        --bk-card: #1a2236;
        --bk-card-border: #283148;
        --bk-card-shadow: rgba(0,0,0,.35);
        --bk-card-shadow-soft: rgba(0,0,0,.30);
        --bk-text: #dce3ed;
        --bk-text-strong: #f5f7fa;
        --bk-muted: #7a8ba0;
        --bk-faint: #6b7488;
        --bk-line: #283148;
        --bk-soft: #212c3f;
        --bk-soft-line: #3a4d66;
        --bk-input-bg: #212c3f;
        --bk-input-border: #3a4d66;
        --bk-input-text: #dce3ed;
        --bk-danger: #f87171;
        --bk-success: #34d399;
        --bk-pill-bg: #3a2b18;
        --bk-code-bg: #1e2a44;
        --bk-code-text: #7aa7ff;
        --bk-row-red-bg: #3a2226;
        --bk-row-yellow-bg: #3a3320;
        --bk-row-green-bg: #1f3329;
        --bk-scroll-track: #283148;
    }

    .booking-page {
        display: grid;
        gap: 20px;
        color: var(--bk-text);
    }

    .booking-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--bk-hero-text);
        background: var(--bk-hero-bg);
        box-shadow: 0 24px 70px var(--bk-hero-glow);
    }

        .booking-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 12% 15%,rgba(255,255,255,.22),transparent 26%);
            pointer-events: none;
        }

        .booking-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            right: -90px;
            bottom: -110px;
            border-radius: 50%;
            background: rgba(255,255,255,.16);
            pointer-events: none;
        }

    .booking-page[dir="rtl"] .booking-hero::after {
        right: auto;
        left: -90px;
    }

    .booking-hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .booking-title {
        display: grid;
        gap: 10px;
    }

    .booking-badge {
        width: fit-content;
        padding: 8px 18px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--bk-hero-text);
    }

    .booking-title h1 {
        margin: 0;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--bk-hero-text);
    }

    .booking-title p {
        margin: 0;
        color: var(--bk-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    .booking-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.10);
        flex-shrink: 0;
    }

        .booking-avatar-wrap::before {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid rgba(255,255,255,.22);
        }

        .booking-avatar-wrap::after {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid transparent;
            border-top-color: #fff;
            border-right-color: rgba(255,255,255,.72);
            animation: booking-avatar-spin 4s linear infinite;
        }

    .booking-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)), linear-gradient(135deg, #ffffff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .booking-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
        box-shadow: 0 8px 18px rgba(18,183,106,.35);
    }

    .booking-page[dir="rtl"] .booking-avatar-status {
        right: auto;
        left: 13px;
    }

    @@keyframes booking-avatar-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .booking-actions {
        position: relative;
        z-index: 2;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .booking-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
        border: 0;
        cursor: pointer;
    }

        .booking-btn:hover {
            transform: translateY(-2px);
        }

    .btn-white {
        background: #fff;
        color: #ff7a18;
        box-shadow: 0 14px 30px rgba(0,0,0,.12);
    }

    .btn-glass {
        background: var(--bk-glass);
        color: var(--bk-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    .summary-card {
        background: var(--bk-card);
        border: 1px solid var(--bk-card-border);
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 16px 38px var(--bk-card-shadow-soft);
        transition: background .3s,border-color .3s;
    }

        .summary-card small {
            display: block;
            margin-bottom: 8px;
            color: var(--bk-muted);
            font-weight: 900;
            transition: color .3s;
        }

        .summary-card strong {
            display: block;
            color: var(--bk-text-strong);
            font-size: 28px;
            transition: color .3s;
        }

    .filter-card,
    .booking-table-card {
        background: var(--bk-card);
        border: 1px solid var(--bk-card-border);
        border-radius: 30px;
        padding: 24px;
        box-shadow: 0 18px 42px var(--bk-card-shadow);
        transition: background .3s,border-color .3s;
    }

    .booking-filter {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-group {
        display: grid;
        gap: 7px;
    }

        .form-group label {
            color: var(--bk-muted);
            font-size: 13px;
            font-weight: 900;
            transition: color .3s;
        }

        .form-group input,
        .form-group select {
            min-height: 46px;
            border-radius: 16px;
            border: 1px solid var(--bk-input-border);
            padding: 0 14px;
            outline: none;
            font-weight: 800;
            background: var(--bk-input-bg);
            color: var(--bk-input-text);
            width: 100%;
            box-sizing: border-box;
            transition: border-color .2s,background .3s,color .3s;
        }

            .form-group input:focus,
            .form-group select:focus {
                border-color: #ff7a18;
                box-shadow: 0 0 0 4px rgba(255,122,24,.12);
            }

        .form-group select option {
            background: #fff;
            color: #172033;
        }

    html[data-theme="dark"] .form-group select option {
        background: #212c3f;
        color: #dce3ed;
    }

    .orange-btn {
        min-height: 46px;
        padding: 0 18px;
        border-radius: 16px;
        border: none;
        background: #ff7a18;
        color: #fff;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .light-btn {
        min-height: 46px;
        padding: 0 18px;
        border-radius: 16px;
        border: 1px solid var(--bk-input-border);
        background: var(--bk-soft);
        color: #ff7a18;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* ===== TABLE + HORIZONTAL SCROLL ===== */
    .booking-table-wrap {
        width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 6px;
        scrollbar-width: thin;
        scrollbar-color: var(--bk-orange) var(--bk-scroll-track);
        -webkit-overflow-scrolling: touch;
    }

        .booking-table-wrap::-webkit-scrollbar {
            height: 12px;
        }

        .booking-table-wrap::-webkit-scrollbar-track {
            background: var(--bk-scroll-track);
            border-radius: 999px;
        }

        .booking-table-wrap::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg,#ff7a18,#ffad42);
            border-radius: 999px;
            border: 3px solid var(--bk-scroll-track);
        }

    .booking-table {
        width: 100%;
        min-width: 980px;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .booking-table th {
            color: var(--bk-muted);
            font-size: 13px;
            padding: 0 12px;
            white-space: nowrap;
            transition: color .3s;
        }

        .booking-table td {
            background: var(--bk-soft);
            border-top: 1px solid var(--bk-soft-line);
            border-bottom: 1px solid var(--bk-soft-line);
            padding: 14px 12px;
            color: var(--bk-text);
            font-weight: 800;
            vertical-align: top;
            white-space: nowrap;
        }

    /* LTR alignment + corners */
    .booking-page:not([dir="rtl"]) .booking-table th {
        text-align: left;
    }

    .booking-page:not([dir="rtl"]) .booking-table td:first-child {
        border-left: 1px solid var(--bk-soft-line);
        border-radius: 18px 0 0 18px;
    }

    .booking-page:not([dir="rtl"]) .booking-table td:last-child {
        border-right: 1px solid var(--bk-soft-line);
        border-radius: 0 18px 18px 0;
    }

    /* RTL alignment + corners */
    .booking-page[dir="rtl"] .booking-table th {
        text-align: right;
    }

    .booking-page[dir="rtl"] .booking-table td:first-child {
        border-right: 1px solid var(--bk-soft-line);
        border-left: 0;
        border-radius: 0 18px 18px 0;
    }

    .booking-page[dir="rtl"] .booking-table td:last-child {
        border-left: 1px solid var(--bk-soft-line);
        border-right: 0;
        border-radius: 18px 0 0 18px;
    }

    .booking-row {
        cursor: pointer;
    }

        .booking-row:hover td {
            filter: brightness(.98);
        }

    html[data-theme="dark"] .booking-row:hover td {
        filter: brightness(1.18);
    }

    .row-red td {
        background: var(--bk-row-red-bg) !important;
    }

    .row-yellow td {
        background: var(--bk-row-yellow-bg) !important;
    }

    .row-green td {
        background: var(--bk-row-green-bg) !important;
    }

    /* LTR colored edge */
    .booking-page:not([dir="rtl"]) .row-red td:first-child {
        border-left: 5px solid #dc2626;
    }

    .booking-page:not([dir="rtl"]) .row-yellow td:first-child {
        border-left: 5px solid #f59e0b;
    }

    .booking-page:not([dir="rtl"]) .row-green td:first-child {
        border-left: 5px solid #16a34a;
    }

    /* RTL colored edge */
    .booking-page[dir="rtl"] .row-red td:first-child {
        border-right: 5px solid #dc2626;
    }

    .booking-page[dir="rtl"] .row-yellow td:first-child {
        border-right: 5px solid #f59e0b;
    }

    .booking-page[dir="rtl"] .row-green td:first-child {
        border-right: 5px solid #16a34a;
    }

    .scroll-hint {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
        padding: 9px 14px;
        border-radius: 14px;
        background: var(--bk-pill-bg);
        color: #ff7a18;
        font-size: 12.5px;
        font-weight: 900;
        width: fit-content;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
        color: #ff7a18;
        background: var(--bk-pill-bg);
        white-space: nowrap;
    }

    .code-pill {
        color: var(--bk-code-text);
        background: var(--bk-code-bg);
        font-family: monospace;
    }

    .paid {
        color: var(--bk-success);
        font-weight: 1000;
    }

    .remaining {
        color: var(--bk-danger);
        font-weight: 1000;
    }

    .empty-box {
        padding: 30px;
        text-align: center;
        color: var(--bk-faint);
        font-weight: 900;
    }

    .alert-error-box {
        padding: 14px 18px;
        border-radius: 18px;
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        font-weight: 900;
    }

    .booking-user-btn {
        min-height: 34px;
        padding: 7px 12px;
        border: 1px solid rgba(255,122,24,.32);
        border-radius: 999px;
        background: var(--bk-pill-bg);
        color: #ff7a18;
        font-weight: 1000;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        box-shadow: 0 8px 18px rgba(255,122,24,.10);
        transition: .2s ease;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

        .booking-user-btn:hover {
            transform: translateY(-2px);
            background: #ff7a18;
            color: #fff;
            box-shadow: 0 12px 24px rgba(255,122,24,.22);
        }

        .booking-user-btn::before {
            content: "👤";
            font-size: 13px;
        }

    .booking-user-hint {
        display: block;
        margin-top: 6px;
        color: var(--bk-faint);
        font-size: 11px;
        font-weight: 900;
    }

    .user-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: none;
        place-items: center;
        padding: 18px;
        background: rgba(15,23,42,.58);
        backdrop-filter: blur(8px);
    }

        .user-modal-overlay.show {
            display: grid;
        }

    .user-modal {
        width: min(480px, 100%);
        overflow: hidden;
        border-radius: 30px;
        background: var(--bk-card);
        border: 1px solid var(--bk-card-border);
        box-shadow: 0 28px 90px rgba(15,23,42,.25);
    }

    .user-modal-head {
        position: relative;
        overflow: hidden;
        padding: 24px;
        color: #fff;
        background: var(--bk-hero-bg);
    }

        .user-modal-head::after {
            content: "";
            position: absolute;
            width: 150px;
            height: 150px;
            right: -48px;
            bottom: -70px;
            border-radius: 50%;
            background: rgba(255,255,255,.16);
        }

    .user-modal-title {
        position: relative;
        z-index: 1;
        margin: 0;
        font-size: 26px;
        font-weight: 1000;
    }

    .user-modal-subtitle {
        position: relative;
        z-index: 1;
        margin-top: 7px;
        color: rgba(255,255,255,.92);
        font-weight: 800;
    }

    .user-modal-close {
        position: absolute;
        top: 16px;
        right: 16px;
        z-index: 2;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,.30);
        background: rgba(255,255,255,.18);
        color: #fff;
        font-size: 24px;
        font-weight: 1000;
        cursor: pointer;
    }

    .booking-page[dir="rtl"] .user-modal-close {
        right: auto;
        left: 16px;
    }

    .user-modal-body {
        padding: 22px;
        display: grid;
        gap: 12px;
    }

    .user-info-row {
        padding: 16px;
        border-radius: 20px;
        background: var(--bk-soft);
        border: 1px solid var(--bk-soft-line);
    }

        .user-info-row small {
            display: block;
            margin-bottom: 7px;
            color: var(--bk-muted);
            font-size: 12px;
            font-weight: 1000;
        }

        .user-info-row strong {
            display: block;
            color: var(--bk-text-strong);
            font-size: 18px;
            font-weight: 1000;
            word-break: break-word;
        }

    .user-modal-loading,
    .user-modal-error {
        padding: 16px;
        border-radius: 18px;
        font-weight: 1000;
    }

    .user-modal-loading {
        background: #fff7ed;
        color: #ff7a18;
    }

    .user-modal-error {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    @@media (max-width: 1300px) {
        .booking-filter {
            grid-template-columns: 1fr 1fr 1fr;
        }
    }

    @@media (max-width: 800px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }

        .booking-filter {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="booking-page" dir="@(isRtl ? "rtl" : "ltr")">

    <section class="booking-hero">
        <div class="booking-hero-inner">
            <div class="booking-title">
                <span class="booking-badge">@L["BkList_Badge"]</span>
                <h1>@L["BkList_Title"]</h1>
                <p>@L["BkList_Subtitle"]</p>
            </div>

            <div class="booking-avatar-wrap">
                <div class="booking-avatar">@userName</div>
                <span class="booking-avatar-status"></span>
            </div>
        </div>

        <div class="booking-actions">
            @if (User.IsInRole("Admin") || User.IsInRole("Helper"))
            {
                <a class="booking-btn btn-white" asp-action="Create">@L["BkList_NewBooking"]</a>
            }

            <a class="booking-btn btn-glass" asp-action="DailyWork">@L["BkList_TodayBookings"]</a>
            <a class="booking-btn btn-glass" asp-controller="Dashboard" asp-action="Index">@L["BkList_Dashboard"]</a>
        </div>
    </section>

    @if (TempData["Error"] != null)
    {
        <div class="alert-error-box">@TempData["Error"]</div>
    }

    <section class="summary-grid">
        <div class="summary-card">
            <small>@L["BkList_TotalBookings"]</small>
            <strong>@totalBookings</strong>
        </div>

        <div class="summary-card">
            <small>@L["BkList_TodayBookings"]</small>
            <strong>@todayBookings</strong>
        </div>

        <div class="summary-card">
            <small>@L["BkList_ActiveBookings"]</small>
            <strong>@activeBookings</strong>
        </div>
    </section>

    <section class="filter-card">
        <form method="get" asp-action="Index" class="booking-filter">
            <div class="form-group">
                <label>@L["BkList_FilterSearch"]</label>
                <input name="search" value="@ViewBag.Search" placeholder="@L["BkList_FilterSearchPH"]" />
            </div>

            <div class="form-group">
                <label>@L["BkList_FilterCheckIn"]</label>
                <input type="date" name="checkInDate" value="@ViewBag.CheckInDate" />
            </div>

            <div class="form-group">
                <label>@L["BkList_FilterCheckOut"]</label>
                <input type="date" name="checkOutDate" value="@ViewBag.CheckOutDate" />
            </div>

            <div class="form-group">
                <label>@L["BkList_FilterType"]</label>
                <select name="bookingType">
                    <option value="">@L["BkList_FilterAllTypes"]</option>
                    <option value="hotel" selected="@(ViewBag.BookingType == "hotel")">@L["BkList_FilterHotelOnly"]</option>
                    <option value="transport" selected="@(ViewBag.BookingType == "transport")">@L["BkList_FilterTransportOnly"]</option>
                    <option value="both" selected="@(ViewBag.BookingType == "both")">@L["BkList_FilterBoth"]</option>
                </select>
            </div>

            <button class="orange-btn" type="submit">@L["BkList_FilterSearchBtn"]</button>
            <a class="light-btn" asp-action="Index">@L["BkList_FilterReset"]</a>
        </form>
    </section>

    <section class="booking-table-card">
        <div class="scroll-hint" id="scrollHint">
            <span>↔️</span>
            <span>@L["BkList_ScrollHint"]</span>
        </div>

        <div class="booking-table-wrap">
            <table class="booking-table">
                <thead>
                    <tr>
                        <th>@L["BkList_ColCode"]</th>
                        <th>@L["BkList_ColClient"]</th>
                        <th>@L["BkList_ColPhone"]</th>
                        <th>@L["BkList_ColType"]</th>
                        <th>@L["BkList_ColHotel"]</th>
                        <th>@L["BkList_ColCheckIn"]</th>
                        <th>@L["BkList_ColCheckOut"]</th>
                        <th>@L["BkList_ColPaid"]</th>
                        <th>@L["BkList_ColRemaining"]</th>
                        <th>@L["BkList_ColUser"]</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="11">
                                <div class="empty-box">@L["BkList_Empty"]</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var bookingTypeText =
                                item.HasHotel && item.HasTransportation ? L["BkList_TypeHT"].Value :
                                item.HasHotel ? L["BkList_TypeHotel"].Value :
                                item.HasTransportation ? L["BkList_TypeTransport"].Value :
                                L["BkList_TypeNA"].Value;

                            var daysToCheckIn = (item.CheckInDate.Date - today).Days;

                            string rowClass;

                            if (item.CheckOutDate.Date < today)
                            {
                                rowClass = "row-red";
                            }
                            else if (item.CheckInDate.Date == today || daysToCheckIn == 1)
                            {
                                rowClass = "row-green";
                            }
                            else
                            {
                                rowClass = "row-yellow";
                            }

                            <tr class="booking-row @rowClass"
                                data-url="@Url.Action("Details", "Bookings", new { id = item.BookingID })"
                                title="@L["BkList_RowTitle"]">

                                <td>
                                    <span class="pill code-pill">@item.Code</span>
                                </td>

                                <td>@item.ClientName</td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.PhoneNumbersText) ? "-" : item.PhoneNumbersText)
                                </td>

                                <td>
                                    <span class="pill">@bookingTypeText</span>
                                </td>

                                <td>
                                    @(item.HasHotel ? item.HotelName : "-")
                                </td>

                                <td>
                                    @(item.HasHotel ? item.CheckInDate.ToString("yyyy-MM-dd") : "-")
                                </td>

                                <td>
                                    @(item.HasHotel ? item.CheckOutDate.ToString("yyyy-MM-dd") : "-")
                                </td>

                                <td>
                                    <span class="paid">@item.PaidAmount.ToString("N2")</span>
                                </td>

                                <td>
                                    @if (item.RemainingAmount > 0)
                                    {
                                        <span class="remaining">@item.RemainingAmount.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="paid">0.00</span>
                                    }
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.CreatedBy))
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="booking-user-btn"
                                                data-booking-id="@item.BookingID"
                                                title="@L["BkList_UserBtnTitle"]">
                                            @item.CreatedBy
                                        </button>
                                        <span class="booking-user-hint">@L["BkList_UserHint"]</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>

<div id="bookingUserModal" class="user-modal-overlay" onclick="closeBookingUserModal(event)">
    <div class="user-modal" onclick="event.stopPropagation()">
        <div class="user-modal-head">
            <button type="button" class="user-modal-close" onclick="hideBookingUserModal()">×</button>
            <h3 class="user-modal-title">@L["BkList_ModalTitle"]</h3>
            <div class="user-modal-subtitle">@L["BkList_ModalSubtitle"]</div>
        </div>

        <div class="user-modal-body">
            <div id="bookingUserLoading" class="user-modal-loading">@L["BkList_ModalLoading"]</div>
            <div id="bookingUserError" class="user-modal-error" style="display:none;"></div>

            <div id="bookingUserContent" style="display:none;">
                <div class="user-info-row">
                    <small>@L["BkList_ModalUserName"]</small>
                    <strong id="bookingUserFullName">-</strong>
                </div>

                <div class="user-info-row">
                    <small>@L["BkList_ModalPhone"]</small>
                    <strong id="bookingUserPhone">-</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showBookingUserModal() {
            document.getElementById("bookingUserModal")?.classList.add("show");
        }

        function hideBookingUserModal() {
            document.getElementById("bookingUserModal")?.classList.remove("show");
        }

        function closeBookingUserModal(event) {
            if (event.target && event.target.id === "bookingUserModal") {
                hideBookingUserModal();
            }
        }

        function setBookingUserModalLoading() {
            document.getElementById("bookingUserLoading").style.display = "";
            document.getElementById("bookingUserError").style.display = "none";
            document.getElementById("bookingUserContent").style.display = "none";
            document.getElementById("bookingUserFullName").innerText = "-";
            document.getElementById("bookingUserPhone").innerText = "-";
        }

        function setBookingUserModalError(message) {
            document.getElementById("bookingUserLoading").style.display = "none";
            document.getElementById("bookingUserContent").style.display = "none";

            const errorBox = document.getElementById("bookingUserError");
            errorBox.innerText = message || "Failed to load user information.";
            errorBox.style.display = "";
        }

        function setBookingUserModalContent(data) {
            document.getElementById("bookingUserLoading").style.display = "none";
            document.getElementById("bookingUserError").style.display = "none";
            document.getElementById("bookingUserContent").style.display = "";

            document.getElementById("bookingUserFullName").innerText = data.fullName || "-";
            document.getElementById("bookingUserPhone").innerText = data.phoneNumber || "-";
        }

        async function loadBookingUserInfo(bookingId) {
            setBookingUserModalLoading();
            showBookingUserModal();

            try {
                const url = '@Url.Action("BookingUserInfo", "Bookings")' + '?bookingId=' + encodeURIComponent(bookingId);
                const response = await fetch(url, {
                    method: "GET",
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    setBookingUserModalError(data.message || "Failed to load user information.");
                    return;
                }

                setBookingUserModalContent(data.data);
            } catch (error) {
                setBookingUserModalError("Failed to connect to the server.");
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".booking-row").forEach(function (row) {
                row.addEventListener("click", function () {
                    const url = row.getAttribute("data-url");
                    if (url) {
                        window.location.href = url;
                    }
                });
            });

            document.querySelectorAll(".booking-user-btn").forEach(function (btn) {
                btn.addEventListener("click", function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    const bookingId = btn.getAttribute("data-booking-id");
                    if (bookingId) {
                        loadBookingUserInfo(bookingId);
                    }
                });
            });

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape") {
                    hideBookingUserModal();
                }
            });

            // hide the scroll hint when there is no horizontal overflow,
            // or once the user has started scrolling
            const wrap = document.querySelector(".booking-table-wrap");
            const hint = document.getElementById("scrollHint");

            function refreshScrollHint() {
                if (!wrap || !hint) return;
                const hasOverflow = wrap.scrollWidth > wrap.clientWidth + 4;
                hint.style.display = hasOverflow ? "flex" : "none";
            }

            refreshScrollHint();
            window.addEventListener("resize", refreshScrollHint);

            if (wrap) {
                wrap.addEventListener("scroll", function () {
                    if (Math.abs(wrap.scrollLeft) > 12 && hint) {
                        hint.style.display = "none";
                    }
                }, { passive: true });
            }
        });
    </script>
}
