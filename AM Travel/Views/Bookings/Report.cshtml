<script>
    function fitReportToA4() {
        const report = document.querySelector('.report');
        if (!report) return;

        report.style.setProperty('--print-scale', '1');

        const a4WidthPx = 210 * 3.7795275591;
        const a4HeightPx = 297 * 3.7795275591;

        const scaleX = a4WidthPx / report.scrollWidth;
        const scaleY = a4HeightPx / report.scrollHeight;

        const scale = Math.min(scaleX, scaleY, 1);
        report.style.setProperty('--print-scale', scale);
    }

    window.addEventListener('beforeprint', fitReportToA4);
</script>

