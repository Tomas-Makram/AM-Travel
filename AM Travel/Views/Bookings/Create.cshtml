@using AM_Travel.Resources
@using Microsoft.Extensions.Localization
@model BusinessLayer.DTOs.Book.CreateBookingDTO
@using DataLayer.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@using BusinessLayer.DTOs.Book
@using System.Text.Json
@using System.Security.Claims
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@inject IStringLocalizer<SharedResource> L

@{
    ViewData["Title"] = L["CB_Title"];

    var fullName = ViewBag.Name as string ?? User.FindFirstValue(ClaimTypes.GivenName) ?? "Unknown";

    var initials = string.Join("", fullName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(initials))
        initials = "AM";

    var roomTypes = ViewBag.RoomTypes as List<SelectListItem> ?? new();
    var payTypes = ViewBag.PayTypes as List<SelectListItem> ?? new();
    var isAdmin = User.IsInRole("Admin");
    var selectedTripType = Model.Transportation?.TripType.ToString() ?? "Departure";
    var fromLocations = ViewBag.FromLocations as List<string> ?? new();
    var busRoutes = ViewBag.BusRoutes as IEnumerable<object> ?? Enumerable.Empty<object>();

    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;

    string ReadRouteProp(object item, string propName)
    {
        return item?.GetType().GetProperty(propName)?.GetValue(item)?.ToString() ?? string.Empty;
    }

    var allLocations = fromLocations
        .Concat(busRoutes.Select(x => ReadRouteProp(x, "FromLocation")))
        .Concat(busRoutes.Select(x => ReadRouteProp(x, "ToLocation")))
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Select(x => x.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();

    if (Model.Rooms == null || Model.Rooms.Count == 0)
        Model.Rooms = new List<BookingRoomDTO> { new() { Count = 1, NightPrice = 0 } };

    if (Model.PhoneNumbers == null || Model.PhoneNumbers.Count == 0)
        Model.PhoneNumbers = new List<BookingPhoneDTO> { new() { Prime = true } };

    if (Model.Payments == null || Model.Payments.Count == 0)
        Model.Payments = new List<BookingPaymentDTO> { new() { Amount = 0, PayType = DataLayer.Models.PayType.cache, PaidAt = DateTime.Today } };

    Model.Transportation ??= new TransportationBookingDTO();
    Model.Transportation.DepartureSeats ??= new List<BookingSeatDTO>();
    Model.Transportation.ReturnSeats ??= new List<BookingSeatDTO>();

    string ErrorFor(string key)
    {
        if (!ViewData.ModelState.TryGetValue(key, out var state) || state.Errors.Count == 0)
            return "";
        return string.Join(" ", state.Errors.Select(e => e.ErrorMessage));
    }

    string JsString(string? value) => JsonSerializer.Serialize(value ?? string.Empty);

    string JsGuid(Guid? value) => JsonSerializer.Serialize(
        value.HasValue && value.Value != Guid.Empty ? value.Value.ToString() : string.Empty);

    string SeatLabel(BookingSeatDTO seat)
    {
        if (!string.IsNullOrWhiteSpace(seat.SeatLabel)) return seat.SeatLabel;
        return seat.SeatNumber > 0 ? seat.SeatNumber.ToString() : L["CB_JsSeat"].Value;
    }

    var postedDepartureSeats = Model.Transportation?.DepartureSeats ?? new List<BookingSeatDTO>();
    var postedReturnSeats = Model.Transportation?.ReturnSeats ?? new List<BookingSeatDTO>();
}

