@{
    ViewData["Title"] = L["Home_Title"];
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<style>
    /* ── CSS Variables: Light & Dark ─────────────────────────────────────── */
    :root {
        --home-bg:            #f5f7fb;
        --home-section-bg:    #fff;
        --home-card-bg:       #fff;
        --home-card-border:   #f0d8c2;
        --home-card-shadow:   rgba(255,122,24,.10);
        --home-heading:       #172033;
        --home-sub:           #667085;
        --home-badge-bg:      #fff3e6;
        --home-badge-txt:     #ff7a18;
        --home-icon-bg:       #fff3e6;
        --home-contact-txt:   #ff7a18;
        --home-gallery-bg:    #fff;
        --home-gallery-bdr:   #f0d8c2;
        --home-section-title: #172033;
        --home-section-sub:   #667085;
    }

    html[data-theme="dark"] {
        --home-bg:            #0f172a;
        --home-section-bg:    #0f172a;
        --home-card-bg:       #1a2236;
        --home-card-border:   #283148;
        --home-card-shadow:   rgba(0,0,0,.35);
        --home-heading:       #dce3ed;
        --home-sub:           #7a8ba0;
        --home-badge-bg:      rgba(196,92,10,.22);
        --home-badge-txt:     #f6ba72;
        --home-icon-bg:       rgba(196,92,10,.18);
        --home-contact-txt:   #f6ba72;
        --home-gallery-bg:    #1a2236;
        --home-gallery-bdr:   #283148;
        --home-section-title: #dce3ed;
        --home-section-sub:   #7a8ba0;
    }

    /* ── Page wrapper ────────────────────────────────────────────────────── */
    .art-home {
        position: relative;
        overflow: hidden;
        background: var(--home-bg);
        transition: background .3s;
    }

        .art-home::before {
            content: "";
            position: absolute;
            inset: -120px -80px auto auto;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(255,122,24,.14);
            filter: blur(6px);
            z-index: 0;
        }

    /* ── Hero ────────────────────────────────────────────────────────────── */
    .hero-art {
        position: relative;
        z-index: 1;
        min-height: 680px;
        border-radius: 36px;
        overflow: hidden;
        background: radial-gradient(circle at 15% 15%, rgba(255,255,255,.26), transparent 26%),
                    linear-gradient(135deg, #ff7a18 0%, #ff9f38 45%, #ffbf69 100%);
        box-shadow: 0 28px 80px rgba(255,122,24,.20);
        color: #fff;
    }

    /* ── Topbar ──────────────────────────────────────────────────────────── */
    .hero-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 28px 34px;
        position: relative;
        z-index: 3;
    }

    /* ── Logo card ───────────────────────────────────────────────────────── */
    .home-logo-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 18px;
        border-radius: 24px;
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        transition: .35s ease;
    }

    .home-logo-img {
        width: 68px;
        height: 68px;
        border-radius: 22px;
        background: #fff;
        padding: 7px;
        object-fit: contain;
        box-shadow: 0 16px 36px rgba(0,0,0,.14);
        transition: .3s ease;
    }

    .home-logo-card strong {
        display: block;
        font-size: 24px;
        line-height: 1;
        color: #fff;
    }

    .home-logo-card small {
        display: block;
        margin-top: 5px;
        opacity: .88;
        font-weight: 700;
        color: #fff;
    }

    /* Sticky small logo */
    .home-logo-card.is-small {
        position: fixed;
        top: 18px;
        right: 24px;
        z-index: 50;
        padding: 8px;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 18px 44px rgba(255,122,24,.28);
    }

        .home-logo-card.is-small .home-logo-img {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            padding: 5px;
            box-shadow: none;
        }

        .home-logo-card.is-small .logo-words { display: none; }

    /* ── Action buttons ──────────────────────────────────────────────────── */
    .hero-login-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .art-btn {
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 13px 20px;
        border-radius: 16px;
        font-weight: 900;
        cursor: pointer;
        transition: .22s ease;
        text-decoration: none;
    }

        .art-btn:hover { transform: translateY(-2px); }

    .art-btn-white { background: #fff;                      color: #ff7a18; }
    .art-btn-glass { background: rgba(255,255,255,.16);     color: #fff; border: 1px solid rgba(255,255,255,.22); }
    .art-btn-dark  { background: #172033;                   color: #fff; }

    /* ── Hero main grid ──────────────────────────────────────────────────── */
    .hero-main {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.05fr .95fr;
        align-items: center;
        gap: 34px;
        padding: 40px 48px 58px;
    }

    .hero-copy .eyebrow {
        display: inline-flex;
        padding: 9px 15px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.22);
        font-weight: 900;
        margin-bottom: 20px;
        color: #fff;
    }

    .hero-copy h1 {
        margin: 0 0 22px;
        font-size: clamp(42px, 5.4vw, 76px);
        line-height: 1.02;
        letter-spacing: -2px;
        color: #fff;
    }

    .hero-copy p {
        margin: 0 0 26px;
        font-size: 19px;
        line-height: 1.9;
        color: rgba(255,255,255,.94);
    }

    /* Arabic note box */
    .arabic-note {
        background: rgba(255,255,255,.15);
        border: 1px solid rgba(255,255,255,.22);
        border-radius: 22px;
        padding: 18px 20px;
        margin: 24px 0;
        line-height: 1.9;
        font-size: 17px;
        color: rgba(255,255,255,.96);
    }

    /* Quick info boxes */
    .quick-info {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-top: 22px;
    }

    .quick-box {
        padding: 18px;
        border-radius: 24px;
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.20);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 90px;
        color: #fff;
    }

        .quick-box strong { display: block; font-size: 22px; }
        .quick-box span   { opacity: .9; margin-top: 4px; }

    /* ── Media showcase ──────────────────────────────────────────────────── */
    .media-showcase {
        position: relative;
        min-height: 450px;
        border-radius: 34px;
        overflow: hidden;
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.22);
        box-shadow: 0 24px 60px rgba(0,0,0,.12);
    }

    .media-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transform: scale(1.05);
        transition: opacity .8s ease, transform 1.2s ease;
    }

        .media-slide.active { opacity: 1; transform: scale(1); }

        .media-slide img,
        .media-slide video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .media-overlay {
        position: absolute;
        inset: auto 20px 20px 20px;
        padding: 18px;
        border-radius: 24px;
        background: rgba(23,32,51,.54);
        backdrop-filter: blur(12px);
        color: #fff;
    }

        .media-overlay strong { display: block; font-size: 20px; margin-bottom: 5px; }

    .media-dots {
        position: absolute;
        top: 18px;
        left: 18px;
        display: flex;
        gap: 8px;
        z-index: 3;
    }

    .media-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.45);
        transition: .25s ease;
    }

        .media-dot.active { width: 28px; background: #fff; }

    /* ── About / Contact / Gallery sections ──────────────────────────────── */
    .about-section,
    .contact-art-section,
    .gallery-strip {
        position: relative;
        z-index: 1;
        margin-top: 30px;
        background: var(--home-section-bg);
        transition: background .3s;
    }

    /* Section title */
    .section-title {
        text-align: center;
        max-width: 820px;
        margin: 0 auto 24px;
    }

    .section-title span {
        display: inline-flex;
        padding: 8px 14px;
        border-radius: 999px;
        background: var(--home-badge-bg);
        color: var(--home-badge-txt);
        font-weight: 900;
        transition: background .3s, color .3s;
    }

    .section-title h2 {
        margin: 14px 0 8px;
        font-size: clamp(30px, 4vw, 46px);
        color: var(--home-section-title);
        transition: color .3s;
    }

    .section-title p {
        color: var(--home-section-sub);
        line-height: 1.9;
        margin: 0;
        transition: color .3s;
    }

    /* About grid */
    .about-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .about-card {
        background: var(--home-card-bg);
        border: 1px solid var(--home-card-border);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 44px var(--home-card-shadow);
        transition: background .3s, border-color .3s;
    }

    .about-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        background: var(--home-icon-bg);
        font-size: 26px;
        margin-bottom: 14px;
        transition: background .3s;
    }

    .about-card h3 {
        margin: 0 0 10px;
        color: var(--home-heading);
        transition: color .3s;
    }

    .about-card p {
        color: var(--home-sub);
        line-height: 1.8;
        margin: 0;
        transition: color .3s;
    }

    /* Contact grid */
    .contact-art-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .contact-art-card {
        background: var(--home-card-bg);
        border: 1px solid var(--home-card-border);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 44px var(--home-card-shadow);
        transition: background .3s, border-color .3s;
    }

    .contact-art-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        background: var(--home-icon-bg);
        font-size: 26px;
        margin-bottom: 14px;
        transition: background .3s;
    }

    .contact-art-card h3 {
        margin: 0 0 10px;
        color: var(--home-heading);
        transition: color .3s;
    }

    .contact-art-card p {
        color: var(--home-sub);
        line-height: 1.8;
        margin: 0 0 8px;
        transition: color .3s;
    }

    .contact-art-card a {
        color: var(--home-contact-txt);
        font-weight: 900;
        word-break: break-word;
        transition: color .3s;
    }

    /* Big map card — always orange gradient */
    .contact-art-card.big {
        grid-row: span 2;
        background: radial-gradient(circle at top right, rgba(255,255,255,.22), transparent 28%),
                    linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        border: none;
        box-shadow: 0 24px 60px rgba(255,122,24,.22);
    }

        .contact-art-card.big h3,
        .contact-art-card.big p { color: #fff; }

        .contact-art-card.big a { color: #fff; text-decoration: underline; }

        .contact-art-card.big .contact-art-icon {
            background: rgba(255,255,255,.18);
        }

    .contact-list { display: grid; gap: 12px; margin-top: 18px; }

    .contact-line {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 13px 14px;
        border-radius: 18px;
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.18);
        line-height: 1.6;
        color: #fff;
    }

    /* Gallery */
    .mini-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
    }

    .mini-gallery-item {
        height: 170px;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 16px 38px var(--home-card-shadow);
        border: 1px solid var(--home-gallery-bdr);
        background: var(--home-gallery-bg);
        transition: background .3s, border-color .3s;
    }

        .mini-gallery-item img,
        .mini-gallery-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    /* ── Responsive ──────────────────────────────────────────────────────── */
    @@media (max-width: 1100px) {
        .hero-main,
        .about-grid,
        .contact-art-grid { grid-template-columns: 1fr; }

        .quick-info,
        .mini-gallery { grid-template-columns: 1fr 1fr; }

        .media-showcase { min-height: 360px; }
    }

    @@media (max-width: 640px) {
        .hero-top {
            align-items: flex-start;
            flex-direction: column;
            padding: 20px;
        }

        .hero-main { padding: 24px 20px 34px; }

        .hero-copy h1 { font-size: 38px; }

        .quick-info,
        .mini-gallery { grid-template-columns: 1fr; }

        .media-showcase { min-height: 300px; }

        .home-logo-card.is-small { right: 12px; top: 12px; }
    }
</style>

<div class="art-home">

    @* ── Hero ── *@
    <section class="hero-art">
        <div class="hero-top">
            <div id="homeLogo" class="home-logo-card">
                <img class="home-logo-img"
                     src="~/img/Logo.jpg"
                     asp-append-version="true"
                     alt="AM Travel Logo" />
                <div class="logo-words">
                    <strong>AM Travel</strong>
                    <small>@L["Home_LogoTagline"]</small>
                </div>
            </div>

            <div class="hero-login-actions">
                @if (isAuthenticated)
                {
                    <a class="art-btn art-btn-white" asp-controller="Dashboard" asp-action="Index">
                        @L["Home_OpenDashboard"]
                    </a>

                    <form asp-controller="Auth" asp-action="Logout" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button class="art-btn art-btn-glass" type="submit">@L["Home_Logout"]</button>
                    </form>
                }
                else
                {
                    <a class="art-btn art-btn-white" asp-controller="Auth" asp-action="Login">
                        @L["Home_Login"]
                    </a>
                    <a class="art-btn art-btn-glass" asp-controller="Dashboard" asp-action="Index">
                        @L["Home_OpenDashboard"]
                    </a>
                }
            </div>
        </div>

        <div class="hero-main">
            <div class="hero-copy">
                <h1>AM Travel</h1>

                <div class="arabic-note" dir="rtl">
                    @L["Home_ArabicNote"]
                </div>

                <div class="actions" style="display:flex; gap:12px; flex-wrap:wrap;">
                    <a class="art-btn art-btn-white"
                       href="https://www.facebook.com/AMTravelFortours/"
                       target="_blank" rel="noopener">
                        @L["Home_Facebook"]
                    </a>
                    <a class="art-btn art-btn-glass"
                       href="https://instagram.com/amtr.avel"
                       target="_blank" rel="noopener">
                        @L["Home_Instagram"]
                    </a>
                </div>

                <div class="quick-info">
                    <div class="quick-box">
                        <strong>@L["Home_QuickAlways"]</strong>
                        <span>@L["Home_QuickOpen"]</span>
                    </div>
                    <div class="quick-box">
                        <strong>@L["Home_QuickOnline"]</strong>
                        <span>@L["Home_QuickBooking"]</span>
                    </div>
                </div>
            </div>

            @* Media slideshow *@
            <div class="media-showcase">
                <div class="media-dots" id="mediaDots"></div>

                <div class="media-slide active">
                    <img src="~/COT/photo1.jpg" asp-append-version="true" alt="AM Travel Gallery 1" />
                    <div class="media-overlay">
                        <strong>@L["Home_SlideHotelTitle"]</strong>
                        <span>@L["Home_SlideHotelSub"]</span>
                    </div>
                </div>

                <div class="media-slide">
                    <img src="~/COT/photo2.jpg" asp-append-version="true" alt="AM Travel Gallery 2" />
                    <div class="media-overlay">
                        <strong>@L["Home_SlideTourTitle"]</strong>
                        <span>@L["Home_SlideTourSub"]</span>
                    </div>
                </div>

                <div class="media-slide">
                    <img src="~/COT/photo3.jpeg" asp-append-version="true" alt="AM Travel Gallery 3" />
                    <div class="media-overlay">
                        <strong>@L["Home_SlideMemTitle"]</strong>
                        <span>@L["Home_SlideMemSub"]</span>
                    </div>
                </div>

                <div class="media-slide">
                    <video src="~/COT/video1.mp4" muted playsinline loop></video>
                    <div class="media-overlay">
                        <strong>@L["Home_SlideVideoTitle"]</strong>
                        <span>@L["Home_SlideVideoSub"]</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ── About ── *@
    <section class="about-section">
        <div class="section-title">
            <span>@L["Home_AboutBadge"]</span>
            <h2>@L["Home_AboutHeading"]</h2>
            <p>@L["Home_AboutSub"]</p>
        </div>

        <div class="about-grid">
            <div class="about-card">
                <div class="about-icon">🏨</div>
                <h3>@L["Home_Card1Title"]</h3>
                <p>@L["Home_Card1Body"]</p>
            </div>

            <div class="about-card">
                <div class="about-icon">🚌</div>
                <h3>@L["Home_Card2Title"]</h3>
                <p>@L["Home_Card2Body"]</p>
            </div>

            <div class="about-card">
                <div class="about-icon">📲</div>
                <h3>@L["Home_Card3Title"]</h3>
                <p>@L["Home_Card3Body"]</p>
            </div>
        </div>
    </section>

    @* ── Contact ── *@
    <section class="contact-art-section">
        <div class="section-title">
            <span>@L["Home_ContactBadge"]</span>
            <h2>@L["Home_ContactHeading"]</h2>
            <p>@L["Home_ContactSub"]</p>
        </div>

        <div class="contact-art-grid">

            @* Map card *@
            <div class="contact-art-card big">
                <div class="contact-art-icon">📍</div>
                <h3>@L["Home_LocationTitle"]</h3>
                <p dir="rtl">@L["Home_LocationAddr"]</p>

                <div class="contact-list">
                    <div class="contact-line" dir="rtl">
                        <strong>📌</strong>
                        <span>@L["Home_LocationDetail"]</span>
                    </div>
                    <div class="contact-line">
                        <strong>🕒</strong>
                        <span>@L["Home_AlwaysOpen"]</span>
                    </div>
                </div>

                <div style="margin-top:20px; border-radius:20px; overflow:hidden;">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7932.310247032895!2d31.19801661593663!3d27.18241165024708!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14450b8696770a77%3A0x7c0a30dbb8abf3e8!2z2KfZhNmB2KTYp9ivINiq2LHYp9mB2YrZhCBhbSB0cmF2ZWw!5e0!3m2!1sar!2seg!4v1777144644270!5m2!1sar!2seg"
                            width="100%"
                            height="250"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>

                <a href="https://maps.app.goo.gl/PZrQTmMX4F8qzrJT7"
                   target="_blank"
                   style="display:block; margin-top:10px;">
                    @L["Home_OpenMaps"]
                </a>
            </div>

            @* Phone *@
            <div class="contact-art-card">
                <div class="contact-art-icon">📞</div>
                <h3>@L["Home_PhoneTitle"]</h3>
                <p>010 61761944</p>
                <p>010 66178170</p>
            </div>

            @* Email *@
            <div class="contact-art-card">
                <div class="contact-art-icon">✉️</div>
                <h3>@L["Home_EmailTitle"]</h3>
                <p>
                    <a href="mailto:amtravelalfouad@gmail.com">amtravelalfouad@gmail.com</a>
                </p>
            </div>

            @* Facebook *@
            <div class="contact-art-card">
                <div class="contact-art-icon">🌐</div>
                <h3>@L["Home_FacebookTitle"]</h3>
                <p>@L["Home_FacebookSub"]</p>
                <a href="https://www.facebook.com/AMTravelFortours/"
                   target="_blank" rel="noopener">
                    facebook.com/AMTravelFortours
                </a>
            </div>

            @* Instagram *@
            <div class="contact-art-card">
                <div class="contact-art-icon">📸</div>
                <h3>@L["Home_InstagramTitle"]</h3>
                <p>
                    <a href="https://instagram.com/amtr.avel"
                       target="_blank" rel="noopener">
                        instagram.com/amtr.avel
                    </a>
                </p>
            </div>

        </div>
    </section>

    @* ── Gallery ── *@
    <section class="gallery-strip">
        <div class="section-title">
            <span>@L["Home_GalleryBadge"]</span>
            <h2>@L["Home_GalleryHeading"]</h2>
        </div>

        <div class="mini-gallery">
            <div class="mini-gallery-item">
                <img src="~/COT/photo1.jpg" asp-append-version="true" alt="Gallery 1" />
            </div>
            <div class="mini-gallery-item">
                <img src="~/COT/photo2.jpg" asp-append-version="true" alt="Gallery 2" />
            </div>
            <div class="mini-gallery-item">
                <img src="~/COT/photo3.jpeg" asp-append-version="true" alt="Gallery 3" />
            </div>
            <div class="mini-gallery-item">
                <video src="~/COT/video1.mp4" muted playsinline loop autoplay></video>
            </div>
        </div>
    </section>

</div>

@section Scripts {
    <script>
        /* Sticky logo */
        const homeLogo = document.getElementById("homeLogo");

        window.addEventListener("scroll", function () {
            if (!homeLogo) return;
            if (window.scrollY > 90) {
                homeLogo.classList.add("is-small");
            } else {
                homeLogo.classList.remove("is-small");
            }
        });

        /* Slideshow */
        const slides = Array.from(document.querySelectorAll(".media-slide"));
        const dotsContainer = document.getElementById("mediaDots");
        let currentSlide = 0;

        slides.forEach((_, index) => {
            const dot = document.createElement("div");
            dot.className = "media-dot" + (index === 0 ? " active" : "");
            dotsContainer.appendChild(dot);
        });

        const dots = Array.from(document.querySelectorAll(".media-dot"));

        function activateSlide(index) {
            slides.forEach(slide => {
                slide.classList.remove("active");
                const video = slide.querySelector("video");
                if (video) { video.pause(); video.currentTime = 0; }
            });

            dots.forEach(dot => dot.classList.remove("active"));

            slides[index].classList.add("active");
            dots[index].classList.add("active");

            const activeVideo = slides[index].querySelector("video");
            if (activeVideo) activeVideo.play();
        }

        setInterval(() => {
            currentSlide = (currentSlide + 1) % slides.length;
            activateSlide(currentSlide);
        }, 4200);
    </script>
}