@using DataLayer.Models
@model BusinessLayer.DTOs.Account.CreateNewAccountDTO

@{
    ViewData["Title"] = L["CU_Title"];
}

<style>
    :root {
        --cu-hero-bg: linear-gradient(135deg, #ff7a18, #ffad42);
        --cu-hero-glow: rgba(255,122,24,.18);
        --cu-hero-text: #fff;
        --cu-hero-sub: rgba(255,255,255,.94);
        --cu-card-bg: #fff;
        --cu-card-border: #f0d8c2;
        --cu-card-shadow: rgba(255,122,24,.10);
        --cu-input-bg: #fffaf5;
        --cu-input-border: #f0d8c2;
        --cu-input-text: #172033;
        --cu-heading: #172033;
        --cu-sub: #667085;
        --cu-label: #172033;
        --cu-note-bg: #fff3e6;
        --cu-note-txt: #9a4a00;
        --cu-toggle-bg: #fff3e6;
        --cu-toggle-txt: #ff7a18;
        --cu-role-bg: linear-gradient(135deg, #ff7a18, #ffad42);
    }

    html[data-theme="dark"] {
        --cu-hero-bg: linear-gradient(135deg, #c45c0a, #d97c2a);
        --cu-hero-glow: rgba(196,92,10,.22);
        --cu-hero-text: #f5f0eb;
        --cu-hero-sub: rgba(245,240,235,.88);
        --cu-card-bg: #1e2535;
        --cu-card-border: #2d3650;
        --cu-card-shadow: rgba(0,0,0,.28);
        --cu-input-bg: #252d3f;
        --cu-input-border: #3a4460;
        --cu-input-text: #d4cbc3;
        --cu-heading: #e8ddd5;
        --cu-sub: #8a96a8;
        --cu-label: #d4cbc3;
        --cu-note-bg: rgba(196,92,10,.18);
        --cu-note-txt: #e8b48a;
        --cu-toggle-bg: rgba(196,92,10,.22);
        --cu-toggle-txt: #e8925a;
        --cu-role-bg: linear-gradient(135deg, #c45c0a, #d97c2a);
    }

    .create-user-page {
        display: grid;
        gap: 22px;
    }

    .create-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--cu-hero-text);
        background: var(--cu-hero-bg);
        box-shadow: 0 24px 70px var(--cu-hero-glow);
    }

        .create-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 26%);
            pointer-events: none;
        }

        .create-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            right: -90px;
            bottom: -110px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
        }

    .create-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .create-title {
        display: grid;
        gap: 10px;
    }

    .create-badge {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--cu-hero-text);
    }

    .create-title h1 {
        margin: 0;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--cu-hero-text);
    }

    .create-title p {
        margin: 0;
        color: var(--cu-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    .create-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        flex-shrink: 0;
    }

        .create-avatar-wrap::before {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid rgba(255,255,255,.22);
        }

        .create-avatar-wrap::after {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid transparent;
            border-top-color: #fff;
            border-right-color: rgba(255,255,255,.72);
            animation: create-avatar-spin 4s linear infinite;
        }

    .create-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)), linear-gradient(135deg, #fff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .create-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
    }

    @@keyframes create-avatar-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .hero-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .hero-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
        border: 1px solid rgba(255,255,255,.24);
        color: var(--cu-hero-text);
        background: rgba(255,255,255,.16);
    }

        .hero-btn.primary {
            background: #fff;
            color: #ff7a18;
            border-color: #fff;
            box-shadow: 0 14px 30px rgba(0,0,0,.12);
        }

        .hero-btn:hover {
            transform: translateY(-2px);
        }

    .create-layout {
        display: grid;
        grid-template-columns: 1fr 390px;
        gap: 20px;
        align-items: start;
    }

    .create-form-card,
    .side-card {
        background: var(--cu-card-bg);
        border: 1px solid var(--cu-card-border);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 42px var(--cu-card-shadow);
        transition: background .3s, border-color .3s;
    }

    .create-form-card {
        display: grid;
        gap: 16px;
    }

    .form-title h2 {
        margin: 0 0 6px;
        font-size: 28px;
        color: var(--cu-heading);
    }

    .form-title p {
        margin: 0;
        color: var(--cu-sub);
        line-height: 1.7;
    }

    .form-grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
    }

    .field-group {
        display: grid;
        gap: 8px;
    }

        .field-group.full {
            grid-column: 1 / -1;
        }

        .field-group label {
            font-weight: 900;
            color: var(--cu-label);
        }

        .field-group input,
        .field-group select {
            width: 100%;
            border: 1px solid var(--cu-input-border);
            border-radius: 16px;
            padding: 14px 15px;
            background: var(--cu-input-bg);
            color: var(--cu-input-text);
            transition: .2s ease;
            font-size: 15px;
            outline: none;
            box-sizing: border-box;
        }

            .field-group input:focus,
            .field-group select:focus {
                border-color: rgba(255,122,24,.6);
                background: var(--cu-card-bg);
                box-shadow: 0 0 0 5px rgba(255,122,24,.10);
            }

            .field-group input::placeholder {
                color: var(--cu-sub);
                opacity: .7;
            }

            .field-group select option {
                background: #fff;
                color: #172033;
            }

    .password-wrap {
        position: relative;
    }

        .password-wrap input {
            padding-right: 54px;
        }

    .toggle-password {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 13px;
        background: var(--cu-toggle-bg);
        color: var(--cu-toggle-txt);
        cursor: pointer;
        font-weight: 900;
        transition: .18s ease;
        display: grid;
        place-items: center;
    }

        .toggle-password:hover {
            background: #ff7a18;
            color: #fff;
        }

    .validation,
    .field-validation-error {
        color: #ef4444;
        font-size: 13px;
        font-weight: 700;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 6px;
    }

    .create-btn {
        border: none;
        border-radius: 18px;
        padding: 14px 22px;
        background: linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(255,122,24,.22);
        transition: .22s ease;
        font-size: 15px;
    }

        .create-btn:hover {
            transform: translateY(-2px);
        }

    .side-card h3 {
        margin: 0 0 10px;
        color: var(--cu-heading);
        font-size: 24px;
    }

    .side-card > p {
        color: var(--cu-sub);
        line-height: 1.8;
        margin: 0 0 14px;
    }

    .note-list {
        display: grid;
        gap: 12px;
        margin-top: 14px;
    }

    .note {
        background: var(--cu-note-bg);
        color: var(--cu-note-txt);
        padding: 14px;
        border-radius: 18px;
        line-height: 1.8;
        font-weight: 700;
        transition: background .3s, color .3s;
    }

    .role-box {
        margin-top: 18px;
        border-radius: 26px;
        padding: 20px;
        color: #fff;
        background: var(--cu-role-bg);
    }

        .role-box strong {
            display: block;
            margin-bottom: 8px;
            font-size: 18px;
        }

        .role-box span {
            display: block;
            opacity: .92;
            line-height: 1.8;
        }

    @@media (max-width: 1000px) {
        .create-layout,
        .form-grid-2 {
            grid-template-columns: 1fr;
        }

        .hero-actions,
        .form-actions {
            flex-direction: column;
        }

        .hero-btn,
        .create-btn {
            width: 100%;
        }
    }

    @@media (max-width: 700px) {
        .create-avatar-wrap {
            width: 112px;
            height: 112px;
            border-radius: 32px;
        }

            .create-avatar-wrap::before,
            .create-avatar-wrap::after {
                border-radius: 38px;
            }

        .create-avatar {
            width: 88px;
            height: 88px;
            border-radius: 27px;
            font-size: 34px;
        }
    }
</style>

<div class="create-user-page">

    <section class="create-hero">
        <div class="create-hero-inner">
            <div class="create-title">
                <span class="create-badge">@L["CU_Badge"]</span>
                <h1>@L["CU_Heading"]</h1>
                <p>@L["CU_Subtitle"]</p>
            </div>

            <div class="create-avatar-wrap">
                <div class="create-avatar">AA</div>
                <span class="create-avatar-status"></span>
            </div>
        </div>

        <div class="hero-actions">
            <a class="hero-btn primary" asp-action="Users">
                @L["CU_UsersManagement"]
            </a>

            <a class="hero-btn" asp-controller="Dashboard" asp-action="Index">
                @L["CU_Dashboard"]
            </a>
        </div>
    </section>

    <section class="create-layout">

        <form asp-action="CreateUser" method="post" class="create-form-card">
            @Html.AntiForgeryToken()

            <div class="form-title">
                <h2>@L["CU_FormTitle"]</h2>
                <p>@L["CU_FormSubtitle"]</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="validation"></div>

            <div class="form-grid-2">

                <div class="field-group full">
                    <label asp-for="FullName">@L["CU_FullName"]</label>
                    <input asp-for="FullName" placeholder="@L["CU_FullNamePH"]" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="UserName">@L["CU_Username"]</label>
                    <input asp-for="UserName" placeholder="@L["CU_UsernamePH"]" autocomplete="username" />
                    <span asp-validation-for="UserName" class="field-validation-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="PhoneNumber">@L["CU_PhoneNumber"]</label>
                    <input asp-for="PhoneNumber" placeholder="@L["CU_PhoneNumberPH"]" />
                    <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="NationalId">@L["CU_NationalId"]</label>
                    <input asp-for="NationalId" placeholder="@L["CU_NationalIdPH"]" />
                    <span asp-validation-for="NationalId" class="field-validation-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="AccountType">@L["CU_AccountType"]</label>
                    <select asp-for="AccountType" asp-items="Html.GetEnumSelectList<AccountType>()"></select>
                    <span asp-validation-for="AccountType" class="field-validation-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Password">@L["CU_Password"]</label>
                    <div class="password-wrap">
                        <input asp-for="Password"
                               id="password"
                               type="password"
                               placeholder="@L["CU_PasswordPH"]"
                               autocomplete="new-password" />
                        <button type="button" class="toggle-password" data-target="password">👁</button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="ConfirmPassword">@L["CU_ConfirmPassword"]</label>
                    <div class="password-wrap">
                        <input asp-for="ConfirmPassword"
                               id="confirmPassword"
                               type="password"
                               placeholder="@L["CU_ConfirmPasswordPH"]"
                               autocomplete="new-password" />
                        <button type="button" class="toggle-password" data-target="confirmPassword">👁</button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>

            </div>

            <div class="form-actions">
                <button class="create-btn" type="submit">
                    @L["CU_Submit"]
                </button>
            </div>
        </form>

        <aside>
            <div class="side-card">
                <h3>@L["CU_NotesTitle"]</h3>
                <p>@L["CU_NotesSubtitle"]</p>

                <div class="note-list">
                    <div class="note">@L["CU_Note1"]</div>
                    <div class="note">@L["CU_Note2"]</div>
                    <div class="note">@L["CU_Note3"]</div>
                </div>
            </div>

            <div class="role-box">
                <strong>@L["CU_RoleGuideTitle"]</strong>
                <span>@L["CU_RoleGuideText"]</span>
            </div>
        </aside>

    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelectorAll(".toggle-password").forEach(button => {
            button.addEventListener("click", function () {
                const targetId = this.getAttribute("data-target");
                const input = document.getElementById(targetId);

                if (!input) return;

                const isPassword = input.type === "password";

                input.type = isPassword ? "text" : "password";
                this.textContent = isPassword ? "🙈" : "👁";
            });
        });
    </script>
}