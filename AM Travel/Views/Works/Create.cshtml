@using DataLayer.Models

@model BusinessLayer.DTOs.Work.CreateWorkDTO

@{
    ViewData["Title"] = L["Work_CreateTitle"];

    string fullName = Convert.ToString(ViewBag.Name) ?? "User";
    var cleanName   = fullName.Trim().Replace("  ", " ");

    var userName = string.Join("", cleanName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(userName)) userName = "U";
}

<style>
    /* ── CSS Variables: Light & Dark ─────────────────────────────────────── */
    :root {
        --wk-hero-bg:        linear-gradient(135deg, #ff7a18, #ffad42);
        --wk-hero-glow:      rgba(255,122,24,.18);
        --wk-hero-text:      #fff;
        --wk-hero-sub:       rgba(255,255,255,.92);
        --wk-card-bg:        #fff;
        --wk-card-border:    #f0d8c2;
        --wk-card-shadow:    rgba(255,122,24,.10);
        --wk-input-bg:       #fff;
        --wk-input-border:   #f3dfcc;
        --wk-input-text:     #172033;
        --wk-label:          #667085;
        --wk-light-btn-bg:   #fffaf5;
        --wk-light-btn-bdr:  #f3dfcc;
        --wk-light-btn-txt:  #ff7a18;
    }

    html[data-theme="dark"] {
        --wk-hero-bg:        linear-gradient(135deg, #c45c0a, #d97c2a);
        --wk-hero-glow:      rgba(196,92,10,.22);
        --wk-hero-text:      #f5f0eb;
        --wk-hero-sub:       rgba(245,240,235,.85);
        --wk-card-bg:        #1a2236;
        --wk-card-border:    #283148;
        --wk-card-shadow:    rgba(0,0,0,.35);
        --wk-input-bg:       #212c3f;
        --wk-input-border:   #3a4d66;
        --wk-input-text:     #c4cedb;
        --wk-label:          #7a8ba0;
        --wk-light-btn-bg:   #212c3f;
        --wk-light-btn-bdr:  #3a4d66;
        --wk-light-btn-txt:  #f6ba72;
    }

    /* ── Layout ──────────────────────────────────────────────────────────── */
    .work-form-page { display: grid; gap: 20px; }

    /* ── Hero ────────────────────────────────────────────────────────────── */
    .work-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--wk-hero-text);
        background: var(--wk-hero-bg);
        box-shadow: 0 24px 70px var(--wk-hero-glow);
    }

        .work-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 26%);
            pointer-events: none;
        }

        .work-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            right: -90px;
            bottom: -110px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
        }

    .work-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .work-title {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 10px;
    }

    .work-badge {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--wk-hero-text);
    }

    .work-title h1 {
        margin: 0;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--wk-hero-text);
    }

    .work-title p {
        margin: 0;
        color: var(--wk-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    /* ── Avatar ──────────────────────────────────────────────────────────── */
    .work-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        flex-shrink: 0;
    }

        .work-avatar-wrap::before {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid rgba(255,255,255,.22);
        }

        .work-avatar-wrap::after {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid transparent;
            border-top-color: #fff;
            border-right-color: rgba(255,255,255,.72);
            animation: work-avatar-spin 4s linear infinite;
        }

    .work-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)),
                    linear-gradient(135deg, #ffffff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .work-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
        box-shadow: 0 8px 18px rgba(18,183,106,.35);
    }

    @@keyframes work-avatar-spin {
        to { transform: rotate(360deg); }
    }

    /* ── Hero actions ────────────────────────────────────────────────────── */
    .work-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .work-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
    }

        .work-btn:hover { transform: translateY(-2px); }

    .btn-white { background: #fff; color: #ff7a18; box-shadow: 0 14px 30px rgba(0,0,0,.12); }

    .btn-glass {
        background: rgba(255,255,255,.16);
        color: var(--wk-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

    /* ── Form card ───────────────────────────────────────────────────────── */
    .work-form-card {
        background: var(--wk-card-bg);
        border: 1px solid var(--wk-card-border);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 42px var(--wk-card-shadow);
        transition: background .3s, border-color .3s;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
    }

    .form-group {
        display: grid;
        gap: 7px;
    }

        .form-group.full { grid-column: 1 / -1; }

        .form-group label {
            color: var(--wk-label);
            font-size: 13px;
            font-weight: 900;
            transition: color .3s;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            border-radius: 16px;
            border: 1px solid var(--wk-input-border);
            padding: 13px 14px;
            outline: none;
            font-weight: 800;
            resize: vertical;
            background: var(--wk-input-bg);
            color: var(--wk-input-text);
            font-size: 14px;
            transition: border-color .2s, background .3s, color .3s;
            width: 100%;
            box-sizing: border-box;
        }

            .form-group input:focus,
            .form-group select:focus,
            .form-group textarea:focus {
                border-color: rgba(255,122,24,.55);
                background: var(--wk-card-bg);
                box-shadow: 0 0 0 4px rgba(255,122,24,.09);
            }

            .form-group input::placeholder,
            .form-group textarea::placeholder {
                color: var(--wk-label);
                opacity: .7;
            }

            .form-group select option { background: #fff; color: #172033; }

    /* ── Form actions ────────────────────────────────────────────────────── */
    .form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .orange-btn {
        min-height: 46px;
        padding: 0 22px;
        border-radius: 16px;
        border: none;
        background: linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        font-weight: 900;
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 28px rgba(255,122,24,.22);
        transition: .2s ease;
    }

        .orange-btn:hover  { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(255,122,24,.30); }
        .orange-btn:active { transform: translateY(0); }

    .light-btn {
        min-height: 46px;
        padding: 0 22px;
        border-radius: 16px;
        border: 1px solid var(--wk-light-btn-bdr);
        background: var(--wk-light-btn-bg);
        color: var(--wk-light-btn-txt);
        font-weight: 900;
        font-size: 15px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: .2s ease;
    }

        .light-btn:hover { transform: translateY(-2px); }

    /* ── Validation ──────────────────────────────────────────────────────── */
    .text-danger,
    .field-validation-error {
        color: #f04438;
        font-weight: 800;
        font-size: 13px;
    }

    /* ── Responsive ──────────────────────────────────────────────────────── */
    @@media (max-width: 700px) {
        .form-grid { grid-template-columns: 1fr; }

        .work-avatar-wrap { width: 112px; height: 112px; border-radius: 32px; }

            .work-avatar-wrap::before,
            .work-avatar-wrap::after { border-radius: 38px; }

        .work-avatar { width: 88px; height: 88px; border-radius: 27px; font-size: 34px; }

        .work-actions { flex-direction: column; }

        .work-btn { width: 100%; }

        .form-actions { flex-direction: column; }

        .orange-btn,
        .light-btn { width: 100%; }
    }
</style>

<div class="work-form-page">

    @* Hero *@
    <section class="work-hero">
        <div class="work-hero-inner">
            <div class="work-title">
                <span class="work-badge">@L["Work_CreateBadge"]</span>
                <h1>@L["Work_CreateHeading"]</h1>
                <p>@L["Work_CreateSubtitle"]</p>
            </div>

            <div class="work-avatar-wrap">
                <div class="work-avatar">@userName</div>
                <span class="work-avatar-status"></span>
            </div>
        </div>

        <div class="work-actions">
            <a class="work-btn btn-white" asp-action="Index">@L["Work_AllWorks"]</a>
            <a class="work-btn btn-glass" asp-action="Today">@L["Work_TodayWorks"]</a>
            <a class="work-btn btn-glass" asp-controller="Dashboard" asp-action="Index">@L["Work_Dashboard"]</a>
        </div>
    </section>

    @* Form *@
    <section class="work-form-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="NameClient">@L["Work_NameClient"]</label>
                    <input asp-for="NameClient" placeholder="@L["Work_NameClientPH"]" />
                    <span asp-validation-for="NameClient" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber">@L["Work_PhoneNumber"]</label>
                    <input asp-for="PhoneNumber" placeholder="@L["Work_PhonePH"]" />
                    <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ClientType">@L["Work_ClientType"]</label>
                    <select asp-for="ClientType" asp-items="Html.GetEnumSelectList<ClientType>()"></select>
                    <span asp-validation-for="ClientType" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DayUpdated">@L["Work_DayUpdated"]</label>
                    <input asp-for="DayUpdated" type="date" />
                    <span asp-validation-for="DayUpdated" class="field-validation-error"></span>
                </div>

                <div class="form-group full">
                    <label asp-for="Notes">@L["Work_Notes"]</label>
                    <textarea asp-for="Notes" rows="5" placeholder="@L["Work_NotesPH"]"></textarea>
                    <span asp-validation-for="Notes" class="field-validation-error"></span>
                </div>

            </div>

            <div class="form-actions">
                <button class="orange-btn" type="submit">@L["Work_SubmitCreate"]</button>
                <a class="light-btn" asp-action="Index">@L["Work_Cancel"]</a>
            </div>
        </form>
    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}