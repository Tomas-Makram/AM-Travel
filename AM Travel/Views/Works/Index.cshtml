@using DataLayer.Models

@model List<BusinessLayer.DTOs.Work.WorkListItemDTO>

@{
    ViewData["Title"] = L["WL_Title"];

    var totalWorks = Model.Count;
    var todayWorks = Model.Count(x => x.DayCreated.Date == DateTime.Today || x.DayUpdated.Date == DateTime.Today);
    var scheduledWorks = Model.Count(x => x.DayUpdated.Date >= DateTime.Today);

    string fullName = Convert.ToString(ViewBag.Name) ?? "User";
    var cleanName = fullName.Trim().Replace("  ", " ");

    var userName = string.Join("", cleanName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(userName)) userName = "U";
}

<style>
    :root {
        --wl-hero-bg: linear-gradient(135deg, #ff7a18, #ffad42);
        --wl-hero-glow: rgba(255,122,24,.18);
        --wl-hero-text: #fff;
        --wl-hero-sub: rgba(255,255,255,.92);
        --wl-card-bg: #fff;
        --wl-card-border: #f0d8c2;
        --wl-card-shadow: rgba(255,122,24,.09);
        --wl-heading: #172033;
        --wl-sub: #667085;
        --wl-label: #667085;
        --wl-input-bg: #fff;
        --wl-input-border: #f3dfcc;
        --wl-input-text: #172033;
        --wl-row-bg: #fffaf5;
        --wl-row-border: #f3dfcc;
        --wl-row-text: #172033;
        --wl-pill-bg: #fff3e6;
        --wl-pill-txt: #ff7a18;
        --wl-edit-bg: #fff;
        --wl-edit-border: #f3dfcc;
        --wl-edit-txt: #ff7a18;
        --wl-delete-bg: rgba(240,68,56,.10);
        --wl-delete-txt: #f04438;
        --wl-light-btn-bg: #fffaf5;
        --wl-light-btn-bdr: #f3dfcc;
        --wl-light-btn-txt: #ff7a18;
        --wl-empty-txt: #98a2b3;
        --wl-th-txt: #667085;
    }

    html[data-theme="dark"] {
        --wl-hero-bg: linear-gradient(135deg, #c45c0a, #d97c2a);
        --wl-hero-glow: rgba(196,92,10,.22);
        --wl-hero-text: #f5f0eb;
        --wl-hero-sub: rgba(245,240,235,.85);
        --wl-card-bg: #1a2236;
        --wl-card-border: #283148;
        --wl-card-shadow: rgba(0,0,0,.35);
        --wl-heading: #dce3ed;
        --wl-sub: #7a8ba0;
        --wl-label: #7a8ba0;
        --wl-input-bg: #212c3f;
        --wl-input-border: #3a4d66;
        --wl-input-text: #c4cedb;
        --wl-row-bg: #212c3f;
        --wl-row-border: #283148;
        --wl-row-text: #dce3ed;
        --wl-pill-bg: rgba(196,92,10,.22);
        --wl-pill-txt: #f6ba72;
        --wl-edit-bg: #212c3f;
        --wl-edit-border: #3a4d66;
        --wl-edit-txt: #f6ba72;
        --wl-delete-bg: rgba(248,113,113,.12);
        --wl-delete-txt: #f87171;
        --wl-light-btn-bg: #212c3f;
        --wl-light-btn-bdr: #3a4d66;
        --wl-light-btn-txt: #f6ba72;
        --wl-empty-txt: #5a6a7e;
        --wl-th-txt: #7a8ba0;
    }

    .works-page {
        display: grid;
        gap: 20px;
    }

    /* Hero - same style as Edit page */
    .works-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--wl-hero-text);
        background: var(--wl-hero-bg);
        box-shadow: 0 24px 70px var(--wl-hero-glow);
    }

    .works-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 26%);
        pointer-events: none;
    }

    .works-hero::after {
        content: "";
        position: absolute;
        width: 260px;
        height: 260px;
        right: -90px;
        bottom: -110px;
        border-radius: 50%;
        background: rgba(255,255,255,.12);
    }

    .works-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .works-title {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 10px;
    }

    .works-badge {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--wl-hero-text);
    }

    .works-title h1 {
        margin: 0;
        font-size: clamp(34px,5vw,54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--wl-hero-text);
    }

    .works-title p {
        margin: 0;
        color: var(--wl-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    .works-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        flex-shrink: 0;
    }

    .works-avatar-wrap::before {
        content: "";
        position: absolute;
        inset: -7px;
        border-radius: 44px;
        border: 3px solid rgba(255,255,255,.22);
    }

    .works-avatar-wrap::after {
        content: "";
        position: absolute;
        inset: -7px;
        border-radius: 44px;
        border: 3px solid transparent;
        border-top-color: #fff;
        border-right-color: rgba(255,255,255,.72);
        animation: works-avatar-spin 4s linear infinite;
    }

    .works-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)), linear-gradient(135deg, #fff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .works-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
    }

    @@keyframes works-avatar-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .works-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .works-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
    }

    .works-btn:hover {
        transform: translateY(-2px);
    }

    .btn-white {
        background: #fff;
        color: #ff7a18;
        box-shadow: 0 14px 30px rgba(0,0,0,.12);
    }

    .btn-glass {
        background: rgba(255,255,255,.16);
        color: var(--wl-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
    }

    .summary-card {
        background: var(--wl-card-bg);
        border: 1px solid var(--wl-card-border);
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 12px 30px var(--wl-card-shadow);
    }

    .summary-card small {
        color: var(--wl-sub);
        font-weight: 800;
    }

    .summary-card strong {
        display: block;
        margin-top: 10px;
        font-size: 30px;
        color: var(--wl-heading);
    }

    .filter-card,
    .works-table-card {
        background: var(--wl-card-bg);
        border: 1px solid var(--wl-card-border);
        border-radius: 28px;
        padding: 24px;
        box-shadow: 0 12px 30px var(--wl-card-shadow);
    }

    .works-filter {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-group {
        display: grid;
        gap: 8px;
    }

    .form-group label {
        font-size: 13px;
        font-weight: 800;
        color: var(--wl-label);
    }

    .form-group input,
    .form-group select {
        height: 48px;
        border-radius: 14px;
        border: 1px solid var(--wl-input-border);
        background: var(--wl-input-bg);
        color: var(--wl-input-text);
        padding: 0 14px;
        font-weight: 700;
        outline: none;
    }

    .orange-btn {
        height: 48px;
        padding: 0 20px;
        border-radius: 14px;
        border: none;
        background: linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        font-weight: 800;
        cursor: pointer;
    }

    .light-btn {
        height: 48px;
        padding: 0 20px;
        border-radius: 14px;
        border: 1px solid var(--wl-light-btn-bdr);
        background: var(--wl-light-btn-bg);
        color: var(--wl-light-btn-txt);
        font-weight: 800;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Table */
    .works-table-card {
        overflow: hidden;
    }

    .works-table-wrap {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 12px;
    }

    .works-table-wrap::-webkit-scrollbar {
        height: 12px;
    }

    .works-table-wrap::-webkit-scrollbar-track {
        background: rgba(255,255,255,.08);
        border-radius: 999px;
    }

    .works-table-wrap::-webkit-scrollbar-thumb {
        background: #9ca3af;
        border-radius: 999px;
    }

    .works-table {
        width: 100%;
        min-width: 1180px;
        border-collapse: separate;
        border-spacing: 0 12px;
        table-layout: fixed;
    }

    .works-table th {
        padding: 0 14px 8px;
        text-align: center;
        color: var(--wl-th-txt);
        font-size: 13px;
        font-weight: 900;
        white-space: nowrap;
    }

    .works-table td {
        background: var(--wl-row-bg);
        border-top: 1px solid var(--wl-row-border);
        border-bottom: 1px solid var(--wl-row-border);
        padding: 16px 14px;
        color: var(--wl-row-text);
        font-weight: 800;
        vertical-align: middle;
        text-align: center;
        font-size: 14px;
        white-space: nowrap;
        height: 82px;
    }

    .works-table td:first-child {
        border-left: 1px solid var(--wl-row-border);
        border-radius: 18px 0 0 18px;
    }

    .works-table td:last-child {
        border-right: 1px solid var(--wl-row-border);
        border-radius: 0 18px 18px 0;
    }

    html[dir="rtl"] .works-table td:first-child,
    body[dir="rtl"] .works-table td:first-child {
        border-left: 0;
        border-right: 1px solid var(--wl-row-border);
        border-radius: 0 18px 18px 0;
    }

    html[dir="rtl"] .works-table td:last-child,
    body[dir="rtl"] .works-table td:last-child {
        border-right: 0;
        border-left: 1px solid var(--wl-row-border);
        border-radius: 18px 0 0 18px;
    }

    .works-table tbody tr:hover td {
        background: var(--wl-input-bg);
    }

    .col-client { width: 140px; }
    .col-phone { width: 160px; }
    .col-type { width: 150px; }
    .col-date { width: 150px; }
    .col-notes { width: 300px; }
    .col-user { width: 140px; }
    .col-actions { width: 170px; }

    .notes-box {
        max-height: 70px;
        overflow-y: auto;
        overflow-x: hidden;
        text-align: start;
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        line-height: 1.7;
        padding-inline-end: 8px;
    }

    .notes-box::-webkit-scrollbar {
        width: 6px;
    }

    .notes-box::-webkit-scrollbar-thumb {
        background: var(--wl-input-border);
        border-radius: 999px;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: var(--wl-pill-bg);
        color: var(--wl-pill-txt);
        font-size: 13px;
        font-weight: 900;
        white-space: nowrap;
    }

    .table-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }

    .table-actions form {
        margin: 0;
    }

    .edit-btn {
        height: 38px;
        padding: 0 14px;
        border-radius: 12px;
        border: 1px solid var(--wl-edit-border);
        background: var(--wl-edit-bg);
        color: var(--wl-edit-txt);
        text-decoration: none;
        display: flex;
        align-items: center;
        font-weight: 800;
        white-space: nowrap;
    }

    .delete-btn {
        height: 38px;
        padding: 0 14px;
        border-radius: 12px;
        border: none;
        background: var(--wl-delete-bg);
        color: var(--wl-delete-txt);
        font-weight: 800;
        cursor: pointer;
        white-space: nowrap;
    }

    .empty-box {
        padding: 40px;
        text-align: center;
        color: var(--wl-empty-txt);
        font-weight: 800;
    }

    @@media(max-width:1000px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }

        .works-filter {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="works-page">

    <section class="works-hero">
        <div class="works-hero-inner">
            <div class="works-title">
                <span class="works-badge">@L["WL_Badge"]</span>
                <h1>@L["WL_Heading"]</h1>
                <p>@L["WL_Subtitle"]</p>
            </div>

            <div class="works-avatar-wrap">
                <div class="works-avatar">@userName</div>
                <span class="works-avatar-status"></span>
            </div>
        </div>

        <div class="works-actions">
            <a class="works-btn btn-white" asp-action="Create">@L["WL_NewWork"]</a>
            <a class="works-btn btn-glass" asp-action="Today">@L["WL_TodayWorks"]</a>
            <a class="works-btn btn-glass" asp-controller="Dashboard" asp-action="Index">@L["WL_Dashboard"]</a>
        </div>
    </section>

    <section class="summary-grid">
        <div class="summary-card">
            <small>@L["WL_TotalWorks"]</small>
            <strong>@totalWorks</strong>
        </div>

        <div class="summary-card">
            <small>@L["WL_TodayWorksCard"]</small>
            <strong>@todayWorks</strong>
        </div>

        <div class="summary-card">
            <small>@L["WL_ScheduledWorks"]</small>
            <strong>@scheduledWorks</strong>
        </div>
    </section>

    <section class="filter-card">
        <form method="get" asp-action="Index" class="works-filter">

            <div class="form-group">
                <label>@L["WL_FilterSearch"]</label>
                <input name="search" value="@ViewBag.Search" placeholder="@L["WL_FilterSearchPH"]" />
            </div>

            <div class="form-group">
                <label>@L["WL_FilterDate"]</label>
                <input type="date" name="date" value="@ViewBag.Date" />
            </div>

            <div class="form-group">
                <label>@L["WL_FilterStars"]</label>
                <select name="clientType" asp-items="Html.GetEnumSelectList<ClientType>()">
                    <option value="">@L["WL_FilterAllStars"]</option>
                </select>
            </div>

            <button class="orange-btn" type="submit">@L["WL_FilterApply"]</button>
            <a class="light-btn" asp-action="Index">@L["WL_FilterReset"]</a>

        </form>
    </section>

    <section class="works-table-card">
        <div class="works-table-wrap">
            <table class="works-table">
                <thead>
                    <tr>
                        <th class="col-client">@L["WL_ColClient"]</th>
                        <th class="col-phone">@L["WL_ColPhone"]</th>
                        <th class="col-type">@L["WL_ColType"]</th>
                        <th class="col-date">@L["WL_ColCreated"]</th>
                        <th class="col-date">@L["WL_ColNextAction"]</th>
                        <th class="col-notes">@L["WL_ColNotes"]</th>
                        <th class="col-user">@L["WL_ColUser"]</th>
                        <th class="col-actions">@L["WL_ColActions"]</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-box">@L["WL_NoWorks"]</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="col-client">@item.NameClient</td>

                                <td class="col-phone">@item.PhoneNumber</td>

                                <td class="col-type">
                                    <span class="pill">
                                        @Html.DisplayFor(modelItem => item.ClientType)
                                    </span>
                                </td>

                                <td class="col-date">@item.DayCreated.ToString("yyyy-MM-dd")</td>

                                <td class="col-date">@item.DayUpdated.ToString("yyyy-MM-dd")</td>

                                <td class="col-notes">
                                    <div class="notes-box">
                                        @(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)
                                    </div>
                                </td>

                                <td class="col-user">
                                    @(string.IsNullOrWhiteSpace(item.UserName) ? "-" : item.UserName)
                                </td>

                                <td class="col-actions">
                                    <div class="table-actions">
                                        <a class="edit-btn"
                                           asp-action="Edit"
                                           asp-route-id="@item.WorkId">
                                            @L["WL_EditBtn"]
                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@item.WorkId"
                                              method="post">
                                            @Html.AntiForgeryToken()

                                            <button class="delete-btn" type="submit">
                                                @L["WL_DeleteBtn"]
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>

@section Scripts {
    <script>
        const selectedClientType = '@((int?)ViewBag.ClientType)';

        if (selectedClientType) {
            const select = document.querySelector('select[name="clientType"]');
            if (select) select.value = selectedClientType;
        }
    </script>
}