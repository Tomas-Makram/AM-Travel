@{
    ViewData["Title"] = L["Err_429_Title"];
    var retryAfter = ViewBag.RetryAfter ?? 60;
    var returnUrl = ViewBag.ReturnUrl as string;
}

<style>
    :root {
        --err-card-bg: #fff;
        --err-card-border: #f0d8c2;
        --err-card-shadow: rgba(255,122,24,.10);
        --err-code-bg: #fff3e6;
        --err-code-txt: #ff7a18;
        --err-heading: #172033;
        --err-body: #667085;
        --err-muted: #98a2b3;
        --err-counter-txt: #172033;
    }

    html[data-theme="dark"] {
        --err-card-bg: #1a2236;
        --err-card-border: #283148;
        --err-card-shadow: rgba(0,0,0,.35);
        --err-code-bg: rgba(196,92,10,.22);
        --err-code-txt: #f6ba72;
        --err-heading: #dce3ed;
        --err-body: #7a8ba0;
        --err-muted: #5a6a7e;
        --err-counter-txt: #dce3ed;
    }

    .error-card {
        max-width: 560px;
        margin: 60px auto;
        background: var(--err-card-bg);
        border: 1px solid var(--err-card-border);
        border-radius: 32px;
        padding: 48px 40px;
        text-align: center;
        box-shadow: 0 24px 64px var(--err-card-shadow);
        transition: background .3s, border-color .3s;
    }

        .error-card .badge {
            display: inline-flex;
            padding: 10px 20px;
            border-radius: 999px;
            background: var(--err-code-bg);
            color: var(--err-code-txt);
            font-size: 28px;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 22px;
            transition: background .3s, color .3s;
        }

        .error-card h1 {
            margin: 0 0 12px;
            font-size: clamp(26px, 5vw, 38px);
            color: var(--err-heading);
            letter-spacing: -.5px;
            line-height: 1.1;
            transition: color .3s;
        }

        .error-card p {
            margin: 0 0 16px;
            color: var(--err-body);
            font-size: 17px;
            line-height: 1.7;
            transition: color .3s;
        }

        .error-card .muted {
            color: var(--err-muted);
            font-size: 15px;
            margin-bottom: 28px;
            transition: color .3s;
        }

            .error-card .muted strong {
                color: var(--err-counter-txt);
                font-size: 22px;
                font-weight: 900;
                transition: color .3s;
            }

        .error-card .actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            justify-content: center;
        }
</style>

<div class="error-card">
    <span class="badge">429</span>
    <h1>@L["Err_429_Heading"]</h1>

    <p>@ViewBag.Message</p>

    <p class="muted">
        @L["Err_429_Wait"] <strong id="counter">@retryAfter</strong> @L["Err_429_Seconds"]
    </p>

    <div class="actions">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
            @L["Err_BackHome"]
        </a>

        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <a class="btn btn-soft" href="@returnUrl">
                @L["Err_429_TryAgain"]
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        let seconds = Number("@retryAfter");
        const counter = document.getElementById("counter");

        const timer = setInterval(() => {
            seconds--;
            if (counter) counter.textContent = seconds;
            if (seconds <= 0) clearInterval(timer);
        }, 1000);
    </script>
}