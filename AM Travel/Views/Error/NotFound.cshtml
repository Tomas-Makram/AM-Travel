@{
    ViewData["Title"] = L["Err_404_Title"];
}

<style>
    :root {
        --err-card-bg: #fff;
        --err-card-border: #f0d8c2;
        --err-card-shadow: rgba(255,122,24,.10);
        --err-code-bg: #fff3e6;
        --err-code-txt: #ff7a18;
        --err-heading: #172033;
        --err-body: #667085;
    }

    html[data-theme="dark"] {
        --err-card-bg: #1a2236;
        --err-card-border: #283148;
        --err-card-shadow: rgba(0,0,0,.35);
        --err-code-bg: rgba(196,92,10,.22);
        --err-code-txt: #f6ba72;
        --err-heading: #dce3ed;
        --err-body: #7a8ba0;
    }

    .error-card {
        max-width: 560px;
        margin: 60px auto;
        background: var(--err-card-bg);
        border: 1px solid var(--err-card-border);
        border-radius: 32px;
        padding: 48px 40px;
        text-align: center;
        box-shadow: 0 24px 64px var(--err-card-shadow);
        transition: background .3s, border-color .3s;
    }

        .error-card .badge {
            display: inline-flex;
            padding: 10px 20px;
            border-radius: 999px;
            background: var(--err-code-bg);
            color: var(--err-code-txt);
            font-size: 28px;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 22px;
            transition: background .3s, color .3s;
        }

        .error-card h1 {
            margin: 0 0 12px;
            font-size: clamp(26px, 5vw, 38px);
            color: var(--err-heading);
            letter-spacing: -.5px;
            line-height: 1.1;
            transition: color .3s;
        }

        .error-card p {
            margin: 0 0 30px;
            color: var(--err-body);
            font-size: 17px;
            line-height: 1.7;
            transition: color .3s;
        }
</style>

<div class="error-card">
    <span class="badge">404</span>
    <h1>@L["Err_404_Heading"]</h1>
    <p>@L["Err_404_Body"]</p>
    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
        @L["Err_BackHome"]
    </a>
</div>
