@model BusinessLayer.DTOs.Account.ChangeFieldsDTO

@{
    ViewData["Title"] = L["Edit_Title"];

    string displayName = Model.FullName ?? "Administrator";

    string initials = string.Concat(
        displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(x => x[0])
    ).ToUpper();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "AM";
    }
}

<style>
    /* ── CSS Variables: Light & Dark ─────────────────────────────────────── */
    :root {
        --edit-hero-bg:       linear-gradient(135deg, #ff7a18, #ffad42);
        --edit-hero-glow:     rgba(255,122,24,.18);
        --edit-hero-text:     #fff;
        --edit-hero-sub:      rgba(255,255,255,.92);
        --edit-card-bg:       #fff;
        --edit-card-border:   #f0d8c2;
        --edit-card-shadow:   rgba(255,122,24,.10);
        --edit-input-bg:      #fffaf5;
        --edit-input-border:  #f0d8c2;
        --edit-input-text:    #172033;
        --edit-heading:       #172033;
        --edit-sub:           #667085;
        --edit-label:         #172033;
        --edit-note-bg:       #fff3e6;
        --edit-note-txt:      #9a4a00;
    }

    html[data-theme="dark"] {
        --edit-hero-bg:       linear-gradient(135deg, #c45c0a, #d97c2a);
        --edit-hero-glow:     rgba(196,92,10,.22);
        --edit-hero-text:     #f5f0eb;
        --edit-hero-sub:      rgba(245,240,235,.82);
        --edit-card-bg:       #1e2535;
        --edit-card-border:   #2d3650;
        --edit-card-shadow:   rgba(0,0,0,.28);
        --edit-input-bg:      #252d3f;
        --edit-input-border:  #3a4460;
        --edit-input-text:    #d4cbc3;
        --edit-heading:       #e8ddd5;
        --edit-sub:           #8a96a8;
        --edit-label:         #d4cbc3;
        --edit-note-bg:       rgba(196,92,10,.18);
        --edit-note-txt:      #e8b48a;
    }

    /* ── Layout ──────────────────────────────────────────────────────────── */
    .edit-page {
        display: grid;
        gap: 22px;
    }

    /* ── Hero ────────────────────────────────────────────────────────────── */
    .edit-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--edit-hero-text);
        background: var(--edit-hero-bg);
        box-shadow: 0 24px 70px var(--edit-hero-glow);
    }

        .edit-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 28%);
            pointer-events: none;
        }

        .edit-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            right: -90px;
            bottom: -110px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
        }

    .edit-hero-top {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .edit-hero-content {
        display: grid;
        gap: 10px;
    }

    .edit-badge {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--edit-hero-text);
    }

    .edit-hero h1 {
        margin: 0;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--edit-hero-text);
    }

    .edit-hero p {
        margin: 0;
        color: var(--edit-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    /* ── Avatar ──────────────────────────────────────────────────────────── */
    .account-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.10);
        flex-shrink: 0;
    }

        .account-avatar-wrap::before {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid rgba(255,255,255,.22);
        }

        .account-avatar-wrap::after {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid transparent;
            border-top-color: #fff;
            border-right-color: rgba(255,255,255,.72);
            animation: avatar-spin 4s linear infinite;
        }

    .account-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)),
                    linear-gradient(135deg, #ffffff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        text-transform: uppercase;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .account-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
        box-shadow: 0 8px 18px rgba(18,183,106,.35);
    }

    @@keyframes avatar-spin {
        to { transform: rotate(360deg); }
    }

    /* ── Hero actions ────────────────────────────────────────────────────── */
    .hero-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .hero-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
        background: rgba(255,255,255,.16);
        color: var(--edit-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

        .hero-btn:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,.24);
            color: var(--edit-hero-text);
        }

    /* ── Two-column layout ───────────────────────────────────────────────── */
    .edit-container {
        display: grid;
        grid-template-columns: 1fr 390px;
        gap: 20px;
        align-items: start;
    }

    /* ── Cards ───────────────────────────────────────────────────────────── */
    .edit-form-card,
    .side-card {
        background: var(--edit-card-bg);
        border: 1px solid var(--edit-card-border);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 42px var(--edit-card-shadow);
        transition: background .3s, border-color .3s;
    }

    .edit-form-card {
        display: grid;
        gap: 14px;
    }

    /* ── Form header ─────────────────────────────────────────────────────── */
    .form-title {
        margin-bottom: 8px;
    }

        .form-title h2 {
            margin: 0 0 6px;
            font-size: 28px;
            color: var(--edit-heading);
        }

        .form-title p {
            margin: 0;
            color: var(--edit-sub);
            line-height: 1.7;
        }

    /* ── Fields ──────────────────────────────────────────────────────────── */
    .field-group {
        display: grid;
        gap: 8px;
    }

        .field-group label {
            font-weight: 900;
            color: var(--edit-label);
        }

        .field-group input {
            width: 100%;
            border: 1px solid var(--edit-input-border);
            border-radius: 16px;
            padding: 14px 15px;
            background: var(--edit-input-bg);
            color: var(--edit-input-text);
            transition: .2s ease;
            font-size: 15px;
            outline: none;
            box-sizing: border-box;
        }

            .field-group input:focus {
                border-color: rgba(255,122,24,.6);
                background: var(--edit-card-bg);
                box-shadow: 0 0 0 5px rgba(255,122,24,.10);
            }

            .field-group input::placeholder {
                color: var(--edit-sub);
                opacity: .7;
            }

    .validation,
    .field-validation-error {
        color: #ef4444;
        font-size: 13px;
        font-weight: 700;
    }

    /* ── Submit ──────────────────────────────────────────────────────────── */
    .form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .save-btn {
        border: none;
        border-radius: 18px;
        padding: 14px 22px;
        background: linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(255,122,24,.22);
        transition: .22s ease;
        font-size: 15px;
    }

        .save-btn:hover  { transform: translateY(-2px); }
        .save-btn:active { transform: translateY(0); }

    /* ── Side card ───────────────────────────────────────────────────────── */
    .side-card h3 {
        margin: 0 0 10px;
        color: var(--edit-heading);
        font-size: 24px;
    }

    .side-card > p {
        color: var(--edit-sub);
        line-height: 1.8;
        margin: 0 0 14px;
    }

    .note-list {
        display: grid;
        gap: 12px;
        margin-top: 14px;
    }

    .note {
        background: var(--edit-note-bg);
        color: var(--edit-note-txt);
        padding: 14px;
        border-radius: 18px;
        line-height: 1.8;
        font-weight: 700;
        transition: background .3s, color .3s;
    }

    /* ── Responsive ──────────────────────────────────────────────────────── */
    @@media (max-width: 1000px) {
        .edit-container { grid-template-columns: 1fr; }

        .hero-actions,
        .form-actions { flex-direction: column; }

        .hero-btn,
        .save-btn { width: 100%; }

        .edit-hero-top { align-items: flex-start; }
    }

    @@media (max-width: 650px) {
        .edit-hero { padding: 24px; border-radius: 24px; }

        .account-avatar-wrap { width: 112px; height: 112px; border-radius: 32px; }

            .account-avatar-wrap::before,
            .account-avatar-wrap::after { border-radius: 38px; }

        .account-avatar { width: 88px; height: 88px; border-radius: 27px; font-size: 34px; }
    }
</style>

<div class="edit-page">

    @* Hero *@
    <section class="edit-hero">
        <div class="edit-hero-top">
            <div class="edit-hero-content">
                <span class="edit-badge">@L["Edit_Badge"]</span>

                <h1>@L["Edit_Heading"]</h1>

                <p>@L["Edit_WelcomeBack"], @displayName. @L["Edit_Subtitle"]</p>
            </div>

            <div class="account-avatar-wrap" title="@displayName">
                <div class="account-avatar">@initials</div>
                <span class="account-avatar-status"></span>
            </div>
        </div>

        <div class="hero-actions">
            <a class="hero-btn" asp-controller="Account" asp-action="Index">
                @L["Edit_MyAccount"]
            </a>

            <a class="hero-btn" asp-controller="Account" asp-action="ChangePassword">
                @L["Edit_ChangePassword"]
            </a>

            <a class="hero-btn" asp-controller="Dashboard" asp-action="Index">
                @L["Edit_Dashboard"]
            </a>
        </div>
    </section>

    @* Form + Side *@
    <section class="edit-container">

        <form asp-action="Edit" method="post" class="edit-form-card">
            @Html.AntiForgeryToken()

            <div class="form-title">
                <h2>@L["Edit_FormTitle"]</h2>
                <p>@L["Edit_FormSubtitle"]</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="validation"></div>

            <div class="field-group">
                <label asp-for="FullName">@L["Edit_FullName"]</label>
                <input asp-for="FullName" placeholder="@L["Edit_FullNamePH"]" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="PhoneNumber">@L["Edit_PhoneNumber"]</label>
                <input asp-for="PhoneNumber" placeholder="@L["Edit_PhoneNumberPH"]" />
                <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="NationalId">@L["Edit_NationalId"]</label>
                <input asp-for="NationalId" placeholder="@L["Edit_NationalIdPH"]" />
                <span asp-validation-for="NationalId" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">
                    @L["Edit_Submit"]
                </button>
            </div>
        </form>

        @* Side notes *@
        <aside>
            <div class="side-card">
                <h3>@L["Edit_NotesTitle"]</h3>

                <p>@L["Edit_NotesSubtitle"]</p>

                <div class="note-list">
                    <div class="note">@L["Edit_Note1"]</div>
                    <div class="note">@L["Edit_Note2"]</div>
                    <div class="note">@L["Edit_Note3"]</div>
                </div>
            </div>
        </aside>

    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}