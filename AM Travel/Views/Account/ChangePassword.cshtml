@model BusinessLayer.DTOs.Account.ChangePasswordDTO

@{
    ViewData["Title"] = L["Pwd_Title"];

    string displayName = ViewBag.FullName as string ?? "Administrator";

    var initials = displayName
        .Split(' ')
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(2)
        .Select(x => x[0])
        .Aggregate("", (a, b) => a + b)
        .ToUpper();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "AM";
    }
}

<style>
    /* ── CSS Variables ────────────────────────────────────────────────────── */
    :root {
        --pwd-hero-bg:        linear-gradient(135deg, #ff7a18, #ffad42);
        --pwd-hero-glow:      rgba(255,122,24,.18);
        --pwd-hero-text:      #fff;
        --pwd-hero-sub:       rgba(255,255,255,.92);
        --pwd-card-bg:        #fff;
        --pwd-card-border:    #f0d8c2;
        --pwd-card-shadow:    rgba(255,122,24,.10);
        --pwd-input-bg:       #fffaf5;
        --pwd-input-border:   #f0d8c2;
        --pwd-input-text:     #172033;
        --pwd-heading:        #172033;
        --pwd-sub:            #667085;
        --pwd-label:          #172033;
        --pwd-tip-bg:         #fff3e6;
        --pwd-tip-txt:        #9a4a00;
        --pwd-toggle-bg:      #fff3e6;
        --pwd-toggle-txt:     #ff7a18;
        --pwd-meter-bg:       linear-gradient(135deg, #ff7a18, #ffad42);
    }

    html[data-theme="dark"] {
        --pwd-hero-bg:        linear-gradient(135deg, #c45c0a, #d97c2a);
        --pwd-hero-glow:      rgba(196,92,10,.22);
        --pwd-hero-text:      #f5f0eb;
        --pwd-hero-sub:       rgba(245,240,235,.82);
        --pwd-card-bg:        #1e2535;
        --pwd-card-border:    #2d3650;
        --pwd-card-shadow:    rgba(0,0,0,.28);
        --pwd-input-bg:       #252d3f;
        --pwd-input-border:   #3a4460;
        --pwd-input-text:     #d4cbc3;
        --pwd-heading:        #e8ddd5;
        --pwd-sub:            #8a96a8;
        --pwd-label:          #d4cbc3;
        --pwd-tip-bg:         rgba(196,92,10,.18);
        --pwd-tip-txt:        #e8b48a;
        --pwd-toggle-bg:      rgba(196,92,10,.22);
        --pwd-toggle-txt:     #e8925a;
        --pwd-meter-bg:       linear-gradient(135deg, #c45c0a, #d97c2a);
    }

    /* ── Layout ──────────────────────────────────────────────────────────── */
    .password-page {
        display: grid;
        gap: 22px;
    }

    /* ── Hero ────────────────────────────────────────────────────────────── */
    .password-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 32px;
        color: var(--pwd-hero-text);
        background: var(--pwd-hero-bg);
        box-shadow: 0 24px 70px var(--pwd-hero-glow);
    }

        .password-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 12% 15%, rgba(255,255,255,.18), transparent 28%);
            pointer-events: none;
        }

        .password-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            right: -90px;
            bottom: -110px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
        }

    .password-hero-inner {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        flex-wrap: wrap;
    }

    .password-hero-content {
        display: grid;
        gap: 10px;
    }

    .password-badge {
        width: fit-content;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.24);
        font-weight: 900;
        color: var(--pwd-hero-text);
    }

    .password-hero h1 {
        margin: 0;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: -1px;
        color: var(--pwd-hero-text);
    }

    .password-hero p {
        margin: 0;
        color: var(--pwd-hero-sub);
        font-size: 17px;
        line-height: 1.7;
    }

    /* ── Avatar ──────────────────────────────────────────────────────────── */
    .password-avatar-wrap {
        position: relative;
        width: 132px;
        height: 132px;
        display: grid;
        place-items: center;
        border-radius: 38px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(12px);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.10);
        flex-shrink: 0;
    }

        .password-avatar-wrap::before {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid rgba(255,255,255,.22);
        }

        .password-avatar-wrap::after {
            content: "";
            position: absolute;
            inset: -7px;
            border-radius: 44px;
            border: 3px solid transparent;
            border-top-color: #fff;
            border-right-color: rgba(255,255,255,.72);
            animation: password-avatar-spin 4s linear infinite;
        }

    .password-avatar {
        position: relative;
        z-index: 2;
        width: 104px;
        height: 104px;
        border-radius: 32px;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 30% 20%, rgba(255,255,255,.9), rgba(255,255,255,.72)),
                    linear-gradient(135deg, #ffffff, #fff3e6);
        color: #ff7a18;
        border: 1px solid rgba(255,255,255,.55);
        font-size: 42px;
        font-weight: 1000;
        letter-spacing: -1px;
        text-transform: uppercase;
        box-shadow: 0 18px 38px rgba(0,0,0,.16);
    }

    .password-avatar-status {
        position: absolute;
        right: 13px;
        bottom: 13px;
        z-index: 3;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #12b76a;
        border: 4px solid #fff;
        box-shadow: 0 8px 18px rgba(18,183,106,.35);
    }

    @@keyframes password-avatar-spin {
        to { transform: rotate(360deg); }
    }

    /* ── Hero actions ────────────────────────────────────────────────────── */
    .hero-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .hero-btn {
        min-height: 46px;
        padding: 12px 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        transition: .2s ease;
        background: rgba(255,255,255,.16);
        color: var(--pwd-hero-text);
        border: 1px solid rgba(255,255,255,.24);
    }

        .hero-btn:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,.24);
            color: var(--pwd-hero-text);
        }

    /* ── Two-column layout ───────────────────────────────────────────────── */
    .password-layout {
        display: grid;
        grid-template-columns: 1fr 390px;
        gap: 20px;
        align-items: start;
    }

    /* ── Cards ───────────────────────────────────────────────────────────── */
    .password-form-card,
    .password-side-card {
        background: var(--pwd-card-bg);
        border: 1px solid var(--pwd-card-border);
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 42px var(--pwd-card-shadow);
        transition: background .3s, border-color .3s;
    }

    .password-form-card {
        display: grid;
        gap: 16px;
    }

    /* ── Form header ─────────────────────────────────────────────────────── */
    .form-title h2 {
        margin: 0 0 6px;
        color: var(--pwd-heading);
        font-size: 28px;
    }

    .form-title p {
        margin: 0;
        color: var(--pwd-sub);
        line-height: 1.7;
    }

    /* ── Fields ──────────────────────────────────────────────────────────── */
    .password-field {
        display: grid;
        gap: 8px;
    }

        .password-field label {
            font-weight: 900;
            color: var(--pwd-label);
        }

    .password-input-wrap {
        position: relative;
    }

        .password-input-wrap input {
            width: 100%;
            border: 1px solid var(--pwd-input-border);
            border-radius: 16px;
            padding: 14px 56px 14px 15px;
            background: var(--pwd-input-bg);
            color: var(--pwd-input-text);
            transition: .2s ease;
            font-size: 15px;
            outline: none;
            box-sizing: border-box;
        }

            .password-input-wrap input:focus {
                border-color: rgba(255,122,24,.6);
                background: var(--pwd-card-bg);
                box-shadow: 0 0 0 5px rgba(255,122,24,.10);
            }

            .password-input-wrap input::placeholder {
                color: var(--pwd-sub);
                opacity: .7;
            }

    .password-toggle {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 13px;
        background: var(--pwd-toggle-bg);
        color: var(--pwd-toggle-txt);
        display: grid;
        place-items: center;
        cursor: pointer;
        transition: .2s ease;
        font-weight: 900;
    }

        .password-toggle:hover {
            background: #ff7a18;
            color: #fff;
        }

    .validation,
    .field-validation-error {
        color: #ef4444;
        font-size: 13px;
        font-weight: 700;
    }

    /* ── Submit ──────────────────────────────────────────────────────────── */
    .form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .change-btn {
        border: none;
        border-radius: 18px;
        padding: 14px 22px;
        background: linear-gradient(135deg, #ff7a18, #ffad42);
        color: #fff;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(255,122,24,.22);
        transition: .22s ease;
        font-size: 15px;
    }

        .change-btn:hover { transform: translateY(-2px); }
        .change-btn:active { transform: translateY(0); }

    /* ── Side card ───────────────────────────────────────────────────────── */
    .password-side-card h3 {
        margin: 0 0 10px;
        color: var(--pwd-heading);
        font-size: 24px;
    }

    .password-side-card > p {
        color: var(--pwd-sub);
        line-height: 1.8;
        margin: 0 0 14px;
    }

    .security-list {
        display: grid;
        gap: 12px;
        margin-top: 14px;
    }

    .security-note {
        background: var(--pwd-tip-bg);
        color: var(--pwd-tip-txt);
        padding: 14px;
        border-radius: 18px;
        line-height: 1.8;
        font-weight: 700;
    }

    /* ── Strength meter ──────────────────────────────────────────────────── */
    .security-meter {
        margin-top: 14px;
        padding: 16px;
        border-radius: 20px;
        background: var(--pwd-meter-bg);
        color: #fff;
    }

    .meter-label {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        font-weight: 900;
    }

    .meter-bar {
        height: 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.26);
        overflow: hidden;
    }

    .meter-fill {
        width: 0%;
        height: 100%;
        border-radius: inherit;
        background: #fff;
        transition: width .25s ease;
    }

    /* ── Responsive ──────────────────────────────────────────────────────── */
    @@media (max-width: 1000px) {
        .password-layout { grid-template-columns: 1fr; }

        .form-actions { flex-direction: column; }

        .change-btn { width: 100%; }
    }

    @@media (max-width: 650px) {
        .password-hero { padding: 24px; border-radius: 24px; }

        .hero-actions { flex-direction: column; }

        .hero-btn { width: 100%; }

        .password-avatar-wrap { width: 112px; height: 112px; border-radius: 32px; }

            .password-avatar-wrap::before,
            .password-avatar-wrap::after { border-radius: 38px; }

        .password-avatar { width: 88px; height: 88px; font-size: 34px; border-radius: 27px; }
    }
</style>

<div class="password-page">

    @* Hero *@
    <section class="password-hero">
        <div class="password-hero-inner">
            <div class="password-hero-content">
                <span class="password-badge">@L["Pwd_Badge"]</span>

                <h1>@L["Pwd_Title"]</h1>

                <p>@L["Pwd_WelcomeBack"], @displayName. @L["Pwd_Subtitle"]</p>
            </div>

            <div class="password-avatar-wrap" title="@displayName">
                <div class="password-avatar">@initials</div>
                <span class="password-avatar-status"></span>
            </div>
        </div>

        <div class="hero-actions">
            <a class="hero-btn" asp-controller="Account" asp-action="Index">
                @L["Pwd_MyAccount"]
            </a>

            <a class="hero-btn" asp-controller="Account" asp-action="Edit">
                @L["Pwd_EditProfile"]
            </a>

            <a class="hero-btn" asp-controller="Dashboard" asp-action="Index">
                @L["Pwd_Dashboard"]
            </a>
        </div>
    </section>

    @* Form + Side *@
    <section class="password-layout">

        <form asp-action="ChangePassword" method="post" class="password-form-card">
            @Html.AntiForgeryToken()

            <div class="form-title">
                <h2>@L["Pwd_FormTitle"]</h2>
                <p>@L["Pwd_FormSubtitle"]</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="validation"></div>

            @* Current Password *@
            <div class="password-field">
                <label asp-for="OldPassword">@L["Pwd_OldPassword"]</label>

                <div class="password-input-wrap">
                    <input asp-for="OldPassword"
                           id="oldPassword"
                           type="password"
                           placeholder="@L["Pwd_OldPlaceholder"]"
                           autocomplete="current-password" />

                    <button type="button" class="password-toggle" data-target="oldPassword">👁</button>
                </div>

                <span asp-validation-for="OldPassword" class="field-validation-error"></span>
            </div>

            @* New Password *@
            <div class="password-field">
                <label asp-for="NewPassword">@L["Pwd_NewPassword"]</label>

                <div class="password-input-wrap">
                    <input asp-for="NewPassword"
                           id="newPassword"
                           type="password"
                           placeholder="@L["Pwd_NewPlaceholder"]"
                           autocomplete="new-password" />

                    <button type="button" class="password-toggle" data-target="newPassword">👁</button>
                </div>

                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            @* Confirm Password *@
            <div class="password-field">
                <label asp-for="ConfirmPassword">@L["Pwd_ConfirmPassword"]</label>

                <div class="password-input-wrap">
                    <input asp-for="ConfirmPassword"
                           id="confirmPassword"
                           type="password"
                           placeholder="@L["Pwd_ConfirmPlaceholder"]"
                           autocomplete="new-password" />

                    <button type="button" class="password-toggle" data-target="confirmPassword">👁</button>
                </div>

                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button class="change-btn" type="submit">
                    @L["Pwd_Submit"]
                </button>
            </div>
        </form>

        @* Side tips *@
        <aside>
            <div class="password-side-card">
                <h3>@L["Pwd_TipsTitle"]</h3>

                <p>@L["Pwd_TipsSubtitle"]</p>

                <div class="security-list">
                    <div class="security-note">@L["Pwd_Tip1"]</div>
                    <div class="security-note">@L["Pwd_Tip2"]</div>
                    <div class="security-note">@L["Pwd_Tip3"]</div>
                </div>

                <div class="security-meter">
                    <div class="meter-label">
                        <span>@L["Pwd_StrengthLabel"]</span>
                        <span id="strengthText">@L["Pwd_StrengthEmpty"]</span>
                    </div>

                    <div class="meter-bar">
                        <div id="strengthFill" class="meter-fill"></div>
                    </div>
                </div>
            </div>
        </aside>

    </section>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const strengthLabels = {
            empty:  "@L["Pwd_StrengthEmpty"]",
            weak:   "@L["Pwd_StrengthWeak"]",
            good:   "@L["Pwd_StrengthGood"]",
            strong: "@L["Pwd_StrengthStrong"]"
        };

        document.querySelectorAll(".password-toggle").forEach(button => {
            button.addEventListener("click", function () {
                const targetId = this.getAttribute("data-target");
                const input    = document.getElementById(targetId);
                if (!input) return;
                const isPassword = input.type === "password";
                input.type       = isPassword ? "text" : "password";
                this.textContent = isPassword ? "🙈" : "👁";
            });
        });

        const newPassword  = document.getElementById("newPassword");
        const strengthFill = document.getElementById("strengthFill");
        const strengthText = document.getElementById("strengthText");

        function calculateStrength(value) {
            let score = 0;
            if (value.length >= 8)          score++;
            if (/[A-Z]/.test(value))        score++;
            if (/[a-z]/.test(value))        score++;
            if (/[0-9]/.test(value))        score++;
            if (/[^A-Za-z0-9]/.test(value)) score++;
            return score;
        }

        if (newPassword) {
            newPassword.addEventListener("input", function () {
                const value   = this.value || "";
                const score   = calculateStrength(value);
                const percent = score * 20;

                strengthFill.style.width = percent + "%";

                if      (score === 0) strengthText.textContent = strengthLabels.empty;
                else if (score <= 2)  strengthText.textContent = strengthLabels.weak;
                else if (score <= 4)  strengthText.textContent = strengthLabels.good;
                else                  strengthText.textContent = strengthLabels.strong;
            });
        }
    </script>
}